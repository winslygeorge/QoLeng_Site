<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>Qoleng - Build Bold. Run Fast. Scale Wild.</title>  
    <link rel="icon" href="https://placehold.co/32x32/17183B/FFFBFF?text=DF" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;600;700&family=Roboto:wght@400;500&family=Open+Sans:wght@400;600&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/static/assets/css/style.css">
    <script src="/static/assets/js/main.js"></script>
    <script src="/static/assets/js/Fluid-Container.umd.min.js"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'laser-blue': '#0066FF',
                        'build-green': '#00CC88',
                        'query-purple': '#8A2BE2',
                        'warning-amber': '#FFB300',
                        'neural-charcoal': '#2A2A3A',
                        'light-surface': '#FFFFFF',
                        'light-border': '#E0E5EC',
                        'light-text-secondary': '#5A6578',
                        'quantum-white': '#FBFBFF',
                    },
                    fontFamily: {
                        'heading': ['Segoe UI', 'Tahoma', 'Geneva', 'Verdana', 'sans-serif'],
                        'body': ['Segoe UI', 'Tahoma', 'Geneva', 'Verdana', 'sans-serif'],
                    },
                    animation: {
                        'fadeIn': 'fadeIn 0.5s ease',
                        'slideDown': 'slideDown 0.3s ease-out',
                        'pulse': 'pulse 2s infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            from: { opacity: 0 },
                            to: { opacity: 1 }
                        },
                        slideDown: {
                            from: { opacity: 0, transform: 'translateY(-10px)' },
                            to: { opacity: 1, transform: 'translateY(0)' }
                        },
                        pulse: {
                            '0%': { boxShadow: '0 0 0 0 rgba(0, 204, 136, 0.7)' },
                            '70%': { boxShadow: '0 0 0 10px rgba(0, 204, 136, 0)' },
                            '100%': { boxShadow: '0 0 0 0 rgba(0, 204, 136, 0)' }
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme Variables - Light Mode Default */
        :root {
            /* Light Theme Colors */
            --quantum-black: #0A0A0F;
            --laser-blue: #0066FF;
            --neural-grey: #E0E5EC;
            --build-green: #00CC88;
            --query-purple: #8A2BE2;
            --warning-amber: #FFB300;
            --dark-surface: #151520;
            --dark-border: #2A2A3A;
            --dark-text-secondary: #A0A5B5;
            --quantum-white: #FBFBFF;
            --neural-charcoal: #2A2A3A;
            --light-surface: #FFFFFF;
            --light-border: #E0E5EC;
            --light-text-secondary: #5A6578;

            /* Light Mode Variables (Default) */
            --bg-primary: var(--quantum-white);
            --bg-surface: var(--light-surface);
            --text-primary: var(--neural-charcoal);
            --text-secondary: var(--light-text-secondary);
            --border-color: var(--light-border);
            --bg-card : var(--quantum-white);
        }

        /* Dark Mode Variables */
        body.dark-theme {
            --bg-primary: var(--quantum-black);
            --bg-surface: var(--dark-surface);
            --text-primary: var(--neural-grey);
            --text-secondary: var(--dark-text-secondary);
            --border-color: var(--dark-border);
            --bg-card : var(--dark-surface);
        }

        /* Base styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        header {
            width: 100%;
            z-index: 100;
        }

        .footer {
            background-color: var(--bg-surface);
            color: var(--text-secondary);
            text-align: center;
            padding: 1.5rem 0;
            border-top: 1px solid var(--border-color);
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        /* Main content container */
        .main-content {
            display: flex;
            flex-direction: row;
            height: 80vh;
            width: 100%;
            overflow: hidden;
            transition: all 0.4s ease;
        }

        /* Main body */
        .main-content-body {
            flex: 1;
            background-color: var(--bg-surface);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-y: auto;
            padding: 2rem 3rem;
            min-height: 100vh;
            transition: all 0.3s ease;
        }

        /* Content styles */
        .content-section {
            margin-bottom: 3rem;
            animation: fadeIn 0.8s ease;
        }

        .content-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            background: linear-gradient(90deg, var(--laser-blue), var(--build-green));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            position: relative;
            padding-bottom: 0.5rem;
        }

        .content-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100px;
            height: 4px;
            background: linear-gradient(90deg, var(--laser-blue), var(--build-green));
            border-radius: 2px;
        }

        .content-card {
            background-color: var(--bg-surface);
            border-radius: 12px;
            padding: 2rem;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            border: 1px solid var(--border-color);
            margin-bottom: 1.5rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
        }

        .content-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .card-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .card-title i {
            color: var(--laser-blue);
        }

        .card-content {
            color: var(--text-secondary);
            line-height: 1.7;
        }

        .code-block {
            background: var(--bg-primary);
            border-radius: 8px;
            padding: 1.5rem;
            margin: 1.5rem 0;
            font-family: 'Courier New', monospace;
            overflow-x: auto;
            border-left: 4px solid var(--laser-blue);
            transition: background-color 0.3s ease;
        }

        .code-keyword {
            color: var(--laser-blue);
        }

        .code-string {
            color: var(--build-green);
        }

        .code-comment {
            color: #6A737D;
        }

        body.dark-theme .code-comment {
            color: #b5a09a;
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Mobile responsiveness */
        @media (max-width: 1024px) {
            body {
                flex-direction: column;
            }
            
            .main-content {
                flex-direction: column;
                height: auto;
                overflow: visible;
            }
            
            .main-content-body {
                padding: 1.5rem;
            }
        }
    </style>
</head>
<body>

    {{{children.header}}}
    <main class="main-content">
        {{{children.nav}}} 
        {{{children.body}}} 
    </main>

    {{{layout_data.body_extra}}}

    <script type="module">
        import {
            bindStateToDOM,
            initializeBindings
        } from '/static/assets/js/domBindings.js';

        import {
            getState,
            dispatch,
        } from '/static/assets/js/clientStore.js';

        document.addEventListener("DOMContentLoaded", () => {
            initializeBindings(dispatch);
            bindStateToDOM(getState(), dispatch);
        });
    </script>
    <script type="module" src="/reactors/_index.js"></script>
</body>
</html>