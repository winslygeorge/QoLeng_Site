                </div>
                <pre><code><span class="comment">// Optimistic update with rollback</span>
<span class="keyword">let</span> lastTaskId = <span class="keyword">null</span>;

registerReducer(<span class="string">"OPTIMISTIC_ADD_TASK"</span>, (state, action) => {
    <span class="keyword">const</span> { title } = action;
    <span class="keyword">const</span> tempId = Date.now();
    lastTaskId = tempId;
    
    <span class="keyword">const</span> optimisticTask = {
        id: tempId,
        title: title,
        completed: <span class="keyword">false</span>,
        syncing: <span class="keyword">true</span>
    };
    
    <span class="comment">// Optimistically update UI</span>
    <span class="keyword">const</span> newState = {
        ...state,
        tasks: [...state.tasks, optimisticTask]
    };
    
    <span class="comment">// Attempt server sync</span>
    fetch(<span class="string">'/api/tasks'</span>, {
        method: <span class="string">'POST'</span>,
        headers: { <span class="string">'Content-Type'</span>: <span class="string">'application/json'</span> },
        body: JSON.stringify({ title })
    })
    .then(res => res.json())
    .then(serverTask => {
        dispatch({ type: <span class="string">"REPLACE_TASK"</span>, tempId, task: serverTask });
    })
    .catch(error => {
        <span class="comment">// Rollback on error</span>
        dispatch({ type: <span class="string">"REMOVE_TASK"</span>, id: tempId });
    });
    
    <span class="keyword">return</span> newState;
});</code></pre>
