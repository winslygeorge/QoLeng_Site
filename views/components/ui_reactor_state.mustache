        <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center text-white font-bold mr-4">10</div>
            <h2 class="text-3xl font-bold">Best Practices</h2>
        </div>
        
        <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="p-4 bg-green-50 rounded-lg">
                    <h3 class="font-bold text-green-800 mb-2">✅ DO</h3>
                    <ul class="list-disc pl-5 text-sm space-y-1">
                        <li>Use UI-Reactor for all UI state that doesn't need persistence</li>
                        <li>Keep reducers pure and predictable</li>
                        <li>Use descriptive action type names (UPPER_CASE)</li>
                        <li>Enable persistence for user preferences and drafts</li>
                        <li>Use middleware for logging, analytics, and async operations</li>
                        <li>Leverage computed selectors for derived data</li>
                        <li>Enable dev tools in development for debugging</li>
                        <li>Use compression for large state slices</li>
                        <li>Set appropriate TTL for persisted data</li>
                    </ul>
                </div>
                
                <div class="p-4 bg-red-50 rounded-lg">
                    <h3 class="font-bold text-red-800 mb-2">❌ DON'T</h3>
                    <ul class="list-disc pl-5 text-sm space-y-1">
                        <li>Don't mutate state directly - always use reducers</li>
                        <li>Don't store sensitive data (no encryption)</li>
                        <li>Don't store large binary data (use IndexedDB)</li>
                        <li>Don't put complex business logic in reducers</li>
                        <li>Don't forget to unsubscribe on component unmount</li>
                        <li>Don't rely on UI-Reactor for critical server-side validation</li>
                        <li>Don't store circular references (JSON.stringify will fail)</li>
                        <li>Don't over-persist - use TTL for temporary data</li>
                    </ul>
                </div>
            </div>
            
            <h3 class="text-xl font-bold mt-8 mb-3">Performance Tips</h3>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-javascript">// 1. Batch updates when possible
dispatch({ type: "BATCH_UPDATE", updates: { a: 1, b: 2, c: 3 } });

registerReducer("BATCH_UPDATE", (state, action) => {
    return { ...state, ...action.updates };
});

// 2. Use shallow equality for change detection
registerReducer("UPDATE_ITEM", (state, action) => {
    const items = state.items.map(item => {
        if (item.id === action.id) {
            return { ...item, ...action.updates };
        }
        return item;
    });
    
    // Only create new array if actually changed
    if (JSON.stringify(state.items) === JSON.stringify(items)) {
        return state; // No change, prevent re-render
    }
    
    return { ...state, items };
});

// 3. Debounce high-frequency updates
let searchTimeout;
registerReducer("SEARCH", (state, action) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        dispatch({ type: "PERFORM_SEARCH", query: action.query });
    }, 300);
    return state;
});

// 4. Use lazy binding for expensive inputs
// &lt;input ui-model.lazy="searchQuery"&gt;  // Only updates on blur

// 5. Limit loop items with pagination
// &lt;div ui-loop="item in items"&gt;...&lt;/div&gt;
// Use __page and __perPage for pagination

// 6. Compress large persisted slices
enablePersistenceSlice("largeData", { compressed: true });

// 7. Clean up subscriptions on page unload
window.addEventListener('beforeunload', () => {
    unsubscribeAll();
});</code></pre>
