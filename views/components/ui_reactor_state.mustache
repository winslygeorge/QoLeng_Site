    <section id="best-practices" class="doc-section mb-16">
        <div class="flex items-center mb-6">
            <div class="section-number">10</div>
            <h2 class="section-title">Best Practices</h2>
        </div>
        
        <div class="rounded-xl p-6 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="grid md:grid-cols-2 gap-6 mb-6">
                <div class="success-box">
                    <h3 class="font-bold mb-2">✅ DO</h3>
                    <ul class="list-disc pl-5 text-sm space-y-1">
                        <li>Use UI-Reactor for all UI state that doesn't need persistence</li>
                        <li>Keep reducers pure and predictable</li>
                        <li>Use descriptive action type names (UPPER_CASE)</li>
                        <li>Enable persistence for user preferences and drafts</li>
                        <li>Use middleware for logging, analytics, and async operations</li>
                        <li>Leverage computed selectors for derived data</li>
                        <li>Enable dev tools in development for debugging</li>
                    </ul>
                </div>
                
                <div class="warning-box">
                    <h3 class="font-bold mb-2">❌ DON'T</h3>
                    <ul class="list-disc pl-5 text-sm space-y-1">
                        <li>Don't mutate state directly - always use reducers</li>
                        <li>Don't store sensitive data (no encryption)</li>
                        <li>Don't store large binary data (use IndexedDB)</li>
                        <li>Don't put complex business logic in reducers</li>
                        <li>Don't forget to unsubscribe on component unmount</li>
                        <li>Don't store circular references (JSON.stringify will fail)</li>
                    </ul>
                </div>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fas fa-bolt"></i> Performance Tips</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">// 1. Batch updates when possible</span>
dispatch({ type: <span class="string">"BATCH_UPDATE"</span>, updates: { a: <span class="number">1</span>, b: <span class="number">2</span>, c: <span class="number">3</span> } });

<span class="comment">// 2. Use shallow equality for change detection</span>
registerReducer(<span class="string">"UPDATE_ITEM"</span>, (state, action) => {
    <span class="keyword">const</span> items = state.items.map(item => {
        <span class="keyword">if</span> (item.id === action.id) {
            <span class="keyword">return</span> { ...item, ...action.updates };
        }
        <span class="keyword">return</span> item;
    });
    
    <span class="comment">// Only create new array if actually changed</span>
    <span class="keyword">if</span> (JSON.stringify(state.items) === JSON.stringify(items)) {
        <span class="keyword">return</span> state;
    }
    
    <span class="keyword">return</span> { ...state, items };
});

<span class="comment">// 3. Debounce high-frequency updates</span>
<span class="keyword">let</span> searchTimeout;
registerReducer(<span class="string">"SEARCH"</span>, (state, action) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        dispatch({ type: <span class="string">"PERFORM_SEARCH"</span>, query: action.query });
    }, <span class="number">300</span>);
    <span class="keyword">return</span> state;
});</code></pre>
