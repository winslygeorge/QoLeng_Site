            <h3 class="text-xl font-bold mt-6 mb-3">Pattern 2: Computed Values with Selectors</h3>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-javascript">// Selector pattern for computed values
const selectors = {
    filteredTasks: (state) => {
        let tasks = state.tasks;
        
        if (state.filter === "active") {
            tasks = tasks.filter(t => !t.completed);
        } else if (state.filter === "completed") {
            tasks = tasks.filter(t => t.completed);
        }
        
        if (state.searchQuery) {
            const query = state.searchQuery.toLowerCase();
            tasks = tasks.filter(t => t.title.toLowerCase().includes(query));
        }
        
        return tasks;
    },
    
    taskStats: (state) => ({
        total: state.tasks.length,
        active: state.tasks.filter(t => !t.completed).length,
        completed: state.tasks.filter(t => t.completed).length
    }),
    
    paginatedTasks: (state) => {
        const filtered = selectors.filteredTasks(state);
        const page = state.__page.tasks || 1;
        const perPage = state.__perPage.tasks || 10;
        const start = (page - 1) * perPage;
        
        return filtered.slice(start, start + perPage);
    }
};

// Update computed values when state changes
subscribe((state) => {
    const filtered = selectors.filteredTasks(state);
    const stats = selectors.taskStats(state);
    const paginated = selectors.paginatedTasks(state);
    
    dispatch({ 
        type: "UPDATE_COMPUTED", 
        filtered, 
        stats, 
        paginated 
    });
});</code></pre>
            </div>
            
            <h3 class="text-xl font-bold mt-6 mb-3">Pattern 3: Optimistic Updates</h3>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-javascript">// Optimistic update with rollback
let lastTaskId = null;

registerReducer("OPTIMISTIC_ADD_TASK", (state, action) => {
    const { title } = action;
    const tempId = Date.now();
    lastTaskId = tempId;
    
    const optimisticTask = {
        id: tempId,
        title: title,
        completed: false,
        syncing: true  // Mark as syncing
    };
    
    // Optimistically update UI
    const newState = {
        ...state,
        tasks: [...state.tasks, optimisticTask]
    };
    
    // Attempt server sync
    fetch('/api/tasks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title })
    })
    .then(res => res.json())
    .then(serverTask => {
        // Replace temp task with server task
        dispatch({ 
            type: "REPLACE_TASK", 
            tempId: tempId, 
            task: serverTask 
        });
    })
    .catch(error => {
        // Rollback on error
        dispatch({ 
            type: "REMOVE_TASK", 
            id: tempId 
        });
        dispatch({ 
            type: "SHOW_ERROR", 
            message: "Failed to save task" 
        });
    });
    
    return newState;
});</code></pre>
            </div>
            
            <h3 class="text-xl font-bold mt-6 mb-3">Pattern 4: Derived State with Subscriptions</h3>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-javascript">// Derived state with automatic updates
const derivedState = {
    activeTasks: [],
    completedTasks: [],
    taskGroups: {}
};

// Subscribe to calculate derived state
subscribe((state) => {
    derivedState.activeTasks = state.tasks.filter(t => !t.completed);
    derivedState.completedTasks = state.tasks.filter(t => t.completed);
    
    derivedState.taskGroups = state.tasks.reduce((groups, task) => {
        const group = task.group || "ungrouped";
        if (!groups[group]) groups[group] = [];
        groups[group].push(task);
        return groups;
    }, {});
    
    // Update UI with derived values
    document.querySelectorAll('[data-derived="activeCount"]').forEach(el => {
        el.textContent = derivedState.activeTasks.length;
    });
});

// Use derived state in components
// &lt;span data-derived="activeCount"&gt;0&lt;/span&gt;</code></pre>
            </div>
        </div>
