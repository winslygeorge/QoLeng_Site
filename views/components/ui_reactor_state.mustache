        <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
            <h3 class="text-xl font-bold mb-4">Store Initialization & Management</h3>
            
            <table class="api-table">
                <thead>
                    <tr><th>Function</th><th>Description</th><th>Example</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>initializeStore(initialState)</code></td>
                        <td>Initialize the global store with initial state</td>
                        <td><code>initializeStore({ count: 0, users: [] })</code></td>
                    </tr>
                    <tr>
                        <td><code>registerReducer(type, reducer)</code></td>
                        <td>Register a reducer function for an action type</td>
                        <td><code>registerReducer("INCREMENT", (state) => ({ count: state.count + 1 }))</code></td>
                    </tr>
                    <tr>
                        <td><code>dispatch(action)</code></td>
                        <td>Dispatch an action to update state</td>
                        <td><code>dispatch({ type: "INCREMENT" })</code></td>
                    </tr>
                    <tr>
                        <td><code>getState()</code></td>
                        <td>Get current state (returns a copy)</td>
                        <td><code>const state = getState()</code></td>
                    </tr>
                    <tr>
                        <td><code>subscribe(callback)</code></td>
                        <td>Subscribe to state changes (returns unsubscribe function)</td>
                        <td><code>const unsub = subscribe((state) => console.log(state))</code></td>
                    </tr>
                    <tr>
                        <td><code>hydrateStore(serverState)</code></td>
                        <td>Hydrate store with server-side state</td>
                        <td><code>hydrateStore({ tasks: serverTasks })</code></td>
                    </tr>
                    <tr>
                        <td><code>unsubscribeAll()</code></td>
                        <td>Remove all subscribers</td>
                        <td><code>unsubscribeAll()</code></td>
                    </tr>
                </tbody>
            </table>
            
            <h3 class="text-xl font-bold mt-6 mb-4">Event System</h3>
            
            <table class="api-table">
                <thead>
                    <tr><th>Function</th><th>Description</th><th>Example</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>on(event, callback)</code></td>
                        <td>Subscribe to store events</td>
                        <td><code>on("persist:done", (key) => console.log("Saved:", key))</code></td>
                    </tr>
                    <tr>
                        <td><code>emit(event, data)</code></td>
                        <td>Emit events (internal use)</td>
                        <td><code>emit("persist:expired", "userPrefs")</code></td>
                    </tr>
                </tbody>
            </table>
            
            <h3 class="text-xl font-bold mt-6 mb-4">DevTools & History</h3>
            
            <table class="api-table">
                <thead>
                    <tr><th>Function</th><th>Description</th><th>Example</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>enableDevTools(options)</code></td>
                        <td>Enable development tools with logging and history</td>
                        <td><code>enableDevTools({ log: true, history: true, max: 50 })</code></td>
                    </tr>
                    <tr>
                        <td><code>getStateHistory()</code></td>
                        <td>Get history of state changes</td>
                        <td><code>const history = getStateHistory()</code></td>
                    </tr>
                    <tr>
                        <td><code>undoState()</code></td>
                        <td>Undo last state change</td>
                        <td><code>undoState()</code></td>
                    </tr>
                </tbody>
            </table>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-javascript">// Complete store initialization example
import { 
    initializeStore, 
    registerReducer, 
    dispatch, 
    getState, 
    subscribe,
    enableDevTools,
    on
} from '/static/assets/js/clientStore.js';

// Enable dev tools
enableDevTools({ log: true, history: true, max: 50 });

// Initial state
const initialState = {
    tasks: [],
    filter: "all",
    searchQuery: "",
    __page: { tasks: 1 },
    __perPage: { tasks: 5 }
};

// Initialize store
initializeStore(initialState);

// Register reducers
registerReducer("ADD_TASK", (state, action) => {
    return {
        ...state,
        tasks: [...state.tasks, {
            id: Date.now(),
            title: action.title,
            completed: false
        }]
    };
});

registerReducer("SET_FILTER", (state, action) => {
    return {
        ...state,
        filter: action.filter,
        __page: { ...state.__page, tasks: 1 }
    };
});

// Subscribe to changes
const unsubscribe = subscribe((state) => {
    console.log("State updated:", state);
    // Update DOM bindings automatically
});

// Listen for persistence events
on("persist:done", (key) => {
    console.log(`State slice "${key}" persisted`);
});

// Dispatch actions
dispatch({ type: "ADD_TASK", title: "Learn UI-Reactor" });
dispatch({ type: "SET_FILTER", filter: "active" });</code></pre>
