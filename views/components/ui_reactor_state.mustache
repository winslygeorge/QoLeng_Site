        </div>
        
        <div class="rounded-xl p-6 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <h3 class="text-xl font-bold mb-4">Store Initialization & Management</h3>
            
            <table class="api-table">
                <thead>
                    <tr><th>Function</th><th>Description</th><th>Example</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>initializeStore(initialState)</code></td>
                        <td>Initialize the global store with initial state</td>
                        <td><code>initializeStore({ count: 0, users: [] })</code></td>
                    </tr>
                    <tr>
                        <td><code>registerReducer(type, reducer)</code></td>
                        <td>Register a reducer function for an action type</td>
                        <td><code>registerReducer("INCREMENT", (state) => ({ count: state.count + 1 }))</code></td>
                    </tr>
                    <tr>
                        <td><code>dispatch(action)</code></td>
                        <td>Dispatch an action to update state</td>
                        <td><code>dispatch({ type: "INCREMENT" })</code></td>
                    </tr>
                    <tr>
                        <td><code>getState()</code></td>
                        <td>Get current state (returns a copy)</td>
                        <td><code>const state = getState()</code></td>
                    </tr>
                    <tr>
                        <td><code>subscribe(callback)</code></td>
                        <td>Subscribe to state changes (returns unsubscribe function)</td>
                        <td><code>const unsub = subscribe((state) => console.log(state))</code></td>
                    </tr>
                    <tr>
                        <td><code>hydrateStore(serverState)</code></td>
                        <td>Hydrate store with server-side state</td>
                        <td><code>hydrateStore({ tasks: serverTasks })</code></td>
                    </tr>
                </tbody>
            </table>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-js"></i> JavaScript - Store Initialization</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="keyword">import</span> { 
    initializeStore, 
    registerReducer, 
    dispatch, 
    getState, 
    subscribe,
    enableDevTools
} <span class="keyword">from</span> <span class="string">'/static/assets/js/clientStore.js'</span>;

<span class="comment">// Enable dev tools for debugging</span>
enableDevTools({ log: <span class="keyword">true</span>, history: <span class="keyword">true</span>, max: <span class="number">50</span> });

<span class="comment">// Initial state</span>
<span class="keyword">const</span> initialState = {
    tasks: [],
    filter: <span class="string">"all"</span>,
    searchQuery: <span class="string">""</span>,
    __page: { tasks: <span class="number">1</span> },
    __perPage: { tasks: <span class="number">5</span> }
};

<span class="comment">// Initialize store</span>
initializeStore(initialState);

<span class="comment">// Register reducers</span>
registerReducer(<span class="string">"ADD_TASK"</span>, (state, action) => {
    <span class="keyword">return</span> {
        ...state,
        tasks: [...state.tasks, {
            id: Date.now(),
            title: action.title,
            completed: <span class="keyword">false</span>
        }]
    };
});

<span class="comment">// Subscribe to changes</span>
<span class="keyword">const</span> unsubscribe = subscribe((state) => {
    console.log(<span class="string">"State updated:"</span>, state);
});

<span class="comment">// Dispatch actions</span>
dispatch({ type: <span class="string">"ADD_TASK"</span>, title: <span class="string">"Learn UI-Reactor"</span> });</code></pre>
            </div>
        </div>
    </section>

