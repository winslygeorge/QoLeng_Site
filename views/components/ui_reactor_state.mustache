        &lt;/button&gt;
        &lt;button ui-class="active:filter === 'active'"
                ui-on="click:SET_FILTER(active)"&gt;
            Active
        &lt;/button&gt;
        &lt;button ui-class="active:filter === 'completed'"
                ui-on="click:SET_FILTER(completed)"&gt;
            Completed
        &lt;/button&gt;
    &lt;/div&gt;
    
    &lt;!-- Task list with loop --&gt;
    &lt;div ui-loop="task in filteredTasks" 
         ui-loop-style="odd:background:#fafafa;even:background:#fff"&gt;
        &lt;div class="task-item" data-task-id="{{task.id}}"&gt;
            &lt;input type="checkbox" 
                   ui-model="task.completed"
                   ui-on="change:TOGGLE_TASK({{task.id}})"&gt;
            &lt;span ui-class="completed:task.completed" 
                  ui-bind="task.title"&gt;{{task.title}}&lt;/span&gt;
            &lt;button ui-on="click:DELETE_TASK({{task.id}})"&gt;
                Delete
            &lt;/button&gt;
        &lt;/div&gt;
    &lt;/div&gt;
    
    &lt;!-- Empty state --&gt;
    &lt;div ui-loop-empty="filteredTasks" class="empty-state"&gt;
        No tasks found. Create your first task!
    &lt;/div&gt;
    
    &lt;!-- Add task form --&gt;
    &lt;form ui-form="ADD_TASK"&gt;
        &lt;input type="text" 
               ui-model="newTaskTitle"
               placeholder="Enter new task..."&gt;
        &lt;button type="submit"&gt;Add Task&lt;/button&gt;
    &lt;/form&gt;
    
    &lt;!-- Stats --&gt;
    &lt;div class="stats"&gt;
        &lt;span&gt;Total: &lt;strong ui-bind="tasks.length"&gt;0&lt;/strong&gt;&lt;/span&gt;
        &lt;span&gt;Active: &lt;strong ui-bind="activeCount"&gt;0&lt;/strong&gt;&lt;/span&gt;
