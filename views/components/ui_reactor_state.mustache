    <!-- Section 4: Loop & Collection System -->
    <section id="loop-system" class="doc-section mb-16">
        <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center text-white font-bold mr-4">4</div>
            <h2 class="text-3xl font-bold">Loop & Collection System</h2>
        </div>
        
        <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
            <p class="text-gray-700 mb-4">
                The loop system provides declarative list rendering with built-in pagination, alternating styles, and item binding.
            </p>
            
            <h3 class="text-xl font-bold mt-6 mb-3">Loop Attributes Reference</h3>
            
            <table class="api-table">
                <thead>
                    <tr><th>Attribute</th><th>Description</th><th>Example</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>ui-loop</code></td>
                        <td>Define loop with item variable and collection</td>
                        <td><code>&lt;div ui-loop="user in users"&gt;{{user.name}}&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-loop-style</code></td>
                        <td>Apply alternating styles (odd/even/every-N)</td>
                        <td><code>ui-loop-style="odd:background:#f5f5f5;even:background:#fff"</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-loop-skip</code></td>
                        <td>Skip items based on rule (odd/even/every-N)</td>
                        <td><code>ui-loop-skip="every-2"</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-loop-empty</code></td>
                        <td>Show when collection is empty</td>
                        <td><code>&lt;div ui-loop-empty="users"&gt;No users found&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-page-next</code></td>
                        <td>Navigate to next page for collection</td>
                        <td><code>&lt;button ui-page-next="users"&gt;Next&lt;/button&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-page-prev</code></td>
                        <td>Navigate to previous page for collection</td>
                        <td><code>&lt;button ui-page-prev="users"&gt;Prev&lt;/button&gt;</code></td>
                    </tr>
                </tbody>
            </table>
            
            <h3 class="text-xl font-bold mt-6 mb-3">Complete Loop Example</h3>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-html">&lt;!-- User List with Pagination and Alternating Styles --&gt;
&lt;div class="user-list"&gt;
    &lt;!-- Loop template (hidden by default, used for rendering) --&gt;
    &lt;div ui-loop="user in users" 
         ui-loop-style="odd:background:#f9f9f9;even:background:#fff"
         style="display: none;"&gt;
        &lt;div class="user-item" data-user-id="{{user.id}}"&gt;
            &lt;span ui-bind="user.name"&gt;&lt;/span&gt;
            &lt;span ui-bind="user.email"&gt;&lt;/span&gt;
            &lt;span class="status" ui-class="active:user.active"&gt;
                {{#user.active}}Active{{/user.active}}
                {{^user.active}}Inactive{{/user.active}}
            &lt;/span&gt;
            &lt;button ui-on="click:DELETE_USER({{user.id}})"&gt;
                Delete
            &lt;/button&gt;
        &lt;/div&gt;
    &lt;/div&gt;
    
    &lt;!-- Empty state --&gt;
    &lt;div ui-loop-empty="users" class="empty-state"&gt;
        No users found. Add your first user!
    &lt;/div&gt;
    
    &lt;!-- Pagination controls --&gt;
    &lt;div class="pagination"&gt;
        &lt;button ui-page-prev="users"&gt;Previous&lt;/button&gt;
        &lt;span&gt;Page &lt;span ui-bind="__page.users"&gt;1&lt;/span&gt;&lt;/span&gt;
        &lt;button ui-page-next="users"&gt;Next&lt;/button&gt;
    &lt;/div&gt;
    
    &lt;!-- Page info --&gt;
    &lt;div class="page-info"&gt;
        Showing &lt;span ui-bind="usersPerPage"&gt;0&lt;/span&gt; of &lt;span ui-bind="users.length"&gt;0&lt;/span&gt; users
    &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
// Initial state with pagination support
const initialState = {
    users: [
        { id: 1, name: "John Doe", email: "john@example.com", active: true },
        { id: 2, name: "Jane Smith", email: "jane@example.com", active: false },
        { id: 3, name: "Bob Johnson", email: "bob@example.com", active: true },
        { id: 4, name: "Alice Brown", email: "alice@example.com", active: true },
        { id: 5, name: "Charlie Wilson", email: "charlie@example.com", active: false }
    ],
    __page: { users: 1 },
    __perPage: { users: 2 }
};

initializeStore(initialState);

// Calculate items per page (computed)
registerReducer("CALCULATE_PERPAGE", (state) => {
    return {
        ...state,
        usersPerPage: Math.min(state.__perPage.users, state.users.length)
    };
});

// Delete user reducer
registerReducer("DELETE_USER", (state, action) => {
    const userId = action.args?.[0] || action.userId;
    return {
        ...state,
        users: state.users.filter(u => u.id !== userId),
        __page: { ...state.__page, users: 1 }
    };
});

// Initial calculation
dispatch({ type: "CALCULATE_PERPAGE" });</code></pre>
