    <!-- Section 3: UI Binding System -->
    <section id="ui-bindings" class="doc-section mb-16">
        <div class="flex items-center mb-6">
            <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center text-white font-bold mr-4">3</div>
            <h2 class="text-3xl font-bold">UI Binding System</h2>
        </div>
        
        <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
            <p class="text-gray-700 mb-4">
                The UI binding system uses declarative HTML attributes to connect DOM elements to the store state.
            </p>
            
            <h3 class="text-xl font-bold mt-6 mb-3">Binding Attributes Reference</h3>
            
            <table class="api-table">
                <thead>
                    <tr><th>Attribute</th><th>Description</th><th>Example</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>ui-bind</code></td>
                        <td>Bind text content to state key</td>
                        <td><code>&lt;span ui-bind="user.name"&gt;&lt;/span&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-html</code></td>
                        <td>Bind HTML content (dangerous!)</td>
                        <td><code>&lt;div ui-html="richContent"&gt;&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-show</code> / <code>ui-if</code></td>
                        <td>Toggle visibility based on boolean</td>
                        <td><code>&lt;div ui-show="isVisible"&gt;Content&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-else</code></td>
                        <td>Show when condition is false</td>
                        <td><code>&lt;div ui-else="isVisible"&gt;Fallback&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-class</code></td>
                        <td>Toggle class based on state</td>
                        <td><code>&lt;div ui-class="active:isActive"&gt;&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-style</code></td>
                        <td>Set inline style from state</td>
                        <td><code>&lt;div ui-style="color:themeColor"&gt;&lt;/div&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-model</code></td>
                        <td>Two-way binding for inputs</td>
                        <td><code>&lt;input ui-model="formData.name"&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-model.lazy</code></td>
                        <td>Two-way binding on blur event</td>
                        <td><code>&lt;input ui-model.lazy="formData.email"&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-on</code></td>
                        <td>Event handler with action dispatch</td>
                        <td><code>&lt;button ui-on="click:ADD_TASK"&gt;Add&lt;/button&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-attr-*</code></td>
                        <td>Set arbitrary attribute from state</td>
                        <td><code>&lt;a ui-attr-href="dynamicUrl"&gt;Link&lt;/a&gt;</code></td>
                    </tr>
                    <tr>
                        <td><code>ui-form</code></td>
                        <td>Handle form submission</td>
                        <td><code>&lt;form ui-form="SUBMIT_FORM"&gt;...&lt;/form&gt;</code></td>
                    </tr>
                </tbody>
            </table>
            
            <h3 class="text-xl font-bold mt-6 mb-3">Complete Binding Example</h3>
            
            <div class="code-block">
                <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                <pre><code class="language-html">&lt;!-- User Profile Component with UI Bindings --&gt;
&lt;div class="user-profile"&gt;
    &lt;!-- Text binding --&gt;
    &lt;h1 ui-bind="user.name"&gt;Loading...&lt;/h1&gt;
    
    &lt;!-- Conditional visibility --&gt;
    &lt;div ui-show="user.isAdmin" class="admin-badge"&gt;
        Administrator
    &lt;/div&gt;
    
    &lt;!-- Two-way binding with input --&gt;
    &lt;div class="form-group"&gt;
        &lt;label&gt;Email:&lt;/label&gt;
        &lt;input type="email" ui-model="formData.email"&gt;
    &lt;/div&gt;
    
    &lt;div class="form-group"&gt;
        &lt;label&gt;Bio:&lt;/label&gt;
        &lt;textarea ui-model.lazy="formData.bio"&gt;&lt;/textarea&gt;
    &lt;/div&gt;
    
    &lt;!-- Class toggling --&gt;
    &lt;button ui-class="btn-primary:formData.isValid" 
            ui-class="btn-disabled:!formData.isValid"
            ui-on="click:SAVE_PROFILE"&gt;
        Save Changes
    &lt;/button&gt;
    
    &lt;!-- Dynamic attribute --&gt;
    &lt;a ui-attr-href="dynamicLink" 
       ui-attr-target="linkTarget"
       ui-bind="linkText"&gt;
    &lt;/a&gt;
    
    &lt;!-- HTML content (careful with XSS) --&gt;
    &lt;div ui-html="user.bioHtml"&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
// Reducers for the bindings
registerReducer("SAVE_PROFILE", (state, action) => {
    // Save logic here
    return {
        ...state,
        user: { ...state.user, ...state.formData },
        formData: { email: "", bio: "" }
    };
});

registerReducer("__SET_MODEL", (state, action) => {
    // Built-in reducer for two-way binding
    return {
        ...state,
        [action.key]: action.value
    };
});
&lt;/script&gt;</code></pre>
            </div>
        </div>
