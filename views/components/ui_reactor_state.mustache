    &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
// Store initialization in the page
window.dispatch = dispatch;
window.getState = getState;

// Register reducers
registerReducer("SET_FILTER", (state, action) => {
    const filter = action.args?.[0] || action.filter;
    return { ...state, filter };
});

registerReducer("ADD_TASK", (state, action) => {
    if (!state.newTaskTitle?.trim()) return state;
    
    const newTask = {
        id: Date.now(),
        title: state.newTaskTitle,
        completed: false
    };
    
    return {
        ...state,
        tasks: [...state.tasks, newTask],
        newTaskTitle: "",
        filteredTasks: filterTasks([...state.tasks, newTask], state.filter, state.searchQuery)
    };
});

registerReducer("TOGGLE_TASK", (state, action) => {
    const taskId = action.args?.[0] || action.taskId;
    const tasks = state.tasks.map(task =>
        task.id === taskId ? { ...task, completed: !task.completed } : task
    );
    
    return {
        ...state,
        tasks,
        filteredTasks: filterTasks(tasks, state.filter, state.searchQuery)
    };
});

// Computed values
registerReducer("UPDATE_COMPUTED", (state) => {
    return {
        ...state,
        activeCount: state.tasks.filter(t => !t.completed).length,
        completedCount: state.tasks.filter(t => t.completed).length
    };
});

function filterTasks(tasks, filter, searchQuery) {
    let filtered = tasks;
    
    if (filter === "active") {
        filtered = tasks.filter(t => !t.completed);
    } else if (filter === "completed") {
        filtered = tasks.filter(t => t.completed);
    }
    
    if (searchQuery) {
        const query = searchQuery.toLowerCase();
        filtered = filtered.filter(t => t.title.toLowerCase().includes(query));
    }
    
    return filtered;
}

// Subscribe to update computed values
subscribe(() => {
    dispatch({ type: "UPDATE_COMPUTED" });
});
