                <pre><code class="language-javascript">// Store with persistence configuration
import { 
    initializeStore, 
    registerReducer, 
    enablePersistenceSlice,
    setCompressionLib,
    on 
} from '/static/assets/js/clientStore.js';

// Optional: Enable compression for large data
import pako from 'pako';
setCompressionLib(pako);

const initialState = {
    // User preferences - persist with compression
    userPrefs: {
        theme: "dark",
        fontSize: "medium",
        sidebarCollapsed: false,
        notifications: true
    },
    
    // Form drafts - persist with 7-day TTL
    formDrafts: {
        contactForm: "",
        signupForm: {}
    },
    
    // Shopping cart - persist compressed
    cart: {
        items: [],
        total: 0
    },
    
    // Temporary UI state - don't persist
    ui: {
        modalOpen: false,
        activeTab: "home"
    }
};

initializeStore(initialState);

// Enable persistence for specific slices
enablePersistenceSlice("userPrefs", { compressed: true });
enablePersistenceSlice("formDrafts", { ttlSeconds: 7 * 24 * 3600 }); // 7 days
enablePersistenceSlice("cart", { compressed: true, ttlSeconds: 86400 }); // 24 hours

// Listen for persistence events
on("persist:done", (key) => {
    console.log(`✅ ${key} saved to storage`);
});

on("persist:hydrated", (key) => {
    console.log(`💧 ${key} loaded from storage`);
});

on("persist:expired", (key) => {
    console.log(`⏰ ${key} expired and cleared`);
});

on("persist:failed", ({ key, error }) => {
    console.warn(`❌ Failed to persist ${key}:`, error);
});

// Update preferences (auto-persists)
registerReducer("UPDATE_THEME", (state, action) => {
    return {
        ...state,
        userPrefs: { ...state.userPrefs, theme: action.theme }
    };
});

registerReducer("ADD_TO_CART", (state, action) => {
    const newItem = action.item;
    const items = [...state.cart.items, newItem];
    const total = items.reduce((sum, item) => sum + item.price, 0);
    
    return {
        ...state,
        cart: { items, total }
    };
});

dispatch({ type: "UPDATE_THEME", theme: "light" });
dispatch({ type: "ADD_TO_CART", item: { id: 1, name: "Book", price: 29.99 } });</code></pre>
