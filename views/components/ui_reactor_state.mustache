            dispatch({ type: "USERS_LOADED", users });
        } catch (error) {
            dispatch({ type: "FETCH_ERROR", error: error.message });
        }
        
        // Prevent original action from continuing
        return false;
    }
    
    return true;
});

// Validation middleware
useMiddleware((action, state, dispatch, getState) => {
    if (action.type === "SAVE_FORM") {
        if (!action.data.name || action.data.name.trim() === "") {
            console.warn("Validation failed: name required");
            dispatch({ type: "VALIDATION_ERROR", field: "name", message: "Name is required" });
            return false; // Block the action
        }
    }
    return true;
});

// Analytics middleware
useMiddleware((action, state, dispatch, getState) => {
    if (action.type === "ADD_TO_CART") {
