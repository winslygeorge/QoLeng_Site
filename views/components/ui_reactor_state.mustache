local FunctionalComponent = require("layout.renderer.FuncComponent")
local HTML = require("layout.renderer.LuaHTMLReactive")
local cjson = require("dkjson")

local HybridComponent = FunctionalComponent:extends()
HybridComponent:setReactiveView()

-- Server state (persisted to Redis)
HybridComponent.state = {
    tasks = {},
    nextId = 1
}

-- Client ready: initialize UI-Reactor store
HybridComponent:onClientReady(function(self, ws_id, client_token)
    -- Load server tasks into UI-Reactor
    local tasksJson = cjson.encode(self.state.tasks)
    
    self:sendHTMLClientOperations(ws_id, {
        {
            _op = "jsFunction",
            name = "__hydrateStore__",
            params = {"tasks"},
            body = [[
                if (window.hydrateStore) {
                    window.hydrateStore({ tasks: tasks });
                }
            ]]
        },
        {
            _op = "call",
            fn = "__hydrateStore__",
            args = { tasksJson }
        }
    })
end)

-- Method to sync client changes to server
HybridComponent.methods.syncTasks = function(self, ws_id, args)
    local tasks = args.tasks
    
    self:setState({
        tasks = tasks,
        nextId = #tasks + 1
    })
    
    print("Synced", #tasks, "tasks to server")
end

-- Method to get current server state
HybridComponent.methods.getServerTasks = function(self, ws_id, args)
    return self.state.tasks
end

-- Render component with UI-Reactor bindings
function HybridComponent:renderLayout(state, props, children, H, client_state)
    return H.e("div", { id = props.routeId, class = "p-6 max-w-4xl mx-auto" }, {
        -- UI-Reactor powered task manager
        H.e("div", { class = "mb-8" }, {
            H.e("h2", { class = "text-2xl font-bold mb-4" }, "Hybrid Task Manager"),
            
            -- Add task form
            H.e("div", { class = "flex gap-2 mb-4" }, {
                H.e("input", {
                    type = "text",
                    class = "flex-grow p-2 border rounded",
                    placeholder = "New task...",
                    ["ui-model"] = "newTaskTitle"
                }),
                H.e("button", {
                    class = "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700",
                    ["ui-on"] = "click:ADD_TASK"
                }, "Add Task")
            }),
            
            -- Task list with loop
            H.e("div", { ["ui-loop"] = "task in tasks" }, {
                H.e("div", { class = "flex items-center gap-2 p-2 border rounded mb-2" }, {
                    H.e("input", {
                        type = "checkbox",
                        ["ui-model"] = "task.completed",
                        ["ui-on"] = "change:TOGGLE_TASK"
                    }),
                    H.e("span", { 
                        ["ui-bind"] = "task.title",
                        ["ui-class"] = "line-through:task.completed"
                    }),
                    H.e("button", {
                        class = "text-red-600 hover:text-red-800 ml-auto",
                        ["ui-on"] = "click:DELETE_TASK"
                    }, "Delete")
                })
            }),
            
            -- Sync button
            H.e("button", {
                class = "mt-4 px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700",
                ["ui-on"] = "click:SYNC_TO_SERVER"
            }, "Sync to Server"),
            
            -- Server state indicator
            H.e("div", { class = "mt-4 text-sm text-gray-500" }, {
                "Server tasks: ",
                H.e("strong", { ["ui-bind"] = "serverTaskCount" }, "0")
            })
        }),
        
        -- UI-Reactor initialization script
        H.e("script", { type = "module" }, [[
            import { 
                initializeStore, 
                registerReducer, 
                dispatch, 
                getState, 
                subscribe,
                hydrateStore
            } from '/static/assets/js/clientStore.js';
            
            import { bindStateToDOM, initializeBindings } from '/static/assets/js/domBindings.js';
            
            // Initialize store
            const initialState = {
                tasks: [],
                newTaskTitle: "",
                serverTaskCount: 0
            };
            
            initializeStore(initialState);
            
            // Make available globally
            window.dispatch = dispatch;
            window.getState = getState;
            window.hydrateStore = hydrateStore;
            
            // Reducers
            registerReducer("ADD_TASK", (state) => {
                if (!state.newTaskTitle?.trim()) return state;
                
                const newTask = {
                    id: Date.now(),
                    title: state.newTaskTitle,
                    completed: false
                };
                
                return {
                    ...state,
                    tasks: [...state.tasks, newTask],
                    newTaskTitle: ""
                };
            });
            
            registerReducer("TOGGLE_TASK", (state, action) => {
                const target = action.event?.target;
                const taskEl = target?.closest('[data-task-id]');
                const taskId = taskEl?.getAttribute('data-task-id');
                
                if (taskId) {
                    return {
                        ...state,
                        tasks: state.tasks.map(task =>
                            task.id == taskId 
                                ? { ...task, completed: !task.completed }
                                : task
                        )
                    };
                }
                return state;
            });
            
            registerReducer("DELETE_TASK", (state, action) => {
                const target = action.event?.target;
                const taskEl = target?.closest('[data-task-id]');
                const taskId = taskEl?.getAttribute('data-task-id');
                
                if (taskId) {
                    return {
                        ...state,
                        tasks: state.tasks.filter(task => task.id != taskId)
                    };
                }
                return state;
            });
            
            registerReducer("SYNC_TO_SERVER", (state) => {
                const tasks = state.tasks;
                
                // Send to server via WebSocket
                if (window.__dawn_socket) {
                    window.__dawn_socket.send(JSON.stringify({
                        type: "patch",
                        component: "hybridComponent",
                        method: "syncTasks",
                        args: { tasks: tasks }
                    }));
                }
                
                return {
                    ...state,
                    serverTaskCount: tasks.length
                };
            });
            
            // Subscribe to DOM updates
            subscribe((state) => {
                bindStateToDOM(state, dispatch);
            });
            
            // Initialize bindings
            initializeBindings(dispatch);
            
            console.log("✅ UI-Reactor hybrid store initialized");
        ]])
    })
end

-- Component initialization
function HybridComponent:load()
    self:setComponentKey("hybridComponent")
    self:loadStateFromRedis()
    
    self:init(function(server, children, props, style, H)
        return function(state, props, children, H, clientState)
            return self:renderLayout(state, props, children, H, clientState)
        end
    end)
end

return HybridComponent</code></pre>
