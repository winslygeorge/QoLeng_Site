        <!-- CLI Reference Section -->
        <section id="cli-reference" class="mb-16 animate-fadeIn">
            <h2 class="text-3xl font-bold mb-6 text-neural-charcoal">Dawn CLI Reference</h2>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <p class="text-lg text-light-text-secondary mb-6">
                    The Dawn Command Line Interface (CLI) is your primary tool for managing Dawn projects, from creation to development and deployment.
                </p>
                
                <div class="relative bg-gray-800 text-gray-200 rounded-lg p-4 code-block">
                    <button class="absolute top-3 right-3 bg-laser-blue text-white p-1 rounded text-sm hover:bg-blue-700 transition-colors">
                        <i class="fas fa-copy"></i>
                    </button>
                    <div class="absolute top-3 left-4 flex space-x-1">
                        <span class="w-3 h-3 bg-warning-amber rounded-full"></span>
                        <span class="w-3 h-3 bg-build-green rounded-full"></span>
                        <span class="w-3 h-3 bg-query-purple rounded-full"></span>
                    </div>
                    <pre class="overflow-x-auto pt-4"><code><span class="code-comment"># Dawn Web Framework CLI</span>

<span class="code-variable">Usage:</span>
  <span class="code-keyword">dawn new</span> <span class="code-string">&lt;project_name&gt;</span>             <span class="code-comment"># Create a new project</span>
  <span class="code-keyword">dawn install</span>                     <span class="code-comment"># Install LuaRocks dependencies from config</span>
  <span class="code-keyword">dawn serve</span>                       <span class="code-comment"># Run the dev server</span>
  <span class="code-keyword">dawn generate</span> <span class="code-string">&lt;type&gt; &lt;name&gt;</span>       <span class="code-comment"># Generate controller/model/middleware/etc.</span>
  <span class="code-keyword">dawn db migrate</span> <span class="code-string">[&lt;migration_file&gt;]</span> <span class="code-comment"># Run database migrations</span>
