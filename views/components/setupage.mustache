                        </div>
                        <pre><code><span class="keyword">local</span> json = <span class="keyword">require</span>(<span class="string">'dkjson'</span>)

<span class="keyword">local</span> M = {}
M.<span class="variable">__index</span> = M

<span class="keyword">function</span> M:<span class="function">new</span>(server)
    <span class="keyword">local</span> self = <span class="keyword">setmetatable</span>({}, M)
    self.<span class="variable">server</span> = server
    <span class="keyword">return</span> self
<span class="keyword">end</span>

<span class="keyword">function</span> M:<span class="function">routes</span>()
    <span class="comment">-- Your routes go here</span>
    self.<span class="variable">server</span>:<span class="function">get</span>(<span class="string">"/home"</span>, <span class="keyword">function</span>(req, res)
