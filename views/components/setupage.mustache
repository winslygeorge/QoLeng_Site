        <h2 class="text-3xl font-bold mb-6" style="color: var(--doc-text);">Dawn CLI Reference</h2>
        
        <div class="rounded-xl p-6 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fas fa-terminal"></i> Bash - Dawn CLI Commands</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment"># Dawn Web Framework CLI</span>

<span class="variable">Usage:</span>
  <span class="keyword">dawn new</span> <span class="string">&lt;project_name&gt;</span>             <span class="comment"># Create a new project</span>
