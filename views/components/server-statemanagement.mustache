        <!-- Section 10: Best Practices -->
        <section id="best-practices" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center text-white font-bold mr-4">10</div>
                <h2 class="text-3xl font-bold">Best Practices</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="p-4 bg-green-50 rounded-lg">
                        <h3 class="font-bold text-green-800 mb-2">✅ DO</h3>
                        <ul class="list-disc pl-5 text-sm space-y-1">
                            <li>Use client state for user-specific UI preferences</li>
                            <li>Keep server state lean and focused on shared data</li>
                            <li>Set component_key before loading from Redis</li>
                            <li>Initialize client state in onClientReady callback</li>
                            <li>Use CRUD operations for array manipulations</li>
                            <li>Prune client states regularly to manage memory</li>
                            <li>Use utils helpers for immutable state updates</li>
                            <li>Handle Redis connection failures gracefully</li>
                        </ul>
                    </div>
                    
                    <div class="p-4 bg-red-50 rounded-lg">
                        <h3 class="font-bold text-red-800 mb-2">❌ DON'T</h3>
                        <ul class="list-disc pl-5 text-sm space-y-1">
                            <li>Store large binary data in state (use files instead)</li>
                            <li>Update server state on every keystroke</li>
                            <li>Forget to set component_key before using Redis</li>
                            <li>Mix server and client state in the same table</li>
                            <li>Use mutable state updates without deep copy</li>
                            <li>Ignore the difference between setState and setClientState</li>
                            <li>Store sensitive data in client state (it's persisted)</li>
                            <li>Overuse server state for user-specific data</li>
                        </ul>
                    </div>
                </div>
                
                <h3 class="text-xl font-bold mt-8 mb-3">Performance Tips</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- 1. Batch updates when possible</span>
self:setClientState(ws_id, {
    tasks = newTasks,
    uiState = newUiState,
    filters = newFilters
})  <span class="text-gray-400">-- Single update instead of multiple</span>

<span class="text-gray-400">-- 2. Use shallow state when deep nesting isn't needed</span>
<span class="text-gray-400">-- Instead of:</span>
state.users[userId].profile.settings.theme = <span class="text-green-400">"dark"</span>

<span class="text-gray-400">-- Consider:</span>
state.userThemes[userId] = <span class="text-green-400">"dark"</span>

<span class="text-gray-400">-- 3. Prune client states proactively</span>
self:pruneClientStates(<span class="text-orange-400">100</span>, <span class="text-orange-400">3600</span>)  <span class="text-gray-400">-- Keep only last hour's states</span>

<span class="text-gray-400">-- 4. Use the utils helpers for immutable updates</span>
<span class="text-gray-400">-- They're optimized and prevent accidental mutations</span>
self.utils.arrayPush(tasks, newTask)  <span class="text-gray-400">-- Returns new array</span>
self.utils.objectMerge(obj, updates)   <span class="text-gray-400">-- Returns merged object</span></code></pre>
                </div>
            </div>
        </section>

