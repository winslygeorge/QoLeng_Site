            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <h3 class="text-xl font-bold mt-6 mb-3">Pattern 1: Optimistic Updates with Rollback</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua">MyComponent.methods.optimisticUpdate = <span class="text-blue-400">function</span>(self, ws_id, args)
    <span class="text-blue-400">local</span> taskId = args.id
    <span class="text-blue-400">local</span> oldState = self:getClientState(ws_id)
    
    <span class="text-gray-400">-- Apply optimistic update</span>
    self:setClientState(ws_id, <span class="text-blue-400">function</span>(state)
        <span class="text-blue-400">return</span> self.utils.objectMerge(state, {
            tasks = self.utils.arrayMap(state.tasks <span class="text-keyword">or</span> {}, <span class="text-blue-400">function</span>(task)
                <span class="text-blue-400">if</span> task.id == taskId <span class="text-blue-400">then</span>
                    <span class="text-blue-400">return</span> self.utils.objectMerge(task, { completed = <span class="text-orange-400">true</span> })
                <span class="text-blue-400">end</span>
                <span class="text-blue-400">return</span> task
            <span class="text-blue-400">end</span>)
        })
    <span class="text-blue-400">end</span>)
    
    <span class="text-gray-400">-- Attempt server sync, rollback on failure</span>
    <span class="text-blue-400">local</span> success = self:syncToServer(taskId, <span class="text-orange-400">true</span>)
    <span class="text-blue-400">if</span> <span class="text-blue-400">not</span> success <span class="text-blue-400">then</span>
        <span class="text-gray-400">-- Rollback to old state</span>
        self:setClientState(ws_id, oldState)
    <span class="text-blue-400">end</span>
<span class="text-blue-400">end</span></code></pre>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Pattern 2: State History with Undo/Redo</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Initialize with history tracking</span>
MyComponent:onClientReady(<span class="text-blue-400">function</span>(self, ws_id, client_token)
    self:setClientState(ws_id, {
        tasks = {},
        history = { states = {}, currentIndex = -1 },
        nextClientId = 1
    })
<span class="text-blue-400">end</span>)

<span class="text-gray-400">-- Wrap state updates with history tracking</span>
MyComponent.methods.saveToHistory = <span class="text-blue-400">function</span>(self, ws_id, newState)
    self:setClientState(ws_id, <span class="text-blue-400">function</span>(state)
        <span class="text-blue-400">local</span> history = state.history <span class="text-keyword">or</span> { states = {}, currentIndex = -1 }
        
        <span class="text-gray-400">-- Trim forward history if we're not at the end</span>
        <span class="text-blue-400">if</span> history.currentIndex < #history.states <span class="text-blue-400">then</span>
            <span class="text-blue-400">for</span> i = #history.states, history.currentIndex + 1, -1 <span class="text-blue-400">do</span>
                table.remove(history.states, i)
            <span class="text-blue-400">end</span>
        <span class="text-blue-400">end</span>
        
        <span class="text-gray-400">-- Save current state</span>
        <span class="text-blue-400">local</span> currentSnapshot = self.utils.objectMerge({}, state)
        currentSnapshot.history = <span class="text-keyword">nil</span>
        table.insert(history.states, currentSnapshot)
        history.currentIndex = #history.states
        
        <span class="text-blue-400">return</span> self.utils.objectMerge(state, {
            history = history,
            <span class="text-gray-400">-- ... apply actual state change ...</span>
        })
    <span class="text-blue-400">end</span>)
<span class="text-blue-400">end</span>

MyComponent.methods.undo = <span class="text-blue-400">function</span>(self, ws_id, args)
    self:setClientState(ws_id, <span class="text-blue-400">function</span>(state)
        <span class="text-blue-400">local</span> history = state.history
        <span class="text-blue-400">if</span> history <span class="text-keyword">and</span> history.currentIndex > 1 <span class="text-blue-400">then</span>
            history.currentIndex = history.currentIndex - 1
            <span class="text-blue-400">return</span> self.utils.objectMerge(history.states[history.currentIndex], {
                history = history
            })
        <span class="text-blue-400">end</span>
        <span class="text-blue-400">return</span> state
    <span class="text-blue-400">end</span>)
<span class="text-blue-400">end</span></code></pre>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Pattern 3: Cross-Component State Sharing</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Parent component holds shared state</span>
ParentComponent.methods.updateSharedData = <span class="text-blue-400">function</span>(self, ws_id, args)
    <span class="text-gray-400">-- Update parent state</span>
    self:setState({
        sharedData = args.data
    })
<span class="text-blue-400">end</span>

<span class="text-gray-400">-- Child component can access parent state</span>
ChildComponent.methods.getParentData = <span class="text-blue-400">function</span>(self, ws_id, args)
    <span class="text-blue-400">local</span> parent = self:getParentComponent()
    <span class="text-blue-400">if</span> parent <span class="text-blue-400">then</span>
        <span class="text-blue-400">return</span> parent.state.sharedData
    <span class="text-blue-400">end</span>
<span class="text-blue-400">end</span>

<span class="text-gray-400">-- Or use callParentMethod to update parent</span>
ChildComponent.methods.updateParentData = <span class="text-blue-400">function</span>(self, ws_id, args)
    self:callParentMethod(<span class="text-green-400">"updateSharedData"</span>, { data = args.newData })
<span class="text-blue-400">end</span></code></pre>
                </div>
            </div>
        </section>

