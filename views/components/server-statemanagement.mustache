        <!-- Section 1: Overview -->
        <section id="overview" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold">State Management Overview</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <p class="text-gray-700 mb-4">
                    The Dawn Framework provides a dual-state architecture that separates <strong>server-side state</strong> (shared across all clients) 
                    from <strong>client-side state</strong> (isolated per client). This approach enables:
                </p>
                
                <div class="grid md:grid-cols-3 gap-4 mb-6">
                    <div class="p-4 bg-blue-50 rounded-lg">
                        <h3 class="font-bold text-blue-800 mb-2">📦 Server State</h3>
                        <p class="text-sm text-gray-600">Shared across all connected clients. Persisted to Redis automatically. Perfect for application data.</p>
                    </div>
                    <div class="p-4 bg-purple-50 rounded-lg">
                        <h3 class="font-bold text-purple-800 mb-2">🖥️ Client State</h3>
                        <p class="text-sm text-gray-600">Isolated per client session. Persisted to Redis with client identifier. Perfect for UI state and forms.</p>
                    </div>
                    <div class="p-4 bg-red-50 rounded-lg">
                        <h3 class="font-bold text-red-800 mb-2">💾 Redis Persistence</h3>
                        <p class="text-sm text-gray-600">Automatic persistence with TTL. Supports reconnection and state recovery.</p>
                    </div>
                </div>
                
                <div class="info-box">
                    <strong>💡 Key Insight:</strong> Server state is updated via <code>setState()</code> and affects all users. Client state is updated via <code>setClientState()</code> and is unique per user session.
                </div>
            </div>
        </section>

        <!-- Section 2: Understanding State Types -->
        <section id="state-types" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold mr-4">2</div>
                <h2 class="text-3xl font-bold">Understanding State Types</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <h3 class="text-2xl font-bold mb-4">State Comparison</h3>
                
                <table class="comparison-table">
                    <thead>
                        <tr><th>Feature</th><th>Server State</th><th>Client State</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Scope</td><td>All connected clients</td><td>Single client session</td></tr>
                        <tr><td>Update Method</td><td><code>setState()</code></td><td><code>setClientState()</code></td></tr>
                        <tr><td>Redis Key Pattern</td><td><code>component_state:key</code></td><td><code>client_state:key:client_token</code></td></tr>
                        <tr><td>Use Cases</td><td>Application data, shared resources</td><td>Form inputs, UI preferences, temporary data</td></tr>
                        <tr><td>Persistence</td><td>Global with component key</td><td>Per client with token</td></tr>
                    </tbody>
                </table>
                
                <div class="method-signature">
                    <strong>State Structure:</strong> Both state types are Lua tables that can contain nested data structures.
                </div>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Example State Structures</span>
<span class="text-blue-400">local</span> serverState = {
    tasks = {
        { id = 1, title = <span class="text-green-400">"Task 1"</span>, completed = <span class="text-orange-400">false</span> },
        { id = 2, title = <span class="text-green-400">"Task 2"</span>, completed = <span class="text-orange-400">true</span> }
    },
    nextId = 3,
    settings = {
        theme = <span class="text-green-400">"dark"</span>,
        notifications = <span class="text-orange-400">true</span>
    }
}

<span class="text-gray-400">-- Example Client State (isolated per user)</span>
<span class="text-blue-400">local</span> clientState = {
    draftForm = {
        name = <span class="text-green-400">""</span>,
        email = <span class="text-green-400">""</span>
    },
    uiPreferences = {
        sidebarCollapsed = <span class="text-orange-400">false</span>,
        activeTab = <span class="text-green-400">"tasks"</span>
    },
    temporaryData = {
        searchQuery = <span class="text-green-400">""</span>
    }
}</code></pre>
                </div>
            </div>
        </section>

        <!-- Section 3: Server State (Component State) -->
        <section id="server-state" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold mr-4">3</div>
                <h2 class="text-3xl font-bold">Server State (Component State)</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <p class="text-gray-700 mb-4">
                    Server state is stored in the <code>self.state</code> table of your component. Updates to this state affect all connected clients 
                    and are automatically persisted to Redis when available.
                </p>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Setting Up Server State</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Initialize component with server state</span>
<span class="text-blue-400">local</span> MyComponent = FunctionalComponent:extends()
MyComponent:setReactiveView()

<span class="text-gray-400">-- Define initial state (optional, will be loaded from Redis if available)</span>
MyComponent.state = {
    items = {},
    nextId = 1,
    settings = {
        maxItems = 100
    }
}

<span class="text-gray-400">-- Load state from Redis (called after setComponentKey)</span>
MyComponent:loadStateFromRedis()</code></pre>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Updating Server State</h3>
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="method-card">
                        <h4 class="font-bold text-lg mb-2">Method 1: Partial Table Update</h4>
                        <p class="text-sm text-gray-600 mb-3">Merge changes into existing state.</p>
                        <div class="code-block bg-gray-900 p-3 rounded">
                            <pre><code class="language-lua">MyComponent:setState({
    items = { { id = 1, title = "New Task" } }
})</code></pre>
                        </div>
                    </div>
                    
                    <div class="method-card">
                        <h4 class="font-bold text-lg mb-2">Method 2: Updater Function</h4>
                        <p class="text-sm text-gray-600 mb-3">Calculate new state based on current.</p>
                        <div class="code-block bg-gray-900 p-3 rounded">
                            <pre><code class="language-lua">MyComponent:setState(<span class="text-blue-400">function</span>(currentState)
    <span class="text-blue-400">local</span> newItem = {
        id = currentState.nextId,
        title = <span class="text-green-400">"New Item"</span>
    }
    <span class="text-blue-400">return</span> {
        items = { table.unpack(currentState.items), newItem },
        nextId = currentState.nextId + 1
    }
<span class="text-blue-400">end</span>)</code></pre>
                        </div>
                    </div>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Reading Server State</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- In your component methods</span>
<span class="text-blue-400">function</span> MyComponent:someMethod(ws_id, args)
    <span class="text-gray-400">-- Direct access to self.state</span>
    <span class="text-blue-400">local</span> currentItems = self.state.items <span class="text-keyword">or</span> {}
    <span class="text-blue-400">local</span> nextId = self.state.nextId <span class="text-keyword">or</span> 1
    
    <span class="text-gray-400">-- Or use reactive component helper</span>
    <span class="text-blue-400">local</span> normalState = self.reactive_component:getNormalState()
    <span class="text-blue-400">print</span>(<span class="text-green-400">"Items count:"</span>, #normalState.items)
<span class="text-blue-400">end</span></code></pre>
                </div>
                
                <div class="warning-box">
                    <strong>⚠️ Important:</strong> Server state updates trigger re-renders for ALL connected clients. Use sparingly for high-frequency updates or consider client state for user-specific data.
                </div>
            </div>
        </section>

        <!-- Section 4: Client State -->
        <section id="client-state" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-purple-600 flex items-center justify-center text-white font-bold mr-4">4</div>
                <h2 class="text-3xl font-bold">Client State</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <p class="text-gray-700 mb-4">
                    Client state is isolated per user session and stored with a client token or WebSocket ID. Perfect for UI state, form drafts, 
                    and user preferences that shouldn't affect other users.
                </p>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Setting Up Client State</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Client state is initialized when the client connects</span>
MyComponent:onClientReady(<span class="text-blue-400">function</span>(self, ws_id, client_token)
    <span class="text-gray-400">-- Initialize client state for this user</span>
    self:setClientState(ws_id, {
        tasks = {},
        nextClientId = 1,
        uiState = {
            sidebarOpen = <span class="text-orange-400">true</span>,
            activeTab = <span class="text-green-400">"all"</span>
        }
    }, <span class="text-green-400">"my_component"</span>)
<span class="text-blue-400">end</span>)</code></pre>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Updating Client State</h3>
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="method-card">
                        <h4 class="font-bold text-lg mb-2">Method 1: Direct Merge</h4>
                        <div class="code-block bg-gray-900 p-3 rounded">
                            <pre><code class="language-lua"><span class="text-gray-400">-- Update specific fields</span>
MyComponent.methods.updateTask = <span class="text-blue-400">function</span>(self, ws_id, args)
    self:setClientState(ws_id, {
        tasks = self:getClientState(ws_id).tasks,
        <span class="text-gray-400">-- ... updates</span>
    })
<span class="text-blue-400">end</span></code></pre>
                        </div>
                    </div>
                    
                    <div class="method-card">
                        <h4 class="font-bold text-lg mb-2">Method 2: Updater Function</h4>
                        <div class="code-block bg-gray-900 p-3 rounded">
                            <pre><code class="language-lua"><span class="text-gray-400">-- Use function to transform state</span>
MyComponent.methods.addTask = <span class="text-blue-400">function</span>(self, ws_id, args)
    self:setClientState(ws_id, <span class="text-blue-400">function</span>(clientState)
        <span class="text-blue-400">local</span> tasks = clientState.tasks <span class="text-keyword">or</span> {}
        table.insert(tasks, { id = #tasks + 1, title = args.title })
        <span class="text-blue-400">return</span> { tasks = tasks }
    <span class="text-blue-400">end</span>)
<span class="text-blue-400">end</span></code></pre>
                        </div>
                    </div>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Reading Client State</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Get current client state</span>
<span class="text-blue-400">function</span> MyComponent:someMethod(ws_id, args)
    <span class="text-blue-400">local</span> clientState = self:getClientState(ws_id)
    <span class="text-blue-400">print</span>(<span class="text-green-400">"User has"</span>, #clientState.tasks, <span class="text-green-400">"tasks"</span>)
    
    <span class="text-gray-400">-- Access specific values</span>
    <span class="text-blue-400">local</span> activeTab = clientState.uiState <span class="text-keyword">and</span> clientState.uiState.activeTab <span class="text-keyword">or</span> <span class="text-green-400">"all"</span>
<span class="text-blue-400">end</span></code></pre>
                </div>
                
                <div class="info-box">
                    <strong>💡 Tip:</strong> Client state is automatically persisted to Redis with the pattern <code>client_state:{component_key}:{client_token}</code>. 
                    When a user reconnects, their state is restored automatically.
                </div>
            </div>
        </section>

        <!-- Section 5: Redis Persistence -->
        <section id="redis-persistence" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-red-600 flex items-center justify-center text-white font-bold mr-4">5</div>
                <h2 class="text-3xl font-bold">Redis Persistence</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <p class="text-gray-700 mb-4">
                    The Dawn Framework integrates with Redis for automatic state persistence. Both server and client states are saved with appropriate TTLs.
                </p>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Redis Key Patterns</h3>
                
                <table class="comparison-table">
                    <thead><tr><th>State Type</th><th>Key Pattern</th><th>TTL</th></tr></thead>
                    <tbody>
                        <tr><td>Server State</td><td><code>component_state:{component_key}</code></td><td>24 hours (configurable)</td></tr>
                        <tr><td>Client State</td><td><code>client_state:{component_key}:{client_token}</code></td><td>24 hours</td></tr>
                    </tbody>
                </table>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Manual Redis Operations</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Load server state from Redis (called after setComponentKey)</span>
MyComponent:loadStateFromRedis()

<span class="text-gray-400">-- Get client state from Redis directly</span>
<span class="text-blue-400">local</span> clientState = self:getRedisClientState(client_token, <span class="text-green-400">"my_component"</span>)

<span class="text-gray-400">-- Get component-wide state</span>
<span class="text-blue-400">local</span> componentState = self:getRedisComponentState(<span class="text-green-400">"my_component"</span>)

<span class="text-gray-400">-- Validate Redis connection</span>
<span class="text-blue-400">local</span> isConnected = self:validateRedisConnection()</code></pre>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Pruning Client States</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Automatically prune old client states</span>
<span class="text-gray-400">-- Called automatically, but can be invoked manually</span>
self:pruneClientStates(
    <span class="text-orange-400">300</span>,      <span class="text-gray-400">-- Maximum number of entries to keep</span>
    <span class="text-orange-400">24 * 3600</span>  <span class="text-gray-400">-- Maximum age in seconds (24 hours)</span>
)</code></pre>
                </div>
                
                <div class="warning-box">
                    <strong>⚠️ Important:</strong> Redis persistence requires the server to be configured with Redis support. Check <code>self.server.dawn_sockets_handler.state_management.redis</code> for availability.
                </div>
            </div>
        </section>

        <!-- Section 6: CRUD Operations -->
        <section id="crud-operations" class="doc-section mb-16">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center text-white font-bold mr-4">6</div>
                <h2 class="text-3xl font-bold">CRUD Operations</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
                <p class="text-gray-700 mb-4">
                    The framework provides built-in CRUD operations for both server and client state using the <code>HTML.CRUD_OPERATIONS</code> constants.
                </p>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Available CRUD Operations</h3>
                
                <div class="grid md:grid-cols-3 gap-2 mb-6">
                    <span class="bg-gray-100 p-2 rounded text-center"><code>APPEND</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>PREPEND</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>INSERT</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>REMOVE</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>SET</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>UPDATE</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>MERGE</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>CLEAR</code></span>
                    <span class="bg-gray-100 p-2 rounded text-center"><code>DELETE</code></span>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Using CRUD with Server State</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Append to an array</span>
self:setState({
    _operation = HTML.CRUD_OPERATIONS.APPEND,
    _target = <span class="text-green-400">"tasks"</span>,
    _data = { id = 5, title = <span class="text-green-400">"New Task"</span> }
})

<span class="text-gray-400">-- Update a specific field</span>
self:setState({
    _operation = HTML.CRUD_OPERATIONS.UPDATE,
    _target = <span class="text-green-400">"tasks"</span>,
    _data = { completed = <span class="text-orange-400">true</span> },
    _options = { key = 1 }  <span class="text-gray-400">-- Update task with index 1</span>
})

<span class="text-gray-400">-- Delete from array by predicate</span>
self:setState({
    _operation = HTML.CRUD_OPERATIONS.REMOVE,
    _target = <span class="text-green-400">"tasks"</span>,
    _options = { predicate = <span class="text-blue-400">function</span>(task) <span class="text-blue-400">return</span> task.completed <span class="text-blue-400">end</span> }
})</code></pre>
                </div>
                
                <h3 class="text-xl font-bold mt-6 mb-3">Using CRUD with Client State</h3>
                
                <div class="code-block">
                    <pre><code class="language-lua"><span class="text-gray-400">-- Append to client state array</span>
self:setClientState(ws_id, {
    _operation = HTML.CRUD_OPERATIONS.APPEND,
    _target = <span class="text-green-400">"tasks"</span>,  <span class="text-gray-400">-- No "cs." prefix needed</span>
    _data = { id = nextId, title = title }
})

<span class="text-gray-400">-- Set a value (create or replace)</span>
self:setClientState(ws_id, {
    _operation = HTML.CRUD_OPERATIONS.SET,
    _target = <span class="text-green-400">"uiState.activeTab"</span>,
    _data = <span class="text-green-400">"settings"</span>
})

<span class="text-gray-400">-- Merge into an object</span>
self:setClientState(ws_id, {
    _operation = HTML.CRUD_OPERATIONS.MERGE,
    _target = <span class="text-green-400">"formData"</span>,
    _data = { email = <span class="text-green-400">"user@example.com"</span> }
})</code></pre>
                </div>
                
