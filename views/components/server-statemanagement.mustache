                </div>
                <pre><code>MyComponent.methods.optimisticUpdate = <span class="keyword">function</span>(self, ws_id, args)
    <span class="keyword">local</span> taskId = args.id
    <span class="keyword">local</span> oldState = self:getClientState(ws_id)
    
    <span class="comment">-- Apply optimistic update</span>
    self:setClientState(ws_id, <span class="keyword">function</span>(state)
        <span class="keyword">return</span> self.utils.objectMerge(state, {
            tasks = self.utils.arrayMap(state.tasks <span class="keyword">or</span> {}, <span class="keyword">function</span>(task)
                <span class="keyword">if</span> task.id == taskId <span class="keyword">then</span>
                    <span class="keyword">return</span> self.utils.objectMerge(task, { completed = <span class="keyword">true</span> })
                <span class="keyword">end</span>
                <span class="keyword">return</span> task
            <span class="keyword">end</span>)
        })
    <span class="keyword">end</span>)
    
    <span class="comment">-- Attempt server sync, rollback on failure</span>
    <span class="keyword">local</span> success = self:syncToServer(taskId, <span class="keyword">true</span>)
    <span class="keyword">if</span> <span class="keyword">not</span> success <span class="keyword">then</span>
        self:setClientState(ws_id, oldState)
    <span class="keyword">end</span>
<span class="keyword">end</span></code></pre>
