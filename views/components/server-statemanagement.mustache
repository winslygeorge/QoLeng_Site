TaskManager.methods.toggleClientTask = <span class="text-blue-400">function</span>(self, ws_id, args)
    <span class="text-blue-400">local</span> id = tonumber(args.id)
    
    self:setClientState(ws_id, <span class="text-blue-400">function</span>(clientState)
        <span class="text-blue-400">return</span> {
            tasks = self.utils.arrayMap(clientState.tasks, <span class="text-blue-400">function</span>(task)
                <span class="text-blue-400">if</span> task.id == id <span class="text-blue-400">then</span>
                    <span class="text-blue-400">return</span> self.utils.objectMerge(task, {
                        completed = <span class="text-blue-400">not</span> task.completed
                    })
                <span class="text-blue-400">end</span>
                <span class="text-blue-400">return</span> task
            <span class="text-blue-400">end</span>)
        }
    <span class="text-blue-400">end</span>)
<span class="text-blue-400">end</span>

