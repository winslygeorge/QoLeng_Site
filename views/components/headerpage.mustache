<!-- Header Component -->
<style>
    /* Header Theme Variables */
    header {
        --header-bg: #FFFFFF;
        --header-text: #2A2A3A;
        --header-text-secondary: #5A6578;
        --header-border: #E0E5EC;
        --header-dropdown-bg: #FFFFFF;
        --header-dropdown-hover: #F0F7FF;
        --header-icon-bg: #F3F4F6;
        --header-icon-color: #6B7280;
        --header-top-bar: linear-gradient(135deg, #0066FF, #8A2BE2);
        --header-logo-gradient: linear-gradient(135deg, #0066FF, #00CC88);
        --header-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }

    body.dark-theme header {
        --header-bg: #151520;
        --header-text: #E0E5EC;
        --header-text-secondary: #A0A5B5;
        --header-border: #2A2A3A;
        --header-dropdown-bg: #1F1F2E;
        --header-dropdown-hover: rgba(0, 102, 255, 0.1);
        --header-icon-bg: #2A2A3A;
        --header-icon-color: #E0E5EC;
        --header-top-bar: linear-gradient(135deg, #0066FF, #8A2BE2);
        --header-logo-gradient: linear-gradient(135deg, #0066FF, #00CC88);
        --header-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    }

    header {
        background-color: var(--header-bg);
        border-bottom: 1px solid var(--header-border);
        transition: all 0.3s ease;
        position: sticky;
        top: 0;
        z-index: 1000;
        box-shadow: var(--header-shadow);
    }

    /* Top Bar */
    .top-bar-gradient {
        background: var(--header-top-bar);
        transition: all 0.3s ease;
    }

    /* Navigation Links */
    .nav-link {
        color: var(--header-text);
        transition: all 0.3s ease;
        cursor: pointer;
        position: relative;
        text-decoration: none;
    }

    .nav-link::after {
        content: '';
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--laser-blue), var(--build-green));
        transition: width 0.3s ease;
    }

    .nav-link:hover::after {
        width: 100%;
    }

    .nav-link:hover {
        color: var(--laser-blue);
    }

    body.dark-theme .nav-link:hover {
        color: var(--build-green);
    }

    /* Dropdown Styles */
    .dropdown {
        position: relative;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        margin-top: 0.5rem;
        min-width: 240px;
        background-color: var(--header-dropdown-bg);
        border: 1px solid var(--header-border);
        border-radius: 0.75rem;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.02);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 100;
        overflow: hidden;
    }

    .dropdown-menu.active {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .dropdown-menu a {
        display: block;
        padding: 0.75rem 1rem;
        color: var(--header-text);
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 0.875rem;
    }

    .dropdown-menu a i {
        width: 1.25rem;
        margin-right: 0.5rem;
    }

    .dropdown-menu a:hover {
        background-color: var(--header-dropdown-hover);
        color: var(--laser-blue);
        padding-left: 1.25rem;
    }

    body.dark-theme .dropdown-menu a:hover {
        color: var(--build-green);
    }

    .dropdown-toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

    .dropdown-toggle i {
        transition: transform 0.3s ease;
        font-size: 0.75rem;
    }

    .dropdown.active .dropdown-toggle i {
        transform: rotate(180deg);
    }

    /* Logo */
    .logo-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
    }

    .logo-icon {
        width: 2.5rem;
        height: 2.5rem;
        background: var(--header-logo-gradient);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 1.25rem;
        transition: transform 0.3s ease;
    }

    .logo-icon:hover {
        transform: scale(1.05);
    }

    .logo-text {
        font-size: 1.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--laser-blue), var(--build-green));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }

    .logo-subtitle {
        font-size: 0.75rem;
        color: var(--header-text-secondary);
        margin-top: -0.25rem;
    }

    /* CTA Buttons */
    .btn-outline {
        padding: 0.5rem 1rem;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
        text-decoration: none;
        color: var(--laser-blue);
        border: 1px solid var(--laser-blue);
    }

    .btn-outline:hover {
        background-color: var(--header-dropdown-hover);
        transform: translateY(-1px);
    }

    .btn-primary {
        padding: 0.5rem 1rem;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
        text-decoration: none;
        background: linear-gradient(135deg, var(--laser-blue), var(--build-green));
        color: white;
        box-shadow: 0 2px 4px rgba(0, 102, 255, 0.2);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 102, 255, 0.3);
    }

    /* Theme Toggle */
    .theme-toggle-btn {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        background-color: var(--header-icon-bg);
        color: var(--header-icon-color);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
    }

    .theme-toggle-btn:hover {
        background-color: var(--header-dropdown-hover);
        transform: rotate(15deg);
    }

    /* Mobile Menu Button */
    .mobile-menu-btn {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.5rem;
        background-color: var(--header-icon-bg);
        color: var(--header-icon-color);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
    }

    .mobile-menu-btn:hover {
        background-color: var(--header-dropdown-hover);
    }

    /* Mobile Menu */
    .mobile-menu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s ease;
        background-color: var(--header-bg);
        border-radius: 0.75rem;
    }

    .mobile-menu.open {
        max-height: 600px;
    }

    .mobile-menu a {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        color: var(--header-text);
        text-decoration: none;
        border-bottom: 1px solid var(--header-border);
        transition: all 0.2s ease;
    }

    .mobile-menu a:hover {
        background-color: var(--header-dropdown-hover);
        padding-left: 1.25rem;
    }

    .mobile-menu a i {
        width: 1.25rem;
        text-align: center;
    }

    .mobile-menu .btn-outline,
    .mobile-menu .btn-primary {
        display: block;
        text-align: center;
        margin: 0.5rem 1rem;
    }

    /* Responsive Design */
    @media (max-width: 1024px) {
        .desktop-nav {
            display: none;
        }
        
        .desktop-cta {
            display: none;
        }
        
        .mobile-menu-btn {
            display: flex;
        }
        
        .logo-text {
            font-size: 1.25rem;
        }
        
        .logo-icon {
            width: 2rem;
            height: 2rem;
            font-size: 1rem;
        }
    }
    
    @media (min-width: 1025px) {
        .mobile-menu-btn {
            display: none;
        }
        
        .desktop-nav {
            display: flex;
        }
        
        .desktop-cta {
            display: flex;
        }
    }
</style>

