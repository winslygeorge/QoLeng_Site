    <span class="code-keyword">return</span> HTML.useLayout(<span class="code-string">"main"</span>, {
        title = (ctx.title <span class="code-keyword">or</span> <span class="code-string">"Admin"</span>) .. <span class="code-string">" | Admin Panel"</span>,
        content = HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"admin-layout"</span> }, {
            HTML.e(<span class="code-string">"aside"</span>, { class = <span class="code-string">"sidebar"</span> }, {
                HTML.e(<span class="code-string">"h3"</span>, {}, <span class="code-string">"Admin Menu"</span>),
                HTML.e(<span class="code-string">"ul"</span>, {}, {
                    HTML.e(<span class="code-string">"li"</span>, {}, HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/admin"</span> }, <span class="code-string">"Dashboard"</span>)),
                    HTML.e(<span class="code-string">"li"</span>, {}, HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/admin/users"</span> }, <span class="code-string">"Users"</span>)),
                    HTML.e(<span class="code-string">"li"</span>, {}, HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/admin/settings"</span> }, <span class="code-string">"Settings"</span>))
                })
            }),
            HTML.e(<span class="code-string">"section"</span>, { class = <span class="code-string">"admin-content"</span> }, {
                ctx.content
            })
        }),
        slots = ctx.slots
    })
<span class="code-keyword">end</span>)</code></pre>
                </div>
            </div>

            <!-- Rendering & App Setup -->
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
