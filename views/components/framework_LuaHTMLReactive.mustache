                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Form Schema System</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.setSchema(name, schema)</h4>
                    <p class="text-light-text-secondary mb-3">Registers a validation schema for form generation and validation.</p>
                    
                    <table class="param-table">
                        <thead>
