            HTML.client.setAttrs(<span class="code-string">"#animated"</span>, { style = <span class="code-string">"transform: rotate(1deg)"</span> })
        ),
        <span class="code-string">"animation1"</span>
    )
)

<span class="code-comment">-- Control flow with conditions</span>
<span class="code-keyword">local</span> controlFlow = HTML.client.if_(
