                        HTML.client.setText(<span class="code-string">"#form-errors"</span>, <span class="code-string">"Registration failed. Please try again."</span>)
                    )
                )
            ))
        }, {
            registrationForm,
            HTML.e(<span class="code-string">"div"</span>, { id = <span class="code-string">"form-errors"</span>, class = <span class="code-string">"error-message"</span> }),
            HTML.PrimaryButton(<span class="code-string">"Create Account"</span>, { type = <span class="code-string">"submit"</span> })
        })
    })
<span class="code-keyword">end</span>)

