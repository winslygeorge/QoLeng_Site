            { id = 2, name = <span class="code-string">"Item 2"</span>, completed = true },
            { id = 3, name = <span class="code-string">"Item 3"</span>, completed = false }
        },
        ui = {
            loading = false,
            currentView = <span class="code-string">"dashboard"</span>
        }
    },
    head_extra = HTML.fragment({
        HTML.e(<span class="code-string">"meta"</span>, { name = <span class="code-string">"description"</span>, content = <span class="code-string">"My awesome app"</span> }),
        HTML.e(<span class="code-string">"link"</span>, { rel = <span class="code-string">"preconnect"</span>, href = <span class="code-string">"https://fonts.googleapis.com"</span> }),
        HTML.e(<span class="code-string">"style"</span>, {}, <span class="code-string">[[
            .loading { opacity: 0.5; pointer-events: none; }
            .error { color: red; border: 1px solid red; }
        ]]</span>)
    }),
    body_attrs = {
        class = <span class="code-string">"app-body"</span>,
        onload = <span class="code-string">"console.log('App loaded')"</span>
    },
    children = HTML.useLayout(<span class="code-string">"main"</span>, {
        title = <span class="code-string">"Dashboard"</span>,
        content = HTML.fragment({
            HTML.Component(<span class="code-string">"userProfile"</span>, { userId = <span class="code-string">"user123"</span> }),
            HTML.Component(<span class="code-string">"todoList"</span>, { items = <span class="code-string">"state.items"</span> }),
            HTML.Component(<span class="code-string">"recentActivity"</span>, { limit = 10 })
        }),
        slots = {
            navigation = HTML.fragment({
                HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/dashboard"</span>, class = <span class="code-string">"nav-link active"</span> }, <span class="code-string">"Dashboard"</span>),
                HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/profile"</span>, class = <span class="code-string">"nav-link"</span> }, <span class="code-string">"Profile"</span>),
                HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/settings"</span>, class = <span class="code-string">"nav-link"</span> }, <span class="code-string">"Settings"</span>)
            }),
            footer = HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"footer-content"</span> }, {
