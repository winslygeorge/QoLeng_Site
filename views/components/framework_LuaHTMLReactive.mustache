            <!-- Component Creation -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Component Creation & Management</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.createComponent(fn, initialState)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a stateful reactive component with lifecycle methods.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>fn</td>
                                <td>function</td>
                                <td>Render function: function(state, props) return VDOMNode end</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>initialState</td>
                                <td>table?</td>
                                <td>Initial component state {key = value}</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> Component - Object with: state, lastNode, patches, props, reactiveBindings, setState, render, patch, methods</p>
                </div>

                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Component:setState(partial)</h4>
                    <p class="text-light-text-secondary mb-3">Updates component state and generates UI patches.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>partial</td>
                                <td>table</td>
                                <td>Partial state update {key = newValue}</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> PatchObject[] - Generated patches for UI updates</p>
                </div>

                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Component Creation Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Simple counter component</span>
<span class="code-keyword">local</span> Counter = HTML.createComponent(<span class="code-keyword">function</span>(state, props)
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"counter"</span> }, {
        HTML.e(<span class="code-string">"h2"</span>, {}, <span class="code-string">"Count: "</span> .. state.count),
        HTML.e(<span class="code-string">"button"</span>, {
            onclick = HTML.on(<span class="code-string">"click"</span>, HTML.handler(<span class="code-string">"increment"</span>, props.id))
        }, <span class="code-string">"+"</span>),
        HTML.e(<span class="code-string">"button"</span>, {
            onclick = HTML.on(<span class="code-string">"click"</span>, HTML.handler(<span class="code-string">"decrement"</span>, props.id))
        }, <span class="code-string">"-"</span>),
        HTML.e(<span class="code-string">"button"</span>, {
            onclick = HTML.on(<span class="code-string">"click"</span>, HTML.handler(<span class="code-string">"reset"</span>, props.id))
        }, <span class="code-string">"Reset"</span>)
    })
<span class="code-keyword">end</span>, {
    count = 0,
    _reactiveBindings = { count = true } <span class="code-comment">-- Make count reactive</span>
})

<span class="code-comment">-- Add component methods</span>
Counter.methods = {
    increment = <span class="code-keyword">function</span>(self)
        <span class="code-keyword">return</span> self:setState({ count = self.state.count + 1 })
    <span class="code-keyword">end</span>,
    
    decrement = <span class="code-keyword">function</span>(self)
        <span class="code-keyword">return</span> self:setState({ count = self.state.count - 1 })
    <span class="code-keyword">end</span>,
    
    reset = <span class="code-keyword">function</span>(self)
        <span class="code-keyword">return</span> self:setState({ count = 0 })
    <span class="code-keyword">end</span>,
    
    setCount = <span class="code-keyword">function</span>(self, newCount)
        <span class="code-keyword">return</span> self:setState({ count = newCount })
    <span class="code-keyword">end</span>
}

<span class="code-comment">-- Render the component</span>
<span class="code-keyword">local</span> counterHTML = Counter:render({ id = <span class="code-string">"counter1"</span> })

<span class="code-comment">-- Update state (triggers patches)</span>
<span class="code-keyword">local</span> patches = Counter:setState({ count = 5 })</code></pre>
                </div>
            </div>

            <!-- Component Patching -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Component Patching & Communication</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.patch(parentKey, componentKey, method, ...)</h4>
                    <p class="text-light-text-secondary mb-3">Sends patch message to component for server-side method execution.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>parentKey</td>
                                <td>string</td>
                                <td>Parent component identifier</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>componentKey</td>
                                <td>string?</td>
                                <td>Child component key for namespacing</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>method</td>
                                <td>string</td>
                                <td>Component method name to call</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>...</td>
                                <td>any</td>
                                <td>Arguments to pass to component method</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> HandlerObject - Server handler for patch operation</p>
                </div>

                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.Component(component_key, props)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a component placeholder for embedding.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>component_key</td>
                                <td>string</td>
                                <td>Key of the component to embed</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>props</td>
                                <td>table?</td>
                                <td>Properties to pass to component</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> VDOMNode - Component placeholder element</p>
                </div>

                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Component Communication Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Parent component with embedded children</span>
<span class="code-keyword">local</span> Dashboard = HTML.createComponent(<span class="code-keyword">function</span>(state, props)
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"dashboard"</span> }, {
        HTML.e(<span class="code-string">"h1"</span>, {}, <span class="code-string">"Dashboard"</span>),
        
        <span class="code-comment">-- Embedded components</span>
        HTML.Component(<span class="code-string">"userProfile"</span>, {
            userId = state.currentUserId,
            parentComponentKey = <span class="code-string">"dashboard"</span>
        }),
        
        HTML.Component(<span class="code-string">"notifications"</span>, {
            parentComponentKey = <span class="code-string">"dashboard"</span>
        }),
        
        HTML.Component(<span class="code-string">"recentActivity"</span>, {
            limit = 10,
            parentComponentKey = <span class="code-string">"dashboard"</span>
        }),
        
        <span class="code-comment">-- Buttons that patch child components</span>
        HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"controls"</span> }, {
            HTML.e(<span class="code-string">"button"</span>, {
                onclick = HTML.on(<span class="code-string">"click"</span>, HTML.patch(
                    <span class="code-string">"dashboard"</span>,
                    <span class="code-string">"userProfile"</span>,
                    <span class="code-string">"refreshData"</span>,
                    state.currentUserId
                ))
            }, <span class="code-string">"Refresh Profile"</span>),
            
            HTML.e(<span class="code-string">"button"</span>, {
                onclick = HTML.on(<span class="code-string">"click"</span>, HTML.patch(
                    <span class="code-string">"dashboard"</span>,
                    <span class="code-string">"notifications"</span>,
                    <span class="code-string">"markAllRead"</span>
                ))
            }, <span class="code-string">"Mark All Read"</span>),
            
            HTML.e(<span class="code-string">"button"</span>, {
                onclick = HTML.on(<span class="code-string">"click"</span>, HTML.patch(
                    <span class="code-string">"dashboard"</span>,
                    <span class="code-string">"recentActivity"</span>,
                    <span class="code-string">"loadMore"</span>,
                    20
                ))
            }, <span class="code-string">"Load More"</span>)
        })
    })
<span class="code-keyword">end</span>, {
    currentUserId = <span class="code-string">"user123"</span>
})

<span class="code-comment">-- Child component implementation</span>
<span class="code-keyword">local</span> UserProfile = HTML.createComponent(<span class="code-keyword">function</span>(state, props)
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"user-profile"</span> }, {
        HTML.e(<span class="code-string">"img"</span>, { src = state.avatar, class = <span class="code-string">"avatar"</span> }),
        HTML.e(<span class="code-string">"h2"</span>, {}, state.name),
        HTML.e(<span class="code-string">"p"</span>, {}, state.email)
    })
<span class="code-keyword">end</span>, {
    name = <span class="code-string">"Loading..."</span>,
    email = <span class="code-string">""</span>,
    avatar = <span class="code-string">"/default-avatar.jpg"</span>
})

<span class="code-comment">-- Child component methods</span>
UserProfile.methods = {
    refreshData = <span class="code-keyword">function</span>(self, userId)
        <span class="code-comment">-- Simulate API call</span>
        <span class="code-keyword">local</span> userData = {
            name = <span class="code-string">"Jane Smith"</span>,
            email = <span class="code-string">"jane@example.com"</span>,
            avatar = <span class="code-string">"/avatars/jane.jpg"</span>
        }
        <span class="code-keyword">return</span> self:setState(userData)
    <span class="code-keyword">end</span>,
    
    updateProfile = <span class="code-keyword">function</span>(self, updates)
        <span class="code-keyword">return</span> self:setState(updates)
    <span class="code-keyword">end</span>
}

<span class="code-comment">-- Register components for use with HTML.Component</span>
<span class="code-comment">-- This would typically be done in a component registry</span></code></pre>
                </div>
            </div>

            <!-- Enhanced Components -->
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Enhanced Component Features</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.createComponentWithClientState(options)</h4>
                    <p class="text-light-text-secondary mb-3">Creates component with built-in clientState support.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>options</td>
                                <td>table</td>
                                <td>Component configuration</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>options.render</td>
                                <td>function</td>
                                <td>Render function: function(state, props, clientState)</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>options.initialState</td>
                                <td>table?</td>
                                <td>Initial component state</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>options.initialClientState</td>
                                <td>table?</td>
                                <td>Initial client state</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>options.methods</td>
                                <td>table?</td>
                                <td>Component methods</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>options.onClientStateChange</td>
                                <td>function?</td>
                                <td>Callback when clientState changes</td>
