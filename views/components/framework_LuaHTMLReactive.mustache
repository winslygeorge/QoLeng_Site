    )
)

<span class="code-comment">-- Loop operations</span>
<span class="code-keyword">local</span> loopOps = HTML.client.for_loop(
    HTML.client.setVar(<span class="code-string">"i"</span>, 0),
    HTML.client.lt(HTML.client.getVar(<span class="code-string">"i"</span>), 10),
