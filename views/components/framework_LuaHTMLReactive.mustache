                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Complete application setup</span>
<span class="code-keyword">local</span> app = HTML.App({
    title = <span class="code-string">"My Reactive Application"</span>,
    state = {
        user = {
            id = <span class="code-string">"user123"</span>,
