                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Define a main layout</span>
HTML.defineLayout(<span class="code-string">"main"</span>, <span class="code-keyword">function</span>(ctx)
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"html"</span>, {}, {
        HTML.e(<span class="code-string">"head"</span>, {}, {
            HTML.e(<span class="code-string">"title"</span>, {}, ctx.title <span class="code-keyword">or</span> <span class="code-string">"Default Title"</span>),
            HTML.e(<span class="code-string">"meta"</span>, { charset = <span class="code-string">"utf-8"</span> }),
            HTML.e(<span class="code-string">"meta"</span>, { 
                name = <span class="code-string">"viewport"</span>, 
                content = <span class="code-string">"width=device-width, initial-scale=1.0"</span> 
            }),
            HTML.Slot(<span class="code-string">"head"</span>, ctx)
        }),
        HTML.e(<span class="code-string">"body"</span>, {}, {
            HTML.e(<span class="code-string">"header"</span>, { class = <span class="code-string">"header"</span> }, {
                HTML.e(<span class="code-string">"nav"</span>, {}, {
                    HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/"</span> }, <span class="code-string">"Home"</span>),
                    HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/about"</span> }, <span class="code-string">"About"</span>),
                    HTML.Slot(<span class="code-string">"navigation"</span>, ctx)
                })
            }),
            HTML.e(<span class="code-string">"main"</span>, { class = <span class="code-string">"main-content"</span> }, {
                ctx.content
            }),
            HTML.e(<span class="code-string">"footer"</span>, { class = <span class="code-string">"footer"</span> }, {
                HTML.Slot(<span class="code-string">"footer"</span>, ctx)
            })
        })
    })
<span class="code-keyword">end</span>)

<span class="code-comment">-- Use the layout</span>
<span class="code-keyword">local</span> homePage = HTML.useLayout(<span class="code-string">"main"</span>, {
    title = <span class="code-string">"Home Page"</span>,
    content = HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"home"</span> }, {
