    HTML.client.batch(
        HTML.client.append(<span class="code-string">"#output"</span>, HTML.client.getVar(<span class="code-string">"i"</span>)),
        HTML.client.console(<span class="code-string">"log"</span>, HTML.client.getVar(<span class="code-string">"i"</span>))
    )
)</code></pre>
