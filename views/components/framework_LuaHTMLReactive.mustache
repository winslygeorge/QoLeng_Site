        <!-- VDOM System Section -->
        <section id="vdom" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">VDOM System</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Core VDOM Functions</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.e(tag, attrs, children)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a Virtual DOM node representing an HTML element.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>tag</td>
                                <td>string</td>
                                <td>HTML tag name (e.g., "div", "span", "h1")</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>attrs</td>
                                <td>table?</td>
                                <td>Table of HTML attributes {key = value}</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>children</td>
                                <td>string|number|VDOMNode|VDOMNode[]?</td>
                                <td>Text content or child VDOM nodes</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> VDOMNode - A virtual DOM node table with structure: {tag, attrs, children, content}</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Element Creation Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Simple element with text content</span>
<span class="code-keyword">local</span> title = HTML.e(<span class="code-string">"h1"</span>, { class = <span class="code-string">"title"</span> }, <span class="code-string">"Hello World"</span>)

<span class="code-comment">-- Element with multiple attributes</span>
<span class="code-keyword">local</span> button = HTML.e(<span class="code-string">"button"</span>, {
    id = <span class="code-string">"submit-btn"</span>,
    class = <span class="code-string">"btn btn-primary"</span>,
    disabled = true,
    style = <span class="code-string">"background: blue; color: white;"</span>
}, <span class="code-string">"Submit"</span>)

<span class="code-comment">-- Nested elements with children array</span>
<span class="code-keyword">local</span> list = HTML.e(<span class="code-string">"ul"</span>, { class = <span class="code-string">"menu"</span> }, {
    HTML.e(<span class="code-string">"li"</span>, {}, <span class="code-string">"Item 1"</span>),
    HTML.e(<span class="code-string">"li"</span>, {}, <span class="code-string">"Item 2"</span>),
    HTML.e(<span class="code-string">"li"</span>, {}, <span class="code-string">"Item 3"</span>)
})

<span class="code-comment">-- Self-closing tag</span>
<span class="code-keyword">local</span> image = HTML.e(<span class="code-string">"img"</span>, {
    src = <span class="code-string">"photo.jpg"</span>,
    alt = <span class="code-string">"A beautiful photo"</span>
}) <span class="code-comment">-- No children needed for self-closing tags</span></code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.fragment(children)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a VDOM fragment for grouping multiple nodes without a wrapper element.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>children</td>
                                <td>VDOMNode|VDOMNode[]</td>
                                <td>A list of VDOM nodes to include in the fragment</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> VDOMNode - A fragment VDOM node table with structure: {tag = nil, children = children}</p>
                </div>

                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.bindText(varName, content, attrs)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a reactive text element that updates when state changes.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>varName</td>
                                <td>string</td>
                                <td>Name of the state variable this element is bound to</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>content</td>
                                <td>string|number</td>
                                <td>Current value of the variable</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>attrs</td>
                                <td>table?</td>
                                <td>Additional attributes for the span element</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> VDOMNode - A span element with data-bind attribute</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Fragment & Reactive Binding Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Fragment example</span>
<span class="code-keyword">local</span> tableRows = HTML.fragment({
    HTML.e(<span class="code-string">"tr"</span>, {}, {
        HTML.e(<span class="code-string">"td"</span>, {}, <span class="code-string">"John"</span>),
        HTML.e(<span class="code-string">"td"</span>, {}, <span class="code-string">"30"</span>)
    }),
    HTML.e(<span class="code-string">"tr"</span>, {}, {
        HTML.e(<span class="code-string">"td"</span>, {}, <span class="code-string">"Jane"</span>),
        HTML.e(<span class="code-string">"td"</span>, {}, <span class="code-string">"25"</span>)
    })
})

<span class="code-keyword">local</span> tableElement = HTML.e(<span class="code-string">"table"</span>, {}, tableRows)

<span class="code-comment">-- Reactive text binding</span>
<span class="code-keyword">local</span> userState = { name = <span class="code-string">"John Doe"</span>, score = 100 }
<span class="code-keyword">local</span> userDisplay = HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"user-info"</span> }, {
    HTML.e(<span class="code-string">"h2"</span>, {}, <span class="code-string">"User: "</span>),
    HTML.bindText(<span class="code-string">"userName"</span>, userState.name, { class = <span class="code-string">"font-bold"</span> }),
    HTML.e(<span class="code-string">"br"</span>),
    HTML.e(<span class="code-string">"span"</span>, {}, <span class="code-string">"Score: "</span>),
    HTML.bindText(<span class="code-string">"userScore"</span>, userState.score, { class = <span class="code-string">"text-green-500"</span> })
})

<span class="code-comment">-- When userState changes, the bound elements update automatically</span></code></pre>
                </div>
            </div>
            
            <!-- Diff & Patch System -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Diff & Patch System</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.diff(old, new, path)</h4>
                    <p class="text-light-text-secondary mb-3">Compares two VDOM trees and generates patches for efficient updates.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>old</td>
                                <td>VDOMNode?</td>
                                <td>Previous VDOM tree</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>new</td>
                                <td>VDOMNode?</td>
                                <td>New VDOM tree</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>path</td>
                                <td>string?</td>
                                <td>Internal path tracking (default: "root")</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> PatchObject[] - Array of patch objects with types: "attr", "remove-attr", "text", "replace", "remove"</p>
                </div>

                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.toJS(patches)</h4>
                    <p class="text-light-text-secondary mb-3">Converts patch objects to executable JavaScript code.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>patches</td>
                                <td>PatchObject[]</td>
                                <td>Array of patch objects from HTML.diff</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> string - JavaScript code that applies the patches</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Diff & Patch Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Initial VDOM</span>
<span class="code-keyword">local</span> oldVDOM = HTML.e(<span class="code-string">"div"</span>, {
    id = <span class="code-string">"container"</span>,
    class = <span class="code-string">"old-style"</span>
}, <span class="code-string">"Old content"</span>)

<span class="code-comment">-- Updated VDOM</span>
<span class="code-keyword">local</span> newVDOM = HTML.e(<span class="code-string">"div"</span>, {
    id = <span class="code-string">"container"</span>,
    class = <span class="code-string">"new-style active"</span>,
    style = <span class="code-string">"color: red;"</span>
}, <span class="code-string">"New content"</span>)

<span class="code-comment">-- Generate patches</span>
<span class="code-keyword">local</span> patches = HTML.diff(oldVDOM, newVDOM)

<span class="code-comment">-- Convert to JavaScript</span>
<span class="code-keyword">local</span> jsCode = HTML.toJS(patches)

<span class="code-comment">-- Output JavaScript would be:</span>
<span class="code-comment">-- document.querySelector("#container").setAttribute("class", "new-style active");</span>
<span class="code-comment">-- document.querySelector("#container").setAttribute("style", "color: red;");</span>
<span class="code-comment">-- document.querySelector("#container").textContent = "New content";</span>

print(jsCode)</code></pre>
                </div>
            </div>

            <!-- Advanced Patch Types -->
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Advanced Patch Types</h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.patch_list(selector, items, template_id, classes, staggerDelay)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a patch for updating lists reactively.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>selector</td>
                                <td>string</td>
                                <td>CSS selector for the list container</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>items</td>
                                <td>table</td>
                                <td>New list of data items</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>template_id</td>
                                <td>string</td>
                                <td>ID of HTML template for rendering items</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>classes</td>
                                <td>string?</td>
                                <td>CSS classes for staggered updates</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>staggerDelay</td>
                                <td>number?</td>
                                <td>Delay in ms for staggered item updates</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML.patch_object(selector, object, template_id)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a patch for updating object properties reactively.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>selector</td>
                                <td>string</td>
                                <td>CSS selector for the object container</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>object</td>
                                <td>table</td>
                                <td>New object data</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>template_id</td>
                                <td>string</td>
                                <td>ID of HTML template for rendering object</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Advanced Patch Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- List patch for todo items</span>
<span class="code-keyword">local</span> todos = {
    { id = 1, text = <span class="code-string">"Learn Lua"</span>, completed = true },
    { id = 2, text = <span class="code-string">"Build app"</span>, completed = false },
    { id = 3, text = <span class="code-string">"Deploy"</span>, completed = false }
}

<span class="code-keyword">local</span> listPatch = HTML.patch_list(
    <span class="code-string">"#todo-list"</span>,
    todos,
    <span class="code-string">"todo-item-template"</span>,
    <span class="code-string">"fade-in"</span>,
    100 <span class="code-comment">-- 100ms stagger delay</span>
)

<span class="code-comment">-- Object patch for user profile</span>
<span class="code-keyword">local</span> user = {
    name = <span class="code-string">"Jane Smith"</span>,
    email = <span class="code-string">"jane@example.com"</span>,
    avatar = <span class="code-string">"avatar.jpg"</span>,
    bio = <span class="code-string">"Software developer"</span>
}

<span class="code-keyword">local</span> objectPatch = HTML.patch_object(
    <span class="code-string">"#user-profile"</span>,
    user,
    <span class="code-string">"user-profile-template"</span>
)

<span class="code-comment">-- Nested patch for complex objects</span>
<span class="code-keyword">local</span> nestedPatch = HTML.patch_nested(
    <span class="code-string">"#app"</span>,
    <span class="code-string">"user.preferences.theme"</span>,
    <span class="code-string">"dark"</span>
)</code></pre>
