        HTML.e(<span class="code-string">"p"</span>, {}, <span class="code-string">"This is the home page content."</span>)
    }),
    slots = {
        head = HTML.e(<span class="code-string">"link"</span>, { 
            rel = <span class="code-string">"stylesheet"</span>, 
            href = <span class="code-string">"/styles.css"</span> 
        }),
        navigation = HTML.e(<span class="code-string">"a"</span>, { href = <span class="code-string">"/contact"</span> }, <span class="code-string">"Contact"</span>),
        footer = HTML.e(<span class="code-string">"p"</span>, {}, <span class="code-string">"© 2023 My Company"</span>)
    }
})

<span class="code-comment">-- Define admin layout</span>
