                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Enhanced Component Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Component with clientState support</span>
<span class="code-keyword">local</span> EnhancedUserProfile = HTML.createComponentWithClientState({
    render = <span class="code-keyword">function</span>(state, props, clientState)
        <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"user-profile"</span> }, {
            HTML.e(<span class="code-string">"img"</span>, { 
                src = state.avatar,
                class = <span class="code-string">"avatar"</span>,
                style = clientState.avatarLoaded <span class="code-keyword">and</span> <span class="code-string">""</span> <span class="code-keyword">or</span> <span class="code-string">"display: none"</span>
            }),
            HTML.e(<span class="code-string">"h2"</span>, {}, state.name),
            HTML.clientStateDisplay(<span class="code-string">"onlineStatus"</span>, <span class="code-keyword">function</span>(value)
                <span class="code-keyword">return</span> value <span class="code-keyword">and</span> <span class="code-string">"🟢 Online"</span> <span class="code-keyword">or</span> <span class="code-string">"🔴 Offline"</span>
            <span class="code-keyword">end</span>),
            HTML.clientStateInput(<span class="code-string">"statusMessage"</span>, <span class="code-string">"text"</span>, {
                placeholder = <span class="code-string">"Update your status..."</span>,
                class = <span class="code-string">"status-input"</span>
            })
        })
    <span class="code-keyword">end</span>,
    
    initialState = {
        name = <span class="code-string">"John Doe"</span>,
        avatar = <span class="code-string">"/avatar.jpg"</span>,
        email = <span class="code-string">"john@example.com"</span>
    },
    
    initialClientState = {
        onlineStatus = true,
        statusMessage = <span class="code-string">"Hello world!"</span>,
        avatarLoaded = false
    },
    
    methods = {
        setOnline = <span class="code-keyword">function</span>(self, online)
            <span class="code-keyword">return</span> self:setClientState({ onlineStatus = online })
        <span class="code-keyword">end</span>,
        
        onAvatarLoad = <span class="code-keyword">function</span>(self)
            <span class="code-keyword">return</span> self:setClientState({ avatarLoaded = true })
        <span class="code-keyword">end</span>
    },
    
    onClientStateChange = <span class="code-keyword">function</span>(self, newClientState, oldClientState)
        <span class="code-keyword">if</span> newClientState.onlineStatus ~= oldClientState.onlineStatus <span class="code-keyword">then</span>
            print(<span class="code-string">"Online status changed to:"</span>, newClientState.onlineStatus)
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>
})

<span class="code-comment">-- Using clientState bound elements</span>
<span class="code-keyword">local</span> statusIndicator = HTML.clientStateBound(<span class="code-string">"onlineStatus"</span>, <span class="code-keyword">function</span>(value)
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"span"</span>, {
        class = value <span class="code-keyword">and</span> <span class="code-string">"online"</span> <span class="code-keyword">or</span> <span class="code-string">"offline"</span>
    }, value <span class="code-keyword">and</span> <span class="code-string">"Online"</span> <span class="code-keyword">or</span> <span class="code-string">"Offline"</span>)
<span class="code-keyword">end</span>)</code></pre>
