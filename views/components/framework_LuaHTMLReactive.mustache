<span class="code-comment">-- Create a complete registration component</span>
<span class="code-keyword">local</span> RegistrationPage = HTML.createComponent(<span class="code-keyword">function</span>(state, props)
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"registration-page"</span> }, {
        HTML.e(<span class="code-string">"h1"</span>, {}, <span class="code-string">"Create Account"</span>),
        HTML.e(<span class="code-string">"form"</span>, {
            id = <span class="code-string">"registration-form"</span>,
            onsubmit = HTML.on(<span class="code-string">"submit"</span>, HTML.client.batch(
                HTML.client.preventDefault(),
                HTML.client.fetch(<span class="code-string">"/api/register"</span>, {
                    method = <span class="code-string">"POST"</span>,
                    body = HTML.client.getFormData(<span class="code-string">"#registration-form"</span>)
                }, <span class="code-string">"json"</span>, 
