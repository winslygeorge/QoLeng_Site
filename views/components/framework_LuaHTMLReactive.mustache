                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Schema Field Properties</h4>
                    <p class="text-light-text-secondary mb-3">Each field in a schema can have these properties:</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Property</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>name</td>
                                <td>string</td>
                                <td>Field name (used as form input name)</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>label</td>
                                <td>string?</td>
                                <td>Display label for the field</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>type</td>
                                <td>string?</td>
                                <td>Input type: "text", "email", "textarea", "select", "file", etc.</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>required</td>
                                <td>boolean?</td>
                                <td>Whether field is mandatory</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>pattern</td>
                                <td>string?</td>
                                <td>Regex pattern for validation</td>
                                <td>No</td>
                            </tr>
