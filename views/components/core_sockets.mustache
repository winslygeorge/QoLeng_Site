<span class="code-comment">-- Define channel handlers</span>
<span class="code-keyword">local</span> channel_handlers = {
    chat = {
        join = <span class="code-keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
            <span class="code-comment">-- User joined chat room</span>
            <span class="code-keyword">local</span> ws_id = self:<span class="code-type">safe_get_ws_id</span>(ws)
            print(<span class="code-string">"User joined chat:"</span> .. ws_id)
            
            <span class="code-comment">-- Send welcome message</span>
            self:<span class="code-type">send_to_user</span>(ws_id, {
                type = <span class="code-string">"system_message"</span>,
                content = <span class="code-string">"Welcome to the chat!"</span>,
                timestamp = os.time()
            })
        <span class="code-keyword">end</span>,
        
        message = <span class="code-keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
            <span class="code-comment">-- Broadcast message to room</span>
            self:<span class="code-type">broadcast_to_room</span>(topic, {
                type = <span class="code-string">"chat_message"</span>,
                sender = state.user_id,
                content = payload.content,
                timestamp = os.time()
            })
        <span class="code-keyword">end</span>,
        
        leave = <span class="code-keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
            <span class="code-comment">-- User left chat room</span>
            <span class="code-keyword">local</span> ws_id = self:<span class="code-type">safe_get_ws_id</span>(ws)
            print(<span class="code-string">"User left chat:"</span> .. ws_id)
        <span class="code-keyword">end</span>
    }
}

<span class="code-comment">-- Initialize DawnSockets</span>
<span class="code-keyword">local</span> socket_manager = DawnSockets:<span class="code-type">new</span>(
    dawn_server_instance,
