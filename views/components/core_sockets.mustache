                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- When user authenticates or identifies themselves</span>
identify = <span class="code-keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
    <span class="code-keyword">local</span> user_id = payload.user_id
    <span class="code-keyword">local</span> ws_id = self:<span class="code-type">safe_get_ws_id</span>(ws)
    
    <span class="code-comment">-- Bind user ID to WebSocket connection</span>
    self:<span class="code-type">syncPrivateChat</span>(user_id, ws)
    
    <span class="code-comment">-- Update connection state</span>
    state.user_id = user_id
    state.username = payload.username
    
    <span class="code-comment">-- Send confirmation</span>
    self:<span class="code-type">send_to_user</span>(ws_id, {
        type = <span class="code-string">"identification_success"</span>,
        user_id = user_id,
        timestamp = os.time()
    })
    
    print(<span class="code-string">"User"</span> .. user_id .. <span class="code-string">"bound to WebSocket"</span> .. ws_id)
<span class="code-keyword">end</span>

<span class="code-comment">-- Later, send private message using user ID</span>
<span class="code-keyword">local</span> target_user_id = <span class="code-string">"user_123"</span>
<span class="code-keyword">local</span> target_ws_id = socket_manager:<span class="code-type">getSyncPrivateChatId</span>(target_user_id)

<span class="code-keyword">if</span> target_ws_id <span class="code-keyword">then</span>
    socket_manager:<span class="code-type">send_to_user</span>(target_ws_id, {
        type = <span class="code-string">"private_message"</span>,
        from = current_user_id,
        message = <span class="code-string">"Hello there!"</span>,
        timestamp = os.time()
    })
<span class="code-keyword">else</span>
    print(<span class="code-string">"User is offline, message will be queued"</span>)
<span class="code-keyword">end</span></code></pre>
