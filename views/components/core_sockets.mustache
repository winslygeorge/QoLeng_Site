            </p>
            
            <div class="grid md:grid-cols-3 gap-6 mb-8">
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--laser-blue), var(--query-purple));">
                        <i class="fas fa-plug"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">Connection Management</h3>
                    <p style="color: var(--doc-text-secondary);">WebSocket lifecycle, user binding, and connection tracking</p>
                </div>
                
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--build-green), var(--query-purple));">
                        <i class="fas fa-broadcast-tower"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">Message Broadcasting</h3>
                    <p style="color: var(--doc-text-secondary);">Targeted messaging, room broadcasts, and user notifications</p>
                </div>
                
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--query-purple), var(--warning-amber));">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">Presence & Rooms</h3>
                    <p style="color: var(--doc-text-secondary);">Real-time presence tracking and dynamic room management</p>
                </div>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Basic Socket Setup</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Basic Dawn Sockets integration</span>
<span class="keyword">local</span> DawnSockets = <span class="keyword">require</span> <span class="string">"dawn_sockets"</span>

<span class="comment">-- Initialize with your Dawn server instance</span>
<span class="keyword">local</span> socket_manager = DawnSockets:<span class="function">new</span>(dawn_server, parent_supervisor, shared_state, {
    handlers = {
        channels = {
            chat = {
                join = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
                    <span class="comment">-- Handle user joining chat</span>
                <span class="keyword">end</span>,
                message = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
                    <span class="comment">-- Handle incoming messages</span>
                <span class="keyword">end</span>
            }
        }
    }
})</code></pre>
            </div>
        </div>
    </section>

    <!-- Initialization Section -->
    <section id="initialization" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">1</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">Initialization & Setup</h2>
        </div>
        
        <div class="rounded-xl p-6 mb-8 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="function-signature">
                <h4 class="font-bold text-lg mb-2">new(dawn_server, parent_supervisor, shared_state, options)</h4>
                <p class="mb-3" style="color: var(--doc-text-secondary);">Creates a new DawnSockets instance with the specified configuration.</p>
                
                <table class="param-table">
                    <thead><tr><th>Parameter</th><th>Type</th><th>Description</th> </thead>
                    <tbody>
                        <tr><td>dawn_server</td><td>object</td><td>The main Dawn server instance</td></tr>
                        <tr><td>parent_supervisor</td><td>object</td><td>Supervisor for process management</td></tr>
                        <tr><td>shared_state</td><td>table</td><td>Shared application state (optional)</td></tr>
                        <tr><td>options</td><td>table</td><td>Configuration options including handlers and state management</td></tr>
                    </tbody>
                </table>
                
                <p class="mt-3"><strong>Returns:</strong> DawnSockets instance</p>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Complete Initialization</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Define channel handlers</span>
<span class="keyword">local</span> channel_handlers = {
    chat = {
        join = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
            <span class="keyword">local</span> ws_id = self:<span class="function">safe_get_ws_id</span>(ws)
            print(<span class="string">"User joined chat:"</span> .. ws_id)
            
            self:<span class="function">send_to_user</span>(ws_id, {
                type = <span class="string">"system_message"</span>,
                content = <span class="string">"Welcome to the chat!"</span>
            })
        <span class="keyword">end</span>,
        
        message = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
            self:<span class="function">broadcast_to_room</span>(topic, {
                type = <span class="string">"chat_message"</span>,
                sender = state.user_id,
                content = payload.content
            })
        <span class="keyword">end</span>
    }
}

<span class="comment">-- Initialize DawnSockets</span>
<span class="keyword">local</span> socket_manager = DawnSockets:<span class="function">new</span>(
    dawn_server_instance,
    supervisor_instance,
    shared_state_table,
    { handlers = { channels = channel_handlers } }
)

<span class="comment">-- Start heartbeat for connection monitoring</span>
socket_manager:<span class="function">start_heartbeat</span>(<span class="number">30000</span>, <span class="number">60</span>)</code></pre>
            </div>
        </div>
    </section>

    <!-- Core Methods Section -->
    <section id="core-methods" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">2</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">Core Socket Methods</h2>
        </div>
        
        <div class="rounded-xl p-6 mb-8 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="method-category">Connection & Identification</div>
            
            <div class="function-signature">
                <h4 class="font-bold text-lg mb-2">safe_get_ws_id(ws)</h4>
                <p class="mb-3" style="color: var(--doc-text-secondary);">Safely retrieves the WebSocket ID from a WebSocket object.</p>
                <table class="param-table"><thead><tr><th>Parameter</th><th>Type</th><th>Description</th></tr></thead>
                <tbody><tr><td>ws</td><td>object</td><td>WebSocket connection object</td></tr></tbody></table>
                <p class="mt-3"><strong>Returns:</strong> string (WebSocket ID) or nil if invalid</p>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - WebSocket ID Usage</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code>message = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
    <span class="keyword">local</span> ws_id = self:<span class="function">safe_get_ws_id</span>(ws)
    
    <span class="keyword">if</span> <span class="keyword">not</span> ws_id <span class="keyword">then</span>
        self.logger:log(log_level.ERROR, <span class="string">"Invalid WebSocket connection"</span>)
        <span class="keyword">return</span>
    <span class="keyword">end</span>
    
    self:<span class="function">send_to_user</span>(ws_id, {
        type = <span class="string">"acknowledgement"</span>,
        message_id = payload.message_id,
        status = <span class="string">"received"</span>
    })
<span class="keyword">end</span></code></pre>
            </div>
            
            <div class="method-category">Message Sending</div>
            
            <div class="function-signature">
                <h4 class="font-bold text-lg mb-2">send_to_user(ws_unique_identifier, message_table, ack_callback)</h4>
                <p class="mb-3" style="color: var(--doc-text-secondary);">Sends a message to a specific user/connection with optional acknowledgement.</p>
                <table class="param-table">
                    <thead><tr><th>Parameter</th><th>Type</th><th>Description</th></tr></thead>
                    <tbody>
                        <tr><td>ws_unique_identifier</td><td>string</td><td>WebSocket ID or user ID to send message to</td></tr>
                        <tr><td>message_table</td><td>table</td><td>Message data (will be JSON encoded)</td></tr>
                        <tr><td>ack_callback</td><td>function</td><td>Optional callback for message acknowledgement</td></tr>
                    </tbody>
                </table>
                <p class="mt-3"><strong>Returns:</strong> boolean (true if sent, false if queued or failed)</p>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Message Sending Examples</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Send a simple message</span>
socket_manager:<span class="function">send_to_user</span>(<span class="string">"ws_12345"</span>, {
    type = <span class="string">"notification"</span>,
    title = <span class="string">"New Message"</span>,
    content = <span class="string">"You have a new message"</span>
})

<span class="comment">-- Send with acknowledgement</span>
socket_manager:<span class="function">send_to_user</span>(<span class="string">"user_67890"</span>, {
    id = <span class="string">"msg_001"</span>,
    type = <span class="string">"important_update"</span>
}, <span class="keyword">function</span>(response)
    <span class="keyword">if</span> response.error <span class="keyword">then</span>
        print(<span class="string">"Acknowledgement failed:"</span> .. response.error)
    <span class="keyword">end</span>
<span class="keyword">end</span>)</code></pre>
            </div>
        </div>
    </section>

    <!-- Room Management Section -->
