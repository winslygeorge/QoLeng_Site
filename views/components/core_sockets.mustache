                <p class="mb-3" style="color: var(--doc-text-secondary);">Sends a message to all connected WebSocket clients.</p>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Room Management Examples</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code>join = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
    self:<span class="function">join_room</span>(topic, ws, {
        username = payload.username,
        joined_at = os.time()
    })
    
    self:<span class="function">broadcast_to_room</span>(topic, {
        type = <span class="string">"user_joined"</span>,
        user_id = state.user_id,
        username = payload.username
    })
<span class="keyword">end</span>

message = <span class="keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
    self:<span class="function">broadcast_to_room</span>(topic, {
        type = <span class="string">"chat_message"</span>,
        user_id = state.user_id,
        username = state.username,
        content = payload.message
    })
<span class="keyword">end</span>

<span class="comment">-- Global announcement to all connected clients</span>
socket_manager:<span class="function">broadcast_to_all</span>({
    type = <span class="string">"system_announcement"</span>,
    message = <span class="string">"Server maintenance in 5 minutes"</span>
})</code></pre>
            </div>
        </div>
    </section>

    <!-- User Management Section -->
    <section id="user-management" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">4</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">User & Presence Management</h2>
        </div>
        
        <div class="rounded-xl p-6 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
