                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- In a channel handler for joining rooms</span>
join = <span class="code-keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
    <span class="code-comment">-- Add user to the room</span>
    self:<span class="code-type">join_room</span>(topic, ws, {
        username = payload.username,
        avatar = payload.avatar,
        joined_at = os.time()
    })
    
    <span class="code-comment">-- Notify room about new user</span>
    self:<span class="code-type">broadcast_to_room</span>(topic, {
        type = <span class="code-string">"user_joined"</span>,
        user_id = state.user_id,
        username = payload.username,
        timestamp = os.time()
    })
<span class="code-keyword">end</span>

<span class="code-comment">-- In a message handler for room communication</span>
message = <span class="code-keyword">function</span>(self, ws, payload, state, shared, topic, state_management)
    <span class="code-comment">-- Broadcast message to everyone in the room</span>
    self:<span class="code-type">broadcast_to_room</span>(topic, {
        type = <span class="code-string">"chat_message"</span>,
        user_id = state.user_id,
        username = state.username,
        content = payload.message,
        timestamp = os.time()
    })
<span class="code-keyword">end</span>

<span class="code-comment">-- Global announcement to all connected clients</span>
socket_manager:<span class="code-type">broadcast_to_all</span>({
