<script>
    // Toggle section submenu with animation
    function toggleSection(element) {
        const section = element.closest('.nav-section');
        section.classList.toggle('open');
        
        // Save state to localStorage
        const sectionTitle = element.querySelector('span')?.textContent || 'section';
        localStorage.setItem(`section_${sectionTitle}`, section.classList.contains('open') ? 'open' : 'closed');
    }
    
    // Toggle sidebar collapse (desktop only)
    function toggleSidebar() {
        const sidebar = document.getElementById('docSidebar');
        sidebar.classList.toggle('collapsed');
        
        // Save state to localStorage
        localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
    }
    
    // Open mobile sidebar
    function openMobileSidebar() {
        const sidebar = document.getElementById('docSidebar');
        const overlay = document.getElementById('mobileOverlay');
        const mobileToggle = document.getElementById('mobileSidebarToggle');
        
        sidebar.classList.add('mobile-open');
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // Hide the hamburger icon when sidebar is open
        if (mobileToggle) {
            mobileToggle.classList.add('hidden');
        }
    }
    
    // Close mobile sidebar
    function closeMobileSidebar() {
        const sidebar = document.getElementById('docSidebar');
        const overlay = document.getElementById('mobileOverlay');
        const mobileToggle = document.getElementById('mobileSidebarToggle');
        
        sidebar.classList.remove('mobile-open');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
        
        // Show the hamburger icon when sidebar is closed
        if (mobileToggle) {
            mobileToggle.classList.remove('hidden');
        }
    }
    
    // Load saved states
    function loadSavedStates() {
        // Load sidebar collapse state (desktop only)
        const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        const sidebar = document.getElementById('docSidebar');
        
        // Only apply collapse on desktop
        if (window.innerWidth > 1024 && isCollapsed && sidebar) {
            sidebar.classList.add('collapsed');
        }
        
        // Load section states
        document.querySelectorAll('.nav-section').forEach(section => {
            const titleDiv = section.querySelector('.nav-section-title');
            const sectionTitle = titleDiv?.querySelector('span')?.textContent || '';
            const savedState = localStorage.getItem(`section_${sectionTitle}`);
            
            if (savedState === 'open') {
                section.classList.add('open');
            } else if (savedState === 'closed') {
                section.classList.remove('open');
            } else {
                // Default: first section open, others closed
                const isFirstSection = section === document.querySelector('.nav-section');
                if (isFirstSection) {
                    section.classList.add('open');
                }
            }
        });
    }
    
    // Set active link based on current URL
    function setActiveLink() {
        const currentPath = window.location.pathname;
        let activeFound = false;
        
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href');
            if (href === currentPath || (href !== '#' && currentPath.startsWith(href) && href !== '/web')) {
                link.classList.add('active');
                activeFound = true;
                
                // Expand parent section
                const parentSection = link.closest('.nav-section');
                if (parentSection) {
                    parentSection.classList.add('open');
                }
            }
        });
        
        // If no active link found, highlight first item in first open section
        if (!activeFound) {
            const firstOpenSection = document.querySelector('.nav-section.open');
            if (firstOpenSection) {
                const firstLink = firstOpenSection.querySelector('.nav-link');
                if (firstLink) {
                    firstLink.classList.add('active');
                }
            }
        }
    }
    
    // Handle window resize
    function handleResize() {
        const sidebar = document.getElementById('docSidebar');
        const overlay = document.getElementById('mobileOverlay');
        const mobileToggle = document.getElementById('mobileSidebarToggle');
        
        if (window.innerWidth > 1024) {
            // Desktop: remove mobile classes and restore collapse state if needed
            if (sidebar) {
                sidebar.classList.remove('mobile-open');
                const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
                if (isCollapsed) {
                    sidebar.classList.add('collapsed');
                } else {
                    sidebar.classList.remove('collapsed');
                }
            }
            if (overlay) {
                overlay.classList.remove('active');
            }
            document.body.style.overflow = '';
            
            // Ensure mobile toggle is hidden on desktop
            if (mobileToggle) {
                mobileToggle.style.display = 'none';
            }
        } else {
            // Mobile: show toggle button and ensure it's visible if sidebar is closed
            if (mobileToggle) {
                mobileToggle.style.display = 'flex';
                // If sidebar is open, hide toggle, otherwise show it
                if (sidebar && sidebar.classList.contains('mobile-open')) {
                    mobileToggle.classList.add('hidden');
                } else {
                    mobileToggle.classList.remove('hidden');
                }
            }
            // Ensure collapse class is removed on mobile
            if (sidebar) {
                sidebar.classList.remove('collapsed');
            }
        }
    }
    
    // Sync theme with body
    function syncThemeWithBody() {
        const sidebar = document.getElementById('docSidebar');
        const body = document.body;
        
        if (body.classList.contains('dark-theme')) {
            sidebar.classList.add('dark-theme');
        } else {
            sidebar.classList.remove('dark-theme');
        }
    }
    
    // Initialize everything
    document.addEventListener('DOMContentLoaded', function() {
        loadSavedStates();
        setActiveLink();
        syncThemeWithBody();
        
        // Mobile sidebar toggle
        const mobileToggle = document.getElementById('mobileSidebarToggle');
        const overlay = document.getElementById('mobileOverlay');
        
        if (mobileToggle) {
            mobileToggle.addEventListener('click', openMobileSidebar);
        }
        
        if (overlay) {
            overlay.addEventListener('click', closeMobileSidebar);
        }
        
        // Close on escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeMobileSidebar();
            }
        });
        
        // Watch for theme changes
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.attributeName === 'class') {
                    syncThemeWithBody();
                }
            });
        });
        
        observer.observe(document.body, { attributes: true });
        
        // Add click handlers to nav links
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', function(e) {
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
                
                // Close mobile sidebar on click
                if (window.innerWidth <= 1024) {
                    closeMobileSidebar();
                }
            });
        });
        
        // Handle window resize
        window.addEventListener('resize', handleResize);
        
        // Initial resize check
        handleResize();
    });
</script>