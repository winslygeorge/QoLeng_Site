                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- LuaReactive component with state management</span>
<span class="code-keyword">function</span> MyComponent:renderLayout(state, props, children, H)
  <span class="code-keyword">local</span> count = state.count <span class="code-keyword">or</span> 0
  
