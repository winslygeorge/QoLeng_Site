            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Single Page Application (SPA)</h3>
                <p class="text-light-text-secondary mb-6">
                    Create reactive single-page applications with client-side routing, state management, 
                    and dynamic component rendering. Ideal for interactive web applications.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Main App Page Structure</h4>
                    <p class="text-light-text-secondary mb-3">The main entry point for LuaReactive SPAs includes routing, state management, and component lifecycle.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Component Part</th>
                                <th>Purpose</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>setReactiveView()</td>
                                <td>Marks the component as reactive for client-side updates</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>RouteManager</td>
                                <td>Handles client-side routing and component switching</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>ModalManager</td>
                                <td>Manages modal dialogs and prompts</td>
                                <td>Optional</td>
                            </tr>
                            <tr>
                                <td>renderLayout()</td>
                                <td>Defines the component's render structure</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">LuaReactive Main App Template</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Type "!dawn_main_app_page" to generate this template</span>
<span class="code-keyword">local</span> FunctionalComponent = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.FuncComponent"</span>)
<span class="code-keyword">local</span> HTML = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.LuaHTMLReactive"</span>)
<span class="code-keyword">local</span> cjson = <span class="code-keyword">require</span>(<span class="code-string">"cjson"</span>)

<span class="code-comment">-- Import pages</span>
<span class="code-keyword">local</span> HomePage = <span class="code-keyword">require</span>(<span class="code-string">"lib.components.home"</span>)

<span class="code-comment">-- Import RouteManager and ModalManager</span>
<span class="code-keyword">local</span> RouteManager = <span class="code-keyword">require</span>(<span class="code-string">"system.RouteManager"</span>)
<span class="code-keyword">local</span> ModalManager = <span class="code-keyword">require</span>(<span class="code-string">"system.ModalManager"</span>)

<span class="code-keyword">local</span> MainAppPage = FunctionalComponent:extends()
MainAppPage:setReactiveView()

MainAppPage.routeUrl = <span class="code-string">""</span>

<span class="code-keyword">function</span> MainAppPage:setRouteToNavigateTo(url)
  MainAppPage.routeUrl = url
  RouteManager.setCurrentBrowserRouteUrl(url)
<span class="code-keyword">end</span>

<span class="code-comment">-- Register routes</span>
RouteManager.registerRoute(<span class="code-string">"home"</span>, HomePage, {
  path = <span class="code-string">"/app"</span>,
  title = <span class="code-string">"Home"</span>,
  defaultRoute = <span class="code-keyword">true</span>
})

<span class="code-keyword">function</span> MainAppPage:renderLayout(state, props, children, H, client_state)
  <span class="code-keyword">local</span> parentKey = <span class="code-keyword">self</span>:getParentKey()
  <span class="code-keyword">local</span> componentKey = <span class="code-keyword">self</span>:getComponentKey()

  <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"app-container"</span> }, {
    HTML.Component(<span class="code-string">"routeManager"</span>, {}),
    HTML.Component(<span class="code-string">'modalManager'</span>, {})
  })
<span class="code-keyword">end</span>

<span class="code-keyword">local</span> <span class="code-keyword">function</span> startInit()
  MainAppPage:init(<span class="code-keyword">function</span>(server, children, props, style, HTMLReactive, collected_js_scripts, client_state)
    <span class="code-comment">--====== ROUTING METHODS ======</span>
    MainAppPage.methods.navigateTo = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
      <span class="code-keyword">local</span> routeManager = <span class="code-keyword">self</span>:getChildComponent(<span class="code-string">"routeManager"</span>)
      <span class="code-keyword">if</span> routeManager <span class="code-keyword">then</span>
        routeManager.methods.navigateTo(routeManager, ws_id, args)
      <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>

    MainAppPage.methods.navigateBack = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
      <span class="code-keyword">local</span> routeManager = <span class="code-keyword">self</span>:getChildComponent(<span class="code-string">"routeManager"</span>)
      <span class="code-keyword">if</span> routeManager <span class="code-keyword">then</span>
        routeManager.methods.navigateBack(routeManager, ws_id, args)
      <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>

    <span class="code-comment">--====== MODAL METHODS ======</span>
    MainAppPage.methods.showPrompt = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
      <span class="code-keyword">self</span>:callChildMethod(<span class="code-string">"modalManager"</span>, <span class="code-string">"showModal"</span>, ws_id, args)
    <span class="code-keyword">end</span>

    MainAppPage.methods.hidePrompt = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
      <span class="code-keyword">local</span> modalId = args.modalId <span class="code-keyword">or</span> <span class="code-keyword">nil</span>
      <span class="code-keyword">self</span>:callChildMethod(<span class="code-string">"modalManager"</span>, <span class="code-string">"hideModal"</span>, ws_id, {modalId = modalId})
    <span class="code-keyword">end</span>

    <span class="code-keyword">return</span> <span class="code-keyword">function</span>(state, props, children, H, client_state)
      <span class="code-keyword">return</span> MainAppPage:renderLayout(state, props, children, H)
    <span class="code-keyword">end</span>
  <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>

MainAppPage:onClientReady(<span class="code-keyword">function</span> (<span class="code-keyword">self</span>, parent_ws_id, parent_client_toke)
  <span class="code-keyword">local</span> clientState = <span class="code-keyword">self</span>:getClientState(<span class="code-keyword">self</span>._ws_id)
<span class="code-keyword">end</span>)

<span class="code-keyword">function</span> MainAppPage:render_layout()
  <span class="code-keyword">self</span>:setComponentKey(<span class="code-string">'mainAppPage'</span>)
  <span class="code-keyword">self</span>:loadStateFromRedis()
  startInit()

  <span class="code-comment">-- Add RouteManager as a child component</span>
  <span class="code-keyword">self</span>:addChildComponent(<span class="code-string">"routeManager"</span>, RouteManager)
  RouteManager:load()

  <span class="code-keyword">local</span> modalManager = <span class="code-keyword">require</span>(<span class="code-string">"system.ModalManager"</span>)
  <span class="code-keyword">self</span>:addChildComponent(<span class="code-string">'modalManager'</span>, modalManager)
  modalManager:load()

  <span class="code-keyword">local</span> final_html_vdom = <span class="code-keyword">self</span>:renderAppPage({
    title = <span class="code-string">"Hello Dawn App"</span>,
    state = <span class="code-keyword">self</span>.state,
    head_extra = HTML.fragment({
      HTML.e(<span class="code-string">"script"</span>, {}, string.format(
        <span class="code-string">"window.__DEFAULT_COMPONENT_KEY__ = %q;"</span>, 
        <span class="code-keyword">self</span>.component_key <span class="code-keyword">or</span> <span class="code-string">""</span>
      ))
    }),
    body_attrs = { class = <span class="code-string">"antialiased bg-[#FFFFFF]"</span> }
  })
  
  <span class="code-keyword">return</span> <span class="code-keyword">self</span>.HTMLReactive.render(final_html_vdom)
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> MainAppPage</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Route Registration Parameters</h4>
                    <p class="text-light-text-secondary mb-3">Register routes with the RouteManager to enable client-side navigation.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>routeName</td>
                                <td>string</td>
                                <td>Unique identifier for the route</td>
                            </tr>
                            <tr>
                                <td>component</td>
                                <td>Component</td>
                                <td>The component to render for this route</td>
                            </tr>
                            <tr>
                                <td>options</td>
                                <td>table</td>
                                <td>Configuration options for the route</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Route Options:</strong></p>
                    <ul class="list-disc pl-6 text-light-text-secondary">
                        <li><code>path</code> - URL path for the route</li>
                        <li><code>title</code> - Page title displayed in browser</li>
                        <li><code>defaultRoute</code> - Whether this is the default route (true/false)</li>
