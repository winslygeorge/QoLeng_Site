                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Main Component Structure</h4>
                    <p class="text-light-text-secondary mb-3">The main entry point for Lustache pages extends FuncComponent and uses a layout-based approach.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Component Part</th>
                                <th>Purpose</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>FuncComponent:extends()</td>
                                <td>Creates a new component that inherits from base FuncComponent</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>setView('layouts/default')</td>
                                <td>Sets the Mustache layout template to use</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>startInit() function</td>
                                <td>Initializes the component with children, props, and style</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>render_layout() function</td>
                                <td>Renders the final HTML output</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Lustache Main Page Template</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Type "!dawn_static_webpage" to generate this template</span>
<span class="code-keyword">local</span> FuncComponent = <span class="code-keyword">require</span>(<span class="code-string">'layout.renderer.FuncComponent'</span>)
<span class="code-keyword">local</span> navComponent = <span class="code-keyword">require</span>(<span class="code-string">'lib.components.navpage'</span>)
<span class="code-keyword">local</span> footer = <span class="code-keyword">require</span>(<span class="code-string">'lib.components.footerpage'</span>)
<span class="code-keyword">local</span> header = <span class="code-keyword">require</span>(<span class="code-string">'lib.components.headerpage'</span>)

<span class="code-keyword">local</span> MainComponent = FuncComponent:extends()

MainComponent:setView(<span class="code-string">'layouts/default'</span>)

<span class="code-keyword">function</span> MainComponent:startInit()
    <span class="code-keyword">self</span>:init(<span class="code-keyword">function</span> (children, props, style)
      props.layout_data = {
        title = <span class="code-string">"Home - Dawnserver"</span>,
        head_extra = <span class="code-string">'&lt;meta name="keywords" content="luajit, webserver, uwebsockets">'</span>,
        <span class="code-comment">-- body_extra = '&lt;script src="/static/js/home-page-specific.js" defer>&lt;/script>',</span>
        current_year = os.date(<span class="code-string">"%Y"</span>)
    }
    <span class="code-comment">-- Add children layouts to the main layout</span>
    children.header = header:build()
    children.nav = navComponent:build()
    children.body = children.body <span class="code-keyword">or</span> <span class="code-string">""</span>
    <span class="code-comment">-- children.footer = footer:build()</span>
    <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> MainComponent:render_layout()
    <span class="code-keyword">self</span>:startInit()
    <span class="code-keyword">local</span> output = <span class="code-keyword">self</span>:build()
    <span class="code-keyword">return</span> output
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> MainComponent</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Component Initialization Parameters</h4>
                    <p class="text-light-text-secondary mb-3">The init function receives three main parameters for component configuration.</p>
                    
