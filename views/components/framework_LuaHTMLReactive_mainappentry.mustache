                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">LuaReactive Pages</h3>
                    <p style="color: var(--doc-text-secondary);">Reactive components with client-side state management and routing</p>
                </div>
                
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--query-purple), var(--warning-amber));">
