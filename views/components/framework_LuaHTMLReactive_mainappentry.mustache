                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">LuaReactive SPA Route Registration</h4>
                    <p class="text-light-text-secondary mb-3">Register SPA routes in the system routes file for single-page applications.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>path</td>
                                <td>string</td>
                                <td>The URL pattern (supports wildcards)</td>
                            </tr>
                            <tr>
                                <td>handler</td>
                                <td>function</td>
                                <td>Function that serves the SPA shell</td>
                            </tr>
                            <tr>
                                <td>SINGLE_APP_MODE</td>
                                <td>boolean</td>
                                <td>Environment variable to enable SPA mode</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">SPA Route Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- routes/_system_routes.lua</span>
<span class="code-keyword">local</span> corsMiddleware = <span class="code-keyword">require</span>(<span class="code-string">'routes.middlewares.cors_middleware'</span>)
<span class="code-keyword">local</span> rate_limiting_middleware = <span class="code-keyword">require</span>(<span class="code-string">'routes.middlewares.rate_limiting_middleware'</span>)
<span class="code-keyword">local</span> json = <span class="code-keyword">require</span>(<span class="code-string">'dkjson'</span>)
<span class="code-keyword">local</span> parseFilters = <span class="code-keyword">require</span>(<span class="code-string">"utils.query_filter_parser"</span>)
<span class="code-keyword">local</span> PatchStreamer = <span class="code-keyword">require</span>(<span class="code-string">"utils.patchStreamer"</span>)
<span class="code-keyword">local</span> env = <span class="code-keyword">require</span>(<span class="code-string">'config.get_env'</span>)

<span class="code-keyword">local</span> M = {}
M.__index = M

<span class="code-keyword">function</span> M:new(server)
  <span class="code-keyword">local</span> <span class="code-keyword">self</span> = setmetatable({}, M)
  <span class="code-keyword">self</span>.server = server
  <span class="code-keyword">return</span> <span class="code-keyword">self</span>
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> M:routes()
    <span class="code-keyword">local</span> patch_streamer = PatchStreamer:new(<span class="code-keyword">self</span>.server)

    <span class="code-comment">-- Middleware setup</span>
    <span class="code-keyword">self</span>.server:use(rate_limiting_middleware())
    <span class="code-keyword">self</span>.server:use(corsMiddleware({
      allow_origin = <span class="code-string">"*"</span>,
      allow_methods = <span class="code-string">"GET, POST, PUT, DELETE, OPTIONS"</span>,
      allow_headers = <span class="code-string">"Content-Type, Authorization"</span>
    }))

    <span class="code-comment">-- SPA route handling</span>
    <span class="code-keyword">if</span> env <span class="code-keyword">and</span> env.SINGLE_APP_MODE == <span class="code-keyword">true</span> <span class="code-keyword">then</span>
        <span class="code-keyword">self</span>.server:get(<span class="code-string">"/"</span>, <span class="code-keyword">function</span>(req, res, query)    
          <span class="code-keyword">self</span>.server:redirect(res, <span class="code-string">"/app"</span>, 302)
        <span class="code-keyword">end</span>)

        <span class="code-keyword">self</span>.server:get(<span class="code-string">"/*"</span>, <span class="code-keyword">function</span>(req, res, query)
            <span class="code-keyword">local</span> category
            <span class="code-keyword">local</span> url = req._raw:getUrl() <span class="code-keyword">or</span> <span class="code-string">""</span>

            <span class="code-keyword">if</span> url:match(<span class="code-string">"^/app"</span>) <span class="code-keyword">or</span> url == <span class="code-string">"/"</span> <span class="code-keyword">or</span> url ==  <span class="code-string">""</span> <span class="code-keyword">then</span>
                category = <span class="code-string">"page"</span>
            <span class="code-keyword">else</span>
                category = <span class="code-string">"others"</span>
            <span class="code-keyword">end</span>
            
            <span class="code-keyword">if</span> category == <span class="code-string">"page"</span> <span class="code-keyword">then</span>
                <span class="code-comment">-- Extract path for client-side routing</span>
                <span class="code-keyword">local</span> path = req._raw:getUrl() == <span class="code-string">"/"</span> <span class="code-keyword">and</span> <span class="code-string">"/"</span> <span class="code-keyword">or</span> req._raw:getUrl()        
                <span class="code-comment">-- Serve SPA shell</span>
                <span class="code-keyword">local</span> modalPracPage = <span class="code-keyword">require</span>(<span class="code-string">"lib.WebApp"</span>)
                modalPracPage:setServer(<span class="code-keyword">self</span>.server)
                modalPracPage:setRouteToNavigateTo(path)
                <span class="code-keyword">local</span> htmlOutput = modalPracPage:render_layout()
                res:writeHeader(<span class="code-string">"Content-Type"</span>, <span class="code-string">"text/html; charset=utf-8"</span>)
                res:send(htmlOutput)
            <span class="code-keyword">else</span>
                <span class="code-comment">-- Let other handlers catch API/auth/sse/static routes</span>
                res:writeStatus(<span class="code-string">"404 Not Found"</span>)
                res:send(<span class="code-string">"Not found"</span>)
            <span class="code-keyword">end</span>
        <span class="code-keyword">end</span>)
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> M</code></pre>
                </div>
            </div>
