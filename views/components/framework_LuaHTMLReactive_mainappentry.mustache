                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- routes/app_routes.lua</span>
<span class="code-keyword">local</span> MainLayout = <span class="code-keyword">require</span>(<span class="code-string">"lib.Web"</span>)
<span class="code-keyword">local</span> json = <span class="code-keyword">require</span>(<span class="code-string">"dkjson"</span>)

<span class="code-keyword">local</span> M = {}
