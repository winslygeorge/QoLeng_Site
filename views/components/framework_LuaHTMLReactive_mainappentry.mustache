        <div class="rounded-xl p-6 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - LuaReactive Main App Template</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="keyword">local</span> FunctionalComponent = <span class="keyword">require</span>(<span class="string">"layout.renderer.FuncComponent"</span>)
<span class="keyword">local</span> HTML = <span class="keyword">require</span>(<span class="string">"layout.renderer.LuaHTMLReactive"</span>)

<span class="keyword">local</span> RouteManager = <span class="keyword">require</span>(<span class="string">"system.RouteManager"</span>)
<span class="keyword">local</span> ModalManager = <span class="keyword">require</span>(<span class="string">"system.ModalManager"</span>)

<span class="keyword">local</span> MainAppPage = FunctionalComponent:extends()
MainAppPage:setReactiveView()

<span class="comment">-- Register routes</span>
RouteManager.registerRoute(<span class="string">"home"</span>, HomePage, {
    path = <span class="string">"/app"</span>,
    title = <span class="string">"Home"</span>,
    defaultRoute = <span class="keyword">true</span>
})

<span class="keyword">function</span> MainAppPage:renderLayout(state, props, children, H)
    <span class="keyword">return</span> HTML.e(<span class="string">"div"</span>, { class = <span class="string">"app-container"</span> }, {
        HTML.Component(<span class="string">"routeManager"</span>, {}),
        HTML.Component(<span class="string">'modalManager'</span>, {})
    })
<span class="keyword">end</span>

<span class="keyword">return</span> MainAppPage</code></pre>
            </div>
        </div>
    </section>

    <!-- Route Registration Section -->
    <section id="route-registration" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">3</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">Route Registration</h2>
        </div>
        
        <div class="rounded-xl p-6 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Lustache Route Example</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="keyword">local</span> MainLayout = <span class="keyword">require</span>(<span class="string">"lib.Web"</span>)

<span class="keyword">function</span> M:routes()
    <span class="comment">-- Register Lustache pages</span>
    <span class="keyword">self</span>.server:get(<span class="string">"/web"</span>, <span class="keyword">function</span>(req, res, query)
        MainLayout:init(<span class="keyword">function</span>(children, props, style)
            <span class="keyword">local</span> body = <span class="keyword">require</span>(<span class="string">"lib.components.welcome"</span>)
            children.body = body:build()
        <span class="keyword">end</span>)
        <span class="keyword">local</span> layout = MainLayout:render_layout()
        res:writeHeader(<span class="string">"Content-Type"</span>, <span class="string">"text/html"</span>)
        res:send(layout)
    <span class="keyword">end</span>)

    <span class="comment">-- SPA route handling</span>
    <span class="keyword">if</span> env.SINGLE_APP_MODE == <span class="keyword">true</span> <span class="keyword">then</span>
        <span class="keyword">self</span>.server:get(<span class="string">"/*"</span>, <span class="keyword">function</span>(req, res, query)
            <span class="keyword">local</span> url = req._raw:getUrl()
            <span class="keyword">if</span> url:match(<span class="string">"^/app"</span>) <span class="keyword">then</span>
                <span class="keyword">local</span> modalPracPage = <span class="keyword">require</span>(<span class="string">"lib.WebApp"</span>)
                modalPracPage:setServer(<span class="keyword">self</span>.server)
                modalPracPage:setRouteToNavigateTo(url)
                <span class="keyword">local</span> htmlOutput = modalPracPage:render_layout()
                res:send(htmlOutput)
            <span class="keyword">end</span>
        <span class="keyword">end</span>)
    <span class="keyword">end</span>
<span class="keyword">end</span></code></pre>
            </div>
        </div>
    </section>

