        </div>
    </section>

    <!-- Lustache Pages Section -->
    <section id="lustache-pages" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">1</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">Lustache/Mustache Pages</h2>
        </div>
        
        <div class="rounded-xl p-6 mb-8 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <div class="function-signature">
                <h4 class="font-bold text-lg mb-2">Main Component Structure</h4>
                <p class="mb-3" style="color: var(--doc-text-secondary);">The main entry point for Lustache pages extends FuncComponent and uses a layout-based approach.</p>
                
                <table class="param-table">
                    <thead><tr><th>Component Part</th><th>Purpose</th><th>Required</th> </thead>
                    <tbody>
                        <tr><td>FuncComponent:extends()</td><td>Creates a new component</td><td>Yes</td> </tr>
                        <tr><td>setView('layouts/default')</td><td>Sets the Mustache layout template</td><td>Yes</td> </tr>
                        <tr><td>startInit() function</td><td>Initializes the component</td><td>Yes</td> </tr>
                        <tr><td>render_layout() function</td><td>Renders the final HTML output</td><td>Yes</td> </tr>
                    </tbody>
                 </table>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Lustache Main Page Template</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="keyword">local</span> FuncComponent = <span class="keyword">require</span>(<span class="string">'layout.renderer.FuncComponent'</span>)
<span class="keyword">local</span> navComponent = <span class="keyword">require</span>(<span class="string">'lib.components.navpage'</span>)
<span class="keyword">local</span> header = <span class="keyword">require</span>(<span class="string">'lib.components.headerpage'</span>)

<span class="keyword">local</span> MainComponent = FuncComponent:extends()
MainComponent:setView(<span class="string">'layouts/default'</span>)

<span class="keyword">function</span> MainComponent:startInit()
    <span class="keyword">self</span>:init(<span class="keyword">function</span> (children, props, style)
        props.layout_data = {
            title = <span class="string">"Home - Dawnserver"</span>,
            head_extra = <span class="string">'&lt;meta name="keywords" content="luajit, webserver">'</span>,
            current_year = os.date(<span class="string">"%Y"</span>)
        }
        children.header = header:build()
        children.nav = navComponent:build()
        children.body = children.body <span class="keyword">or</span> <span class="string">""</span>
    <span class="keyword">end</span>)
<span class="keyword">end</span>

<span class="keyword">function</span> MainComponent:render_layout()
    <span class="keyword">self</span>:startInit()
    <span class="keyword">return</span> <span class="keyword">self</span>:build()
<span class="keyword">end</span>

<span class="keyword">return</span> MainComponent</code></pre>
            </div>
        </div>
    </section>

    <!-- LuaReactive Pages Section -->
    <section id="luareactive-pages" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">2</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">LuaReactive Pages</h2>
