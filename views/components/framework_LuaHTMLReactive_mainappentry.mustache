                <pre><code><span class="keyword">function</span> MyComponent:renderLayout(state, props, children, H)
    <span class="keyword">local</span> count = state.count <span class="keyword">or</span> <span class="number">0</span>
    
    <span class="keyword">return</span> HTML.e(<span class="string">"div"</span>, { class = <span class="string">"p-4"</span> }, {
        HTML.e(<span class="string">"h2"</span>, {}, <span class="string">"Counter: "</span> .. count),
        HTML.e(<span class="string">"button"</span>, {
            class = <span class="string">"px-4 py-2 bg-blue-500 text-white rounded"</span>,
            onClick = <span class="keyword">function</span>()
                <span class="keyword">self</span>:setState({ count = count + <span class="number">1</span> })
            <span class="keyword">end</span>
        }, <span class="string">"Increment"</span>)
    })
<span class="keyword">end</span></code></pre>
