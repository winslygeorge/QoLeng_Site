                <h2 class="text-3xl font-bold text-neural-charcoal">Practical Examples</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Real-World Query Examples</h3>
                <p class="text-light-text-secondary mb-6">
                    Comprehensive examples showing how to build complex queries for common real-world scenarios.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">E-commerce Product Queries</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Get active products with categories</span>
<span class="code-keyword">local</span> products = Product:<span class="code-type">query</span>()
                        :<span class="code-type">select</span>(<span class="code-string">"products.*"</span>, <span class="code-string">"categories.name as category_name"</span>)
                        :<span class="code-type">join</span>(<span class="code-string">"INNER"</span>, <span class="code-string">"categories"</span>, <span class="code-string">"products.category_id = categories.id"</span>)
                        :<span class="code-type">where</span>(<span class="code-string">"products.is_active"</span>, <span class="code-string">"="</span>, true)
                        :<span class="code-type">where</span>(<span class="code-string">"products.stock_quantity"</span>, <span class="code-string">">"</span>, 0)
                        :<span class="code-type">where</span>(<span class="code-string">"products.price"</span>, <span class="code-string">"<="</span>, 100.00)
                        :<span class="code-type">order_by</span>(<span class="code-string">"products.created_at"</span>, <span class="code-string">"DESC"</span>)
                        :<span class="code-type">limit</span>(20)
                        :<span class="code-type">get</span>()

<span class="code-comment">-- Count products by category</span>
<span class="code-keyword">local</span> category_counts = Product:<span class="code-type">query</span>()
                               :<span class="code-type">select</span>(<span class="code-string">"category_id"</span>, <span class="code-string">"COUNT(*) as product_count"</span>)
                               :<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
                               :<span class="code-type">group_by</span>(<span class="code-string">"category_id"</span>)
                               :<span class="code-type">get</span>()

<span class="code-comment">-- Search products with multiple criteria</span>
<span class="code-keyword">local</span> search_results = Product:<span class="code-type">query</span>()
                             :<span class="code-type">where</span>(<span class="code-string">"name"</span>, <span class="code-string">"LIKE"</span>, <span class="code-string">"%laptop%"</span>)
                             :<span class="code-type">or_where</span>(<span class="code-string">"description"</span>, <span class="code-string">"LIKE"</span>, <span class="code-string">"%laptop%"</span>)
                             :<span class="code-type">and_where</span>(<span class="code-string">"price"</span>, <span class="code-string">"BETWEEN"</span>, {500, 2000})
                             :<span class="code-type">and_where</span>(<span class="code-string">"brand"</span>, <span class="code-string">"IN"</span>, {<span class="code-string">"Dell"</span>, <span class="code-string">"HP"</span>, <span class="code-string">"Lenovo"</span>})
                             :<span class="code-type">order_by</span>(<span class="code-string">"price"</span>, <span class="code-string">"ASC"</span>)
                             :<span class="code-type">get</span>()</code></pre>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">User Management Queries</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Get users with their roles and permissions</span>
<span class="code-keyword">local</span> users = User:<span class="code-type">query</span>()
                  :<span class="code-type">select</span>(<span class="code-string">"users.*"</span>, <span class="code-string">"roles.name as role_name"</span>, <span class="code-string">"permissions.action"</span>)
                  :<span class="code-type">join</span>(<span class="code-string">"LEFT"</span>, <span class="code-string">"user_roles"</span>, <span class="code-string">"users.id = user_roles.user_id"</span>)
                  :<span class="code-type">join</span>(<span class="code-string">"LEFT"</span>, <span class="code-string">"roles"</span>, <span class="code-string">"user_roles.role_id = roles.id"</span>)
                  :<span class="code-type">join</span>(<span class="code-string">"LEFT"</span>, <span class="code-string">"role_permissions"</span>, <span class="code-string">"roles.id = role_permissions.role_id"</span>)
                  :<span class="code-type">join</span>(<span class="code-string">"LEFT"</span>, <span class="code-string">"permissions"</span>, <span class="code-string">"role_permissions.permission_id = permissions.id"</span>)
                  :<span class="code-type">where</span>(<span class="code-string">"users.is_active"</span>, <span class="code-string">"="</span>, true)
                  :<span class="code-type">where</span>(<span class="code-string">"users.last_login"</span>, <span class="code-string">">"</span>, <span class="code-string">"2023-01-01"</span>)
                  :<span class="code-type">get</span>()

<span class="code-comment">-- Bulk update user status</span>
<span class="code-keyword">local</span> updated = User:<span class="code-type">query</span>()
                   :<span class="code-type">update</span>({ status = <span class="code-string">"inactive"</span> })
                   :<span class="code-type">where</span>(<span class="code-string">"last_login"</span>, <span class="code-string">"<"</span>, <span class="code-string">"2022-01-01"</span>)
                   :<span class="code-type">and_where</span>(<span class="code-string">"status"</span>, <span class="code-string">"="</span>, <span class="code-string">"active"</span>)
                   :<span class="code-type">execute</span>()

<span class="code-comment">-- Get user statistics</span>
<span class="code-keyword">local</span> stats = User:<span class="code-type">query</span>()
                 :<span class="code-type">select</span>(
                     <span class="code-string">"COUNT(*) as total_users"</span>,
                     <span class="code-string">"COUNT(CASE WHEN is_active THEN 1 END) as active_users"</span>,
                     <span class="code-string">"COUNT(CASE WHEN last_login > CURRENT_DATE - INTERVAL '30 days' THEN 1 END) as recent_users"</span>
                 )
                 :<span class="code-type">get</span>()</code></pre>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Advanced Reporting Queries</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Monthly sales report with multiple joins</span>
<span class="code-keyword">local</span> sales_report = Order:<span class="code-type">query</span>()
                         :<span class="code-type">select</span>(
                             <span class="code-string">"DATE_TRUNC('month', orders.created_at) as month"</span>,
                             <span class="code-string">"COUNT(*) as order_count"</span>,
                             <span class="code-string">"SUM(order_items.quantity * order_items.unit_price) as total_revenue"</span>,
                             <span class="code-string">"AVG(order_items.quantity * order_items.unit_price) as avg_order_value"</span>,
                             <span class="code-string">"customers.country"</span>
                         )
                         :<span class="code-type">join</span>(<span class="code-string">"INNER"</span>, <span class="code-string">"order_items"</span>, <span class="code-string">"orders.id = order_items.order_id"</span>)
                         :<span class="code-type">join</span>(<span class="code-string">"INNER"</span>, <span class="code-string">"customers"</span>, <span class="code-string">"orders.customer_id = customers.id"</span>)
                         :<span class="code-type">where</span>(<span class="code-string">"orders.status"</span>, <span class="code-string">"="</span>, <span class="code-string">"completed"</span>)
                         :<span class="code-type">where</span>(<span class="code-string">"orders.created_at"</span>, <span class="code-string">">="</span>, <span class="code-string">"2023-01-01"</span>)
                         :<span class="code-type">group_by</span>(<span class="code-string">"month"</span>, <span class="code-string">"customers.country"</span>)
                         :<span class="code-type">order_by</span>(<span class="code-string">"month"</span>, <span class="code-string">"DESC"</span>)
                         :<span class="code-type">order_by</span>(<span class="code-string">"total_revenue"</span>, <span class="code-string">"DESC"</span>)
                         :<span class="code-type">get</span>()

<span class="code-comment">-- Product inventory alert</span>
<span class="code-keyword">local</span> low_stock = Product:<span class="code-type">query</span>()
                       :<span class="code-type">select</span>(<span class="code-string">"name"</span>, <span class="code-string">"stock_quantity"</span>, <span class="code-string">"min_stock_level"</span>)
                       :<span class="code-type">where</span>(<span class="code-string">"stock_quantity"</span>, <span class="code-string">"<="</span>, <span class="code-string">"min_stock_level"</span>)
                       :<span class="code-type">and_where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
                       :<span class="code-type">order_by</span>(<span class="code-string">"stock_quantity"</span>, <span class="code-string">"ASC"</span>)
                       :<span class="code-type">get</span>()

<span class="code-comment">-- User activity timeline</span>
<span class="code-keyword">local</span> user_activity = User:<span class="code-type">query</span>()
                         :<span class="code-type">select</span>(<span class="code-string">"users.name"</span>, <span class="code-string">"logs.action"</span>, <span class="code-string">"logs.created_at"</span>)
                         :<span class="code-type">join</span>(<span class="code-string">"INNER"</span>, <span class="code-string">"activity_logs logs"</span>, <span class="code-string">"users.id = logs.user_id"</span>)
                         :<span class="code-type">where</span>(<span class="code-string">"logs.created_at"</span>, <span class="code-string">">="</span>, <span class="code-string">"CURRENT_DATE - INTERVAL '7 days'"</span>)
                         :<span class="code-type">where</span>(<span class="code-string">"logs.action"</span>, <span class="code-string">"IN"</span>, {<span class="code-string">"login"</span>, <span class="code-string">"purchase"</span>, <span class="code-string">"profile_update"</span>})
                         :<span class="code-type">order_by</span>(<span class="code-string">"logs.created_at"</span>, <span class="code-string">"DESC"</span>)
                         :<span class="code-type">limit</span>(100)
                         :<span class="code-type">get</span>()</code></pre>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Custom Complex Queries</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Advanced search with multiple optional filters</span>
<span class="code-keyword">local</span> <span class="code-keyword">function</span> search_users(filters)
    <span class="code-keyword">local</span> query = User:<span class="code-type">query</span>()
    
    <span class="code-comment">-- Add optional filters</span>
    <span class="code-keyword">if</span> filters.name <span class="code-keyword">then</span>
        query:<span class="code-type">where</span>(<span class="code-string">"name"</span>, <span class="code-string">"LIKE"</span>, <span class="code-string">"%"</span> .. filters.name .. <span class="code-string">"%"</span>)
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">if</span> filters.email <span class="code-keyword">then</span>
        query:<span class="code-type">where</span>(<span class="code-string">"email"</span>, <span class="code-string">"LIKE"</span>, <span class="code-string">"%"</span> .. filters.email .. <span class="code-string">"%"</span>)
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">if</span> filters.min_age <span class="code-keyword">then</span>
        query:<span class="code-type">where</span>(<span class="code-string">"age"</span>, <span class="code-string">">="</span>, filters.min_age)
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">if</span> filters.max_age <span class="code-keyword">then</span>
        query:<span class="code-type">where</span>(<span class="code-string">"age"</span>, <span class="code-string">"<="</span>, filters.max_age)
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">if</span> filters.countries <span class="code-keyword">then</span>
        query:<span class="code-type">where</span>(<span class="code-string">"country"</span>, <span class="code-string">"IN"</span>, filters.countries)
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">if</span> filters.is_active ~= <span class="code-keyword">nil</span> <span class="code-keyword">then</span>
        query:<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, filters.is_active)
    <span class="code-keyword">end</span>
    
    <span class="code-comment">-- Add sorting</span>
    <span class="code-keyword">local</span> sort_field = filters.sort_by <span class="code-keyword">or</span> <span class="code-string">"created_at"</span>
    <span class="code-keyword">local</span> sort_direction = filters.sort_order <span class="code-keyword">or</span> <span class="code-string">"DESC"</span>
    query:<span class="code-type">order_by</span>(sort_field, sort_direction)
    
    <span class="code-comment">-- Add pagination</span>
    <span class="code-keyword">local</span> page = filters.page <span class="code-keyword">or</span> 1
    <span class="code-keyword">local</span> per_page = filters.per_page <span class="code-keyword">or</span> 25
    query:<span class="code-type">limit</span>(per_page):<span class="code-type">offset</span>((page - 1) * per_page)
    
    <span class="code-keyword">return</span> query:<span class="code-type">get</span>()
<span class="code-keyword">end</span>

<span class="code-comment">-- Usage:</span>
<span class="code-keyword">local</span> filters = {
    name = <span class="code-string">"John"</span>,
    min_age = 25,
    max_age = 40,
    countries = {<span class="code-string">"US"</span>, <span class="code-string">"CA"</span>, <span class="code-string">"UK"</span>},
    is_active = true,
    sort_by = <span class="code-string">"last_login"</span>,
    page = 2,
    per_page = 50
}

<span class="code-keyword">local</span> users = search_users(filters)</code></pre>
