                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Complex query with multiple clauses</span>
<span class="code-keyword">local</span> users = qb:<span class="code-type">select</span>(<span class="code-string">"*"</span>)
                  :<span class="code-type">where</span>(<span class="code-string">"status"</span>, <span class="code-string">"="</span>, <span class="code-string">"active"</span>)
