        <!-- Execution Section -->
        <section id="execution" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-query-purple flex items-center justify-center text-white font-bold mr-4">3</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Query Execution</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Execution Methods</h3>
                <p class="text-light-text-secondary mb-6">
                    Execute built queries with support for both synchronous and asynchronous operations,
                    automatic result mapping, and proper connection management.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">get(callback)</h4>
                    <p class="text-light-text-secondary mb-3">Executes the built SELECT query and returns a list of model instances.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>callback</td>
                                <td>function</td>
                                <td>Optional callback for async mode: function(results, error)</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> table|nil - A list of model instances (sync only)</p>
                    <p class="mt-2"><strong>Raises:</strong> Error if the query operation fails in sync mode</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">GET Execution Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Synchronous execution</span>
<span class="code-keyword">local</span> users = User:<span class="code-type">query</span>()
                  :<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
                  :<span class="code-type">get</span>()

<span class="code-comment">-- Asynchronous execution with callback</span>
User:<span class="code-type">query</span>(<span class="code-string">"async"</span>)
    :<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
    :<span class="code-type">get</span>(<span class="code-keyword">function</span>(users, err)
        <span class="code-keyword">if</span> err <span class="code-keyword">then</span>
            print(<span class="code-string">"Error:"</span>, err)
        <span class="code-keyword">else</span>
            <span class="code-keyword">for</span> i, user <span class="code-keyword">in</span> <span class="code-keyword">ipairs</span>(users) <span class="code-keyword">do</span>
                print(user.name)
            <span class="code-keyword">end</span>
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>)

<span class="code-comment">-- Count execution</span>
<span class="code-keyword">local</span> result = User:<span class="code-type">query</span>()
                   :<span class="code-type">count</span>()
                   :<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
                   :<span class="code-type">get</span>()
<span class="code-keyword">local</span> user_count = result[1].count</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">execute(callback)</h4>
                    <p class="text-light-text-secondary mb-3">Executes the built DML (INSERT, UPDATE, DELETE) query.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>callback</td>
                                <td>function</td>
                                <td>Optional callback for async mode: function(success, error)</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> boolean|nil - True if successful (sync only), or nil for async</p>
                    <p class="mt-2"><strong>Raises:</strong> Error if the query operation fails in sync mode</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">EXECUTE Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Synchronous INSERT</span>
<span class="code-keyword">local</span> success = User:<span class="code-type">query</span>()
                    :<span class="code-type">insert</span>({
                        name = <span class="code-string">"John Doe"</span>,
                        email = <span class="code-string">"john@example.com"</span>
                    })
                    :<span class="code-type">execute</span>()

<span class="code-comment">-- Asynchronous UPDATE</span>
User:<span class="code-type">query</span>(<span class="code-string">"async"</span>)
    :<span class="code-type">update</span>({ status = <span class="code-string">"inactive"</span> })
    :<span class="code-type">where</span>(<span class="code-string">"last_login"</span>, <span class="code-string">"<"</span>, <span class="code-string">"2020-01-01"</span>)
    :<span class="code-type">execute</span>(<span class="code-keyword">function</span>(success, err)
        <span class="code-keyword">if</span> err <span class="code-keyword">then</span>
            print(<span class="code-string">"Update failed:"</span>, err)
        <span class="code-keyword">else</span>
            print(<span class="code-string">"Update successful"</span>)
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>)

<span class="code-comment">-- Synchronous DELETE</span>
<span class="code-keyword">local</span> deleted = User:<span class="code-type">query</span>()
                   :<span class="code-type">delete</span>()
                   :<span class="code-type">where</span>(<span class="code-string">"id"</span>, <span class="code-string">"="</span>, 123)
                   :<span class="code-type">execute</span>()</code></pre>
                </div>
            </div>
            
            <!-- Utility Methods -->
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Utility Methods</h3>
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="function-signature">
