                <h1 class="text-4xl font-bold mb-6 text-neural-charcoal">Query Builder</h1>
                <p class="text-xl text-light-text-secondary mb-8">
                    Comprehensive guide to using the QueryBuilder module for constructing and executing
                    SQL queries programmatically with a fluent, chainable API in Dawn Framework applications.
                </p>
                
                <div class="grid md:grid-cols-3 gap-6 mb-8">
                    <div class="feature-card bg-blue-50 p-6 rounded-lg border border-blue-100">
                        <div class="w-12 h-12 rounded-full bg-laser-blue flex items-center justify-center text-white mb-4">
                            <i class="fas fa-code"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2 text-laser-blue">Fluent API</h3>
                        <p class="text-light-text-secondary">Chainable methods for building complex queries programmatically</p>
                    </div>
                    
                    <div class="feature-card bg-green-50 p-6 rounded-lg border border-green-100">
                        <div class="w-12 h-12 rounded-full bg-build-green flex items-center justify-center text-white mb-4">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2 text-build-green">SQL Injection Protection</h3>
                        <p class="text-light-text-secondary">Automatic parameter binding and safe query execution</p>
                    </div>
                    
                    <div class="feature-card bg-purple-50 p-6 rounded-lg border border-purple-100">
                        <div class="w-12 h-12 rounded-full bg-query-purple flex items-center justify-center text-white mb-4">
                            <i class="fas fa-sync-alt"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2 text-query-purple">Sync & Async Support</h3>
                        <p class="text-light-text-secondary">Support for both synchronous and asynchronous execution</p>
                    </div>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold">Basic Setup</h3>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Load required modules</span>
<span class="code-keyword">local</span> QueryBuilder = <span class="code-keyword">require</span>(<span class="code-string">"orm.query_builder"</span>)
<span class="code-keyword">local</span> User = <span class="code-keyword">require</span>(<span class="code-string">"models.user"</span>) <span class="code-comment">-- Your ORM model</span>

<span class="code-comment">-- Create a QueryBuilder instance</span>
<span class="code-keyword">local</span> qb = QueryBuilder.<span class="code-type">new</span>(<span class="code-string">"users"</span>, <span class="code-string">"sync"</span>, User)

<span class="code-comment">-- Build and execute a query</span>
<span class="code-keyword">local</span> users = qb:<span class="code-type">select</span>(<span class="code-string">"*"</span>)
                  :<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
                  :<span class="code-type">order_by</span>(<span class="code-string">"created_at"</span>, <span class="code-string">"DESC"</span>)
                  :<span class="code-type">limit</span>(10)
                  :<span class="code-type">get</span>()

<span class="code-comment">-- Or use the model's query method</span>
<span class="code-keyword">local</span> users = User:<span class="code-type">query</span>()
                  :<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
                  :<span class="code-type">get</span>()</code></pre>
                </div>
            </div>
        </section>

        <!-- Query Types Section -->
        <section id="query-types" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Query Types & Initialization</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">QueryBuilder Initialization</h3>
                <p class="text-light-text-secondary mb-6">
                    The QueryBuilder can be created directly or through model instances, supporting
                    various query types including SELECT, INSERT, UPDATE, and DELETE operations.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">new(table_name, connection_mode, model_class)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a new QueryBuilder instance for a given table.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>table_name</td>
                                <td>string</td>
                                <td>The name of the database table this query builder operates on</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>connection_mode</td>
                                <td>string</td>
                                <td>The connection mode ("sync" or "async") for this query</td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>model_class</td>
                                <td>table</td>
                                <td>The ORM model class associated with this query builder</td>
                                <td>No</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> table - A new QueryBuilder instance</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Initialization Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Direct QueryBuilder creation</span>
<span class="code-keyword">local</span> QueryBuilder = <span class="code-keyword">require</span>(<span class="code-string">"orm.query_builder"</span>)
<span class="code-keyword">local</span> qb = QueryBuilder.<span class="code-type">new</span>(<span class="code-string">"users"</span>, <span class="code-string">"sync"</span>, User)

<span class="code-comment">-- Through model instance (recommended)</span>
<span class="code-keyword">local</span> qb = User:<span class="code-type">query</span>() <span class="code-comment">-- Automatically sets table_name and model_class</span>

<span class="code-comment">-- Async query builder</span>
<span class="code-keyword">local</span> async_qb = User:<span class="code-type">query</span>(<span class="code-string">"async"</span>)

<span class="code-comment">-- Custom table without model</span>
<span class="code-keyword">local</span> custom_qb = QueryBuilder.<span class="code-type">new</span>(<span class="code-string">"custom_table"</span>)</code></pre>
                </div>
                
                <div class="grid md:grid-cols-2 gap-6 mt-8">
                    <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
                        <h4 class="font-bold text-blue-800 mb-2">Query Builder State Properties</h4>
                        <ul class="text-sm text-blue-700 space-y-1">
                            <li><code>_select_columns</code> - Columns to SELECT</li>
                            <li><code>_where_clauses</code> - WHERE conditions</li>
                            <li><code>_limit</code> - LIMIT clause</li>
                            <li><code>_offset</code> - OFFSET clause</li>
                            <li><code>_order_by</code> - ORDER BY clauses</li>
                            <li><code>_group_by</code> - GROUP BY clauses</li>
                            <li><code>_joins</code> - JOIN clauses</li>
                            <li><code>_parameters</code> - Query parameters</li>
                        </ul>
                    </div>
                    <div class="bg-green-50 p-4 rounded-lg border border-green-200">
                        <h4 class="font-bold text-green-800 mb-2">Query Type Flags</h4>
                        <ul class="text-sm text-green-700 space-y-1">
                            <li><code>_is_insert</code> - INSERT operation</li>
                            <li><code>_is_update</code> - UPDATE operation</li>
                            <li><code>_is_delete</code> - DELETE operation</li>
                            <li><code>_insert_data</code> - INSERT data</li>
                            <li><code>_update_data</code> - UPDATE data</li>
                            <li><code>_on_conflict_clause</code> - ON CONFLICT handling</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- SELECT Queries -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">
                    <span class="query-type type-select">SELECT</span>
                    SELECT Queries
                </h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">select(...)</h4>
                    <p class="text-light-text-secondary mb-3">Sets the columns to select. Supports aliasing with "as".</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>...</td>
                                <td>string|table</td>
                                <td>Column names as strings, or a table of column names</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> QueryBuilder instance for chaining</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">SELECT Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Select all columns (default)</span>
qb:<span class="code-type">select</span>(<span class="code-string">"*"</span>)

<span class="code-comment">-- Select specific columns</span>
qb:<span class="code-type">select</span>(<span class="code-string">"id"</span>, <span class="code-string">"name"</span>, <span class="code-string">"email"</span>)

<span class="code-comment">-- Select with aliases</span>
qb:<span class="code-type">select</span>(<span class="code-string">"users.name as user_name"</span>, <span class="code-string">"posts.title as post_title"</span>)

<span class="code-comment">-- Select with table of columns</span>
qb:<span class="code-type">select</span>({<span class="code-string">"id"</span>, <span class="code-string">"name"</span>, <span class="code-string">"email"</span>})

<span class="code-comment">-- Count records</span>
qb:<span class="code-type">count</span>() <span class="code-comment">-- Sets select to "COUNT(*) as count"</span></code></pre>
                </div>
            </div>
            
            <!-- INSERT Queries -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">
                    <span class="query-type type-insert">INSERT</span>
                    INSERT Queries
                </h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">insert(data)</h4>
                    <p class="text-light-text-secondary mb-3">Configures the query for an INSERT operation.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>data</td>
                                <td>table</td>
                                <td>A table where keys are column names and values are the data to insert</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> QueryBuilder instance for chaining</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">INSERT Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Basic INSERT</span>
qb:<span class="code-type">insert</span>({
    name = <span class="code-string">"John Doe"</span>,
    email = <span class="code-string">"john@example.com"</span>,
    age = 30
}):<span class="code-type">execute</span>()

<span class="code-comment">-- INSERT with ON CONFLICT (UPSERT)</span>
qb:<span class="code-type">insert</span>({
    email = <span class="code-string">"john@example.com"</span>,
    name = <span class="code-string">"John Updated"</span>
}):<span class="code-type">on_conflict</span>(<span class="code-string">"email"</span>, <span class="code-string">"DO UPDATE SET name = EXCLUDED.name"</span>)
 :<span class="code-type">execute</span>()

<span class="code-comment">-- Generated SQL:</span>
<span class="code-comment">-- INSERT INTO users (name, email, age) VALUES (?, ?, ?)</span>
<span class="code-comment">-- INSERT INTO users (email, name) VALUES (?, ?) ON CONFLICT (email) DO UPDATE SET name = EXCLUDED.name</span></code></pre>
                </div>
            </div>
            
            <!-- UPDATE Queries -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">
                    <span class="query-type type-update">UPDATE</span>
                    UPDATE Queries
                </h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">update(data)</h4>
                    <p class="text-light-text-secondary mb-3">Configures the query for an UPDATE operation.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>data</td>
                                <td>table</td>
                                <td>A table where keys are column names and values are the data to update</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> QueryBuilder instance for chaining</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">UPDATE Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Basic UPDATE</span>
qb:<span class="code-type">update</span>({
    name = <span class="code-string">"Jane Doe"</span>,
    email = <span class="code-string">"jane@example.com"</span>
}):<span class="code-type">where</span>(<span class="code-string">"id"</span>, <span class="code-string">"="</span>, 123)
 :<span class="code-type">execute</span>()

<span class="code-comment">-- UPDATE with multiple conditions</span>
qb:<span class="code-type">update</span>({
    status = <span class="code-string">"inactive"</span>,
    updated_at = <span class="code-string">"CURRENT_TIMESTAMP"</span>
}):<span class="code-type">where</span>(<span class="code-string">"last_login"</span>, <span class="code-string">"<"</span>, <span class="code-string">"2023-01-01"</span>)
 :<span class="code-type">and_where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
 :<span class="code-type">execute</span>()

<span class="code-comment">-- Generated SQL:</span>
<span class="code-comment">-- UPDATE users SET name = ?, email = ? WHERE id = ?</span>
<span class="code-comment">-- UPDATE users SET status = ?, updated_at = CURRENT_TIMESTAMP WHERE last_login < ? AND is_active = ?</span></code></pre>
                </div>
            </div>
            
            <!-- DELETE Queries -->
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">
                    <span class="query-type type-delete">DELETE</span>
                    DELETE Queries
                </h3>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">delete()</h4>
                    <p class="text-light-text-secondary mb-3">Configures the query for a DELETE operation.</p>
                    
