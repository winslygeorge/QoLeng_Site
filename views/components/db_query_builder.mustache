                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mt-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Utility Method Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Clone a query builder</span>
<span class="code-keyword">local</span> base_query = User:<span class="code-type">query</span>():<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
<span class="code-keyword">local</span> count_query = base_query:<span class="code-type">clone</span>():<span class="code-type">count</span>():<span class="code-type">get</span>()
<span class="code-keyword">local</span> users = base_query:<span class="code-type">clone</span>():<span class="code-type">limit</span>(10):<span class="code-type">get</span>()

<span class="code-comment">-- Get SQL for debugging</span>
<span class="code-keyword">local</span> sql, params = User:<span class="code-type">query</span>()
                         :<span class="code-type">where</span>(<span class="code-string">"name"</span>, <span class="code-string">"LIKE"</span>, <span class="code-string">"J%"</span>)
                         :<span class="code-type">to_sql</span>()
print(<span class="code-string">"SQL:"</span>, sql)
print(<span class="code-string">"Parameters:"</span>, table.concat(params, <span class="code-string">", "</span>))

<span class="code-comment">-- Force async execution</span>
User:<span class="code-type">query</span>()
    :<span class="code-type">use_async</span>(true)
    :<span class="code-type">where</span>(<span class="code-string">"status"</span>, <span class="code-string">"="</span>, <span class="code-string">"active"</span>)
    :<span class="code-type">get</span>(<span class="code-keyword">function</span>(users, err) ... <span class="code-keyword">end</span>)

<span class="code-comment">-- Include soft deleted records</span>
<span class="code-keyword">local</span> all_users = User:<span class="code-type">query</span>()
                     :<span class="code-type">with_soft_deleted</span>()
                     :<span class="code-type">get</span>()</code></pre>
                </div>
            </div>
        </section>

