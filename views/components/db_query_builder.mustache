        <!-- Clause Methods Section -->
        <section id="clause-methods" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-build-green flex items-center justify-center text-white font-bold mr-4">2</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Clause Methods</h2>
            </div>
            
            <!-- WHERE Clauses -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">WHERE Clauses</h3>
                <p class="text-light-text-secondary mb-6">
                    Build complex WHERE conditions with support for various operators, logical conjunctions,
                    and parameter binding for SQL injection protection.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">where(column, operator, value, conjunction)</h4>
                    <p class="text-light-text-secondary mb-3">Adds a WHERE clause to the query with parameter binding.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Default</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>column</td>
                                <td>string</td>
                                <td>The name of the column</td>
                                <td>Required</td>
                            </tr>
                            <tr>
                                <td>operator</td>
                                <td>string</td>
                                <td>Comparison operator (=, >, <, LIKE, IN, IS, etc.)</td>
                                <td>Required</td>
                            </tr>
                            <tr>
                                <td>value</td>
                                <td>mixed</td>
                                <td>The value to compare against</td>
                                <td>Required</td>
                            </tr>
                            <tr>
                                <td>conjunction</td>
                                <td>string</td>
                                <td>Logical conjunction (AND or OR)</td>
                                <td>"AND"</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Supported Operators:</strong> =, !=, <>, >, <, >=, <=, LIKE, ILIKE, IN, NOT IN, IS, IS NOT</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">WHERE Clause Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Basic equality</span>
qb:<span class="code-type">where</span>(<span class="code-string">"name"</span>, <span class="code-string">"="</span>, <span class="code-string">"John"</span>)

<span class="code-comment">-- Greater than</span>
qb:<span class="code-type">where</span>(<span class="code-string">"age"</span>, <span class="code-string">">"</span>, 18)

<span class="code-comment">-- LIKE operator</span>
qb:<span class="code-type">where</span>(<span class="code-string">"name"</span>, <span class="code-string">"LIKE"</span>, <span class="code-string">"J%"</span>)

<span class="code-comment">-- IN operator with table</span>
qb:<span class="code-type">where</span>(<span class="code-string">"status"</span>, <span class="code-string">"IN"</span>, {<span class="code-string">"active"</span>, <span class="code-string">"pending"</span>})

<span class="code-comment">-- IS NULL</span>
qb:<span class="code-type">where</span>(<span class="code-string">"deleted_at"</span>, <span class="code-string">"IS"</span>, <span class="code-string">"NULL"</span>)

<span class="code-comment">-- Complex conditions with AND/OR</span>
qb:<span class="code-type">where</span>(<span class="code-string">"status"</span>, <span class="code-string">"="</span>, <span class="code-string">"active"</span>)
   :<span class="code-type">or_where</span>(<span class="code-string">"age"</span>, <span class="code-string">">="</span>, 65)
   :<span class="code-type">and_where</span>(<span class="code-string">"country"</span>, <span class="code-string">"="</span>, <span class="code-string">"US"</span>)

<span class="code-comment">-- Raw WHERE clause (use with caution)</span>
qb:<span class="code-type">where_raw</span>(<span class="code-string">"price > ? AND discount < ?"</span>, {100, 50})</code></pre>
                </div>
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="function-signature">
                        <h4 class="font-bold text-lg mb-2">and_where(column, operator, value)</h4>
