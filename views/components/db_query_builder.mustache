                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Basic DELETE</span>
qb:<span class="code-type">delete</span>()
   :<span class="code-type">where</span>(<span class="code-string">"id"</span>, <span class="code-string">"="</span>, 123)
   :<span class="code-type">execute</span>()

<span class="code-comment">-- DELETE with multiple conditions</span>
qb:<span class="code-type">delete</span>()
   :<span class="code-type">where</span>(<span class="code-string">"status"</span>, <span class="code-string">"="</span>, <span class="code-string">"deleted"</span>)
   :<span class="code-type">and_where</span>(<span class="code-string">"deleted_at"</span>, <span class="code-string">"<"</span>, <span class="code-string">"2020-01-01"</span>)
   :<span class="code-type">execute</span>()

<span class="code-comment">-- Soft delete (using with_soft_deleted)</span>
qb:<span class="code-type">with_soft_deleted</span>()
   :<span class="code-type">delete</span>()
   :<span class="code-type">where</span>(<span class="code-string">"id"</span>, <span class="code-string">"="</span>, 123)
   :<span class="code-type">execute</span>()

<span class="code-comment">-- Generated SQL:</span>
<span class="code-comment">-- DELETE FROM users WHERE id = ?</span>
<span class="code-comment">-- DELETE FROM users WHERE status = ? AND deleted_at < ?</span></code></pre>
