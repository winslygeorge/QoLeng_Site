                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">JOIN Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- INNER JOIN</span>
qb:<span class="code-type">select</span>(<span class="code-string">"users.name"</span>, <span class="code-string">"posts.title"</span>)
   :<span class="code-type">join</span>(<span class="code-string">"INNER"</span>, <span class="code-string">"posts"</span>, <span class="code-string">"users.id = posts.user_id"</span>)

<span class="code-comment">-- LEFT JOIN with aliases</span>
qb:<span class="code-type">select</span>(<span class="code-string">"u.name as user_name"</span>, <span class="code-string">"p.title as post_title"</span>)
   :<span class="code-type">join</span>(<span class="code-string">"LEFT"</span>, <span class="code-string">"posts p"</span>, <span class="code-string">"u.id = p.user_id"</span>)

<span class="code-comment">-- Multiple JOINs</span>
qb:<span class="code-type">select</span>(<span class="code-string">"*"</span>)
   :<span class="code-type">join</span>(<span class="code-string">"INNER"</span>, <span class="code-string">"posts"</span>, <span class="code-string">"users.id = posts.user_id"</span>)
   :<span class="code-type">join</span>(<span class="code-string">"LEFT"</span>, <span class="code-string">"comments"</span>, <span class="code-string">"posts.id = comments.post_id"</span>)

<span class="code-comment">-- Generated SQL:</span>
<span class="code-comment">-- SELECT users.name, posts.title FROM users INNER JOIN posts ON users.id = posts.user_id</span>
<span class="code-comment">-- SELECT u.name as user_name, p.title as post_title FROM users u LEFT JOIN posts p ON u.id = p.user_id</span></code></pre>
                </div>
            </div>
            
            <!-- Other Clauses -->
