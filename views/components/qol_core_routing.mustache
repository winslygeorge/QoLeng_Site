                </div>
                <pre><code><span class="comment">-- Handle multipart/form-data uploads</span>
self.<span class="variable">server</span>:<span class="function">post</span>(<span class="string">"/upload"</span>, <span class="keyword">function</span>(req, res, form_data)
    <span class="keyword">if</span> <span class="keyword">type</span>(form_data) ~= <span class="string">"table"</span> <span class="keyword">then</span>
        <span class="keyword">return</span> res:<span class="function">writeStatus</span>(<span class="number">400</span>):<span class="function">send</span>(<span class="string">"No form data received"</span>)
    <span class="keyword">end</span>
    
    <span class="keyword">for</span> name, field <span class="keyword">in</span> <span class="keyword">pairs</span>(form_data <span class="keyword">or</span> {}) <span class="keyword">do</span>
        <span class="keyword">if</span> <span class="keyword">type</span>(field) == <span class="string">"table"</span> <span class="keyword">and</span> field.path <span class="keyword">then</span>
            <span class="comment">-- This is a file upload</span>
            print(<span class="string">"Uploaded file:"</span>, field.filename, <span class="string">"stored at:"</span>, field.path)
            print(<span class="string">"File size:"</span>, field.size, <span class="string">"MIME type:"</span>, field.mimetype)
        <span class="keyword">else</span>
            <span class="comment">-- This is a form field</span>
            print(<span class="string">"Form field:"</span>, name, <span class="string">"="</span>, field)
        <span class="keyword">end</span>
    <span class="keyword">end</span>
    
    res:<span class="function">writeHeader</span>(<span class="string">"Content-Type"</span>, <span class="string">"application/json"</span>)
