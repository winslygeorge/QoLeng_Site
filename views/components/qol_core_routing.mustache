                <pre><code><span class="comment">-- POST with JSON body</span>
self.<span class="variable">server</span>:<span class="function">post</span>(<span class="string">"students/add"</span>, <span class="keyword">function</span>(req, res, body)
    body = body <span class="keyword">or</span> {}
    
    <span class="keyword">if</span> <span class="keyword">type</span>(body) == <span class="string">"table"</span> <span class="keyword">then</span>
        <span class="keyword">local</span> name = body.name
        <span class="keyword">local</span> age = body.age
        <span class="keyword">local</span> mean_score = body.mean_score
        
        <span class="keyword">if</span> <span class="keyword">not</span> name <span class="keyword">or</span> <span class="keyword">not</span> age <span class="keyword">or</span> <span class="keyword">not</span> mean_score <span class="keyword">then</span>
            <span class="keyword">return</span> res:<span class="function">writeStatus</span>(<span class="number">400</span>):<span class="function">send</span>(<span class="string">"Missing student data"</span>)
        <span class="keyword">end</span>
        
        <span class="keyword">local</span> new_student = {
            id = #students + <span class="number">1</span>,
            name = name,
            age = age,
            mean_score = mean_score
        }
        
        res:<span class="function">writeHeader</span>(<span class="string">"Content-Type"</span>, <span class="string">"application/json"</span>)
            :<span class="function">writeStatus</span>(<span class="number">201</span>)
            :<span class="function">send</span>(json.encode(new_student))
    <span class="keyword">else</span>
        <span class="keyword">return</span> res:<span class="function">writeStatus</span>(<span class="number">400</span>):<span class="function">send</span>(<span class="string">"Invalid request body"</span>)
    <span class="keyword">end</span>
<span class="keyword">end</span>)</code></pre>
