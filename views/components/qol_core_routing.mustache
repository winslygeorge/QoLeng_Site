        <!-- Route Basics Section -->
        <section id="route-basics" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Route Basics</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Route Handler Structure</h3>
                <p class="text-light-text-secondary mb-6">
                    Every route handler in Dawn Framework receives three parameters: <code class="bg-gray-100 px-1 rounded">req</code> (request), 
                    <code class="bg-gray-100 px-1 rounded">res</code> (response), and optionally <code class="bg-gray-100 px-1 rounded">body</code> or <code class="bg-gray-100 px-1 rounded">query</code> depending on the HTTP method.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Basic Route Handler</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- GET request handler</span>
self.<span class="code-variable">server</span>:<span class="code-type">get</span>(<span class="code-string">"/example"</span>, <span class="code-keyword">function</span>(req, res, query)
 <span class="code-comment">-- req: Request object with URL, headers, params</span>
 <span class="code-comment">-- res: Response object for sending data back</span>
 <span class="code-comment">-- query: Query parameters from URL (?key=value)</span>
 
 res:<span class="code-type">writeStatus</span>(200)
    :<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"text/plain"</span>)
    :<span class="code-type">send</span>(<span class="code-string">"Hello from Dawn Framework!"</span>)
<span class="code-keyword">end</span>)

<span class="code-comment">-- POST request handler</span>
self.<span class="code-variable">server</span>:<span class="code-type">post</span>(<span class="code-string">"/example"</span>, <span class="code-keyword">function</span>(req, res, body)
 <span class="code-comment">-- body: Parsed request body (JSON, form data, etc.)</span>
 
 <span class="code-keyword">local</span> response = { message = <span class="code-string">"Data received"</span>, received = body }
 res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
    :<span class="code-type">writeStatus</span>(200)
    :<span class="code-type">send</span>(json.encode(response))
<span class="code-keyword">end</span>)</code></pre>
                </div>
                
                <h4 class="text-xl font-bold mb-4 text-build-green">Route Parameters</h4>
                <div class="grid md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <h5 class="font-bold mb-2 text-neural-charcoal">Static Routes</h5>
                        <p class="text-light-text-secondary text-sm mb-4">Exact path matching</p>
                        <div class="bg-gray-100 p-3 rounded">
                            <code class="text-sm">/api/users</code><br>
                            <code class="text-sm">/dashboard/settings</code>
                        </div>
                    </div>
                    <div>
                        <h5 class="font-bold mb-2 text-neural-charcoal">Parameterized Routes</h5>
                        <p class="text-light-text-secondary text-sm mb-4">Dynamic path segments</p>
                        <div class="bg-gray-100 p-3 rounded">
                            <code class="text-sm">/users/:id</code><br>
                            <code class="text-sm">/posts/:category/:slug</code>
                        </div>
                    </div>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Parameterized Route Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Access URL parameters via req.params</span>
self.<span class="code-variable">server</span>:<span class="code-type">get</span>(<span class="code-string">"/users/:id"</span>, <span class="code-keyword">function</span>(req, res)
 <span class="code-keyword">local</span> userId = req.params.id
 <span class="code-comment">-- userId contains the value from the URL</span>
 
 <span class="code-keyword">local</span> user = findUserById(userId)
 <span class="code-keyword">if</span> user <span class="code-keyword">then</span>
  res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
     :<span class="code-type">writeStatus</span>(200)
     :<span class="code-type">send</span>(json.encode(user))
 <span class="code-keyword">else</span>
  res:<span class="code-type">writeStatus</span>(404):<span class="code-type">send</span>(<span class="code-string">"User not found"</span>)
 <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)

<span class="code-comment">-- Multiple parameters</span>
self.<span class="code-variable">server</span>:<span class="code-type">get</span>(<span class="code-string">"/posts/:category/:slug"</span>, <span class="code-keyword">function</span>(req, res)
 <span class="code-keyword">local</span> category = req.params.category
 <span class="code-keyword">local</span> slug = req.params.slug
 
 <span class="code-comment">-- Use both parameters to find the post</span>
<span class="code-keyword">end</span>)</code></pre>
                </div>
            </div>
            
            <!-- Route Scoping -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Route Scoping</h3>
                <p class="text-light-text-secondary mb-6">
                    Use route scoping to group related routes under a common prefix and apply middleware to specific route groups.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Route Scope Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Apply middleware to all /api routes</span>
self.<span class="code-variable">server</span>:<span class="code-type">use</span>(<span class="code-keyword">function</span>(req, res, next)
 <span class="code-comment">-- Authentication middleware</span>
 <span class="code-keyword">if</span> <span class="code-keyword">not</span> req.headers <span class="code-keyword">or</span> <span class="code-keyword">not</span> req.headers.authorization <span class="code-keyword">then</span>
  <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(401):<span class="code-type">send</span>(<span class="code-string">"Unauthorized"</span>)
 <span class="code-keyword">end</span>
 next()
<span class="code-keyword">end</span>, <span class="code-string">"/api"</span>)

<span class="code-comment">-- Create API route group</span>
self.<span class="code-variable">server</span>:<span class="code-type">scope</span>(<span class="code-string">"/api/v1"</span>, <span class="code-keyword">function</span>(s)
 <span class="code-comment">-- These routes become /api/v1/data, /api/v1/users, etc.</span>
 
 s:<span class="code-type">get</span>(<span class="code-string">"/data"</span>, <span class="code-keyword">function</span>(req, res)
  <span class="code-keyword">local</span> response = {
   message = <span class="code-string">"This is some practice data from /api/prac/data"</span>,
   items = {1, 2, 3, 4, 5}
  }
  res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
     :<span class="code-type">writeStatus</span>(200)
     :<span class="code-type">send</span>(json.encode(response))
 <span class="code-keyword">end</span>)
 
 s:<span class="code-type">get</span>(<span class="code-string">"/users"</span>, <span class="code-keyword">function</span>(req, res)
  <span class="code-comment">-- Return list of users</span>
 <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>)</code></pre>
                </div>
            </div>
        </section>

        <!-- Data Access Section -->
        <section id="data-access" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-build-green flex items-center justify-center text-white font-bold mr-4">2</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Data Access Methods</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-6 text-laser-blue">Available Data Sources</h3>
                
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
                    <div class="bg-blue-50 p-4 rounded-lg border border-blue-100">
                        <span class="data-source-badge bg-laser-blue text-white">URL Parameters</span>
