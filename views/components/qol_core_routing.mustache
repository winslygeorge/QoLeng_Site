                <h4 class="text-xl font-bold mb-4 text-build-green">Query Parameters</h4>
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Query Parameter Access</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- URL: /students/get?id=1&format=json</span>
self.<span class="code-variable">server</span>:<span class="code-type">get</span>(<span class="code-string">"students/get"</span>, <span class="code-keyword">function</span>(req, res, query)
 <span class="code-comment">-- Extract parameters from query object</span>
 <span class="code-keyword">local</span> q = query <span class="code-keyword">or</span> {}
 <span class="code-keyword">local</span> student_id = tonumber(q.id)
 <span class="code-keyword">local</span> format = q.format <span class="code-keyword">or</span> <span class="code-string">"json"</span>
 
 <span class="code-keyword">if</span> <span class="code-keyword">not</span> student_id <span class="code-keyword">then</span>
  <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(400):<span class="code-type">send</span>(<span class="code-string">"Invalid student ID"</span>)
 <span class="code-keyword">end</span>
 
 <span class="code-comment">-- Use parameters to fetch data</span>
 <span class="code-keyword">local</span> student = findStudentById(student_id)
 
 <span class="code-keyword">if</span> format == <span class="code-string">"xml"</span> <span class="code-keyword">then</span>
  <span class="code-comment">-- Return XML format</span>
  res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/xml"</span>)
 <span class="code-keyword">else</span>
  <span class="code-comment">-- Return JSON format (default)</span>
  res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
 <span class="code-keyword">end</span>
 
 res:<span class="code-type">writeStatus</span>(200):<span class="code-type">send</span>(json.encode(student))
<span class="code-keyword">end</span>)</code></pre>
                </div>
                
                <h4 class="text-xl font-bold mb-4 text-query-purple">Request Body Data</h4>
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Request Body Handling</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- POST with JSON body</span>
self.<span class="code-variable">server</span>:<span class="code-type">post</span>(<span class="code-string">"students/add"</span>, <span class="code-keyword">function</span>(req, res, body)
 <span class="code-comment">-- body is automatically parsed based on Content-Type</span>
 body = body <span class="code-keyword">or</span> {}
 
 <span class="code-keyword">if</span> <span class="code-keyword">type</span>(body) == <span class="code-string">"table"</span> <span class="code-keyword">then</span>
  <span class="code-keyword">local</span> name = body.name
  <span class="code-keyword">local</span> age = body.age
  <span class="code-keyword">local</span> mean_score = body.mean_score
  
  <span class="code-keyword">if</span> <span class="code-keyword">not</span> name <span class="code-keyword">or</span> <span class="code-keyword">not</span> age <span class="code-keyword">or</span> <span class="code-keyword">not</span> mean_score <span class="code-keyword">then</span>
   <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(400):<span class="code-type">send</span>(<span class="code-string">"Missing student data"</span>)
  <span class="code-keyword">end</span>
  
  <span class="code-comment">-- Process the data...</span>
  <span class="code-keyword">local</span> new_student = {
   id = #students + 1,
   name = name,
   age = age,
   mean_score = mean_score
  }
  
  res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
     :<span class="code-type">writeStatus</span>(201)
     :<span class="code-type">send</span>(json.encode(new_student))
 <span class="code-keyword">else</span>
  <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(400):<span class="code-type">send</span>(<span class="code-string">"Invalid request body"</span>)
 <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)</code></pre>
                </div>
            </div>
            
            <!-- File Uploads -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">File Uploads & Form Data</h3>
                <p class="text-light-text-secondary mb-6">
                    Handle file uploads and multipart form data with Dawn's built-in form parsing capabilities.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">File Upload Handling</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Handle multipart/form-data uploads</span>
self.<span class="code-variable">server</span>:<span class="code-type">post</span>(<span class="code-string">"/upload"</span>, <span class="code-keyword">function</span>(req, res, form_data)
 <span class="code-comment">-- Access uploaded files and fields</span>
 <span class="code-keyword">if</span> <span class="code-keyword">type</span>(form_data) ~= <span class="code-string">"table"</span> <span class="code-keyword">then</span>
  <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(400):<span class="code-type">send</span>(<span class="code-string">"No form data received"</span>)
 <span class="code-keyword">end</span>
 
 <span class="code-keyword">for</span> name, field <span class="code-keyword">in</span> <span class="code-keyword">pairs</span>(form_data <span class="code-keyword">or</span> {}) <span class="code-keyword">do</span>
  <span class="code-keyword">if</span> <span class="code-keyword">type</span>(field) == <span class="code-string">"table"</span> <span class="code-keyword">and</span> field.path <span class="code-keyword">then</span>
   <span class="code-comment">-- This is a file upload</span>
   print(<span class="code-string">"Uploaded file:"</span>, field.filename, <span class="code-string">"stored at:"</span>, field.path)
   print(<span class="code-string">"File size:"</span>, field.size, <span class="code-string">"MIME type:"</span>, field.mimetype)
  <span class="code-keyword">else</span>
   <span class="code-comment">-- This is a form field</span>
   print(<span class="code-string">"Form field:"</span>, field.name, <span class="code-string">"="</span>, field.body)
  <span class="code-keyword">end</span>
 <span class="code-keyword">end</span>
 
 res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
    :<span class="code-type">writeStatus</span>(200)
    :<span class="code-type">send</span>(<span class="code-string">'{"ok":true}'</span>)
<span class="code-keyword">end</span>)

<span class="code-comment">-- Handle raw binary data</span>
self.<span class="code-variable">server</span>:<span class="code-type">post</span>(<span class="code-string">"/binary/upload"</span>, <span class="code-keyword">function</span>(req, res, body)
 <span class="code-comment">-- body contains @file:/tmp/upload_123456.tmp</span>
 <span class="code-keyword">local</span> file_path = body:<span class="code-type">match</span>(<span class="code-string">"^@file:(.+)$"</span>)
 <span class="code-keyword">if</span> <span class="code-keyword">not</span> file_path <span class="code-keyword">then</span>
  <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(400):<span class="code-type">send</span>(<span class="code-string">"Invalid binary data format"</span>)
 <span class="code-keyword">end</span>
 
 <span class="code-comment">-- Read the binary file</span>
 <span class="code-keyword">local</span> file_content, err = self.<span class="code-variable">server</span>:<span class="code-type">read_file</span>(file_path)
 <span class="code-keyword">if</span> err <span class="code-keyword">then</span>
  <span class="code-keyword">return</span> res:<span class="code-type">writeStatus</span>(500):<span class="code-type">send</span>(<span class="code-string">"Error reading binary file: "</span> .. err)
 <span class="code-keyword">end</span>
 
 print(<span class="code-string">"Received binary data of size:"</span>, #file_content)
 
 res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
    :<span class="code-type">writeStatus</span>(200)
    :<span class="code-type">send</span>(<span class="code-string">'{"ok":true, "size":'</span> .. <span class="code-keyword">tostring</span>(#file_content) .. <span class="code-string">'}'</span>)
<span class="code-keyword">end</span>)</code></pre>
