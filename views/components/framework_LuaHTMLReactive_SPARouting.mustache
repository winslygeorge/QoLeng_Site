                            ), 
                            <span class="code-string">"Delete"</span>
                        )
                    })
                })
            <span class="code-keyword">end</span>) <span class="code-keyword">or</span>
            H.e(<span class="code-string">"p"</span>, {}, <span class="code-string">"No users found"</span>)
