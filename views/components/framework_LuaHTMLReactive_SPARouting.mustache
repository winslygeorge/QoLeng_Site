                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- app.lua - Main application file</span>
<span class="code-keyword">local</span> RouteManager = <span class="code-keyword">require</span>(<span class="code-string">"system.route_manager"</span>)
<span class="code-keyword">local</span> ModalManager = <span class="code-keyword">require</span>(<span class="code-string">"system.modal_manager"</span>)

<span class="code-comment">-- Register routes</span>
RouteManager.registerRoute(<span class="code-string">"home"</span>, <span class="code-keyword">require</span>(<span class="code-string">"pages.home"</span>), {
    path = <span class="code-string">"/"</span>,
    defaultRoute = true,
    title = <span class="code-string">"Home - My App"</span>
})

RouteManager.registerRoute(<span class="code-string">"users"</span>, <span class="code-keyword">require</span>(<span class="code-string">"pages.users"</span>), {
    path = <span class="code-string">"/users"</span>,
    title = <span class="code-string">"Users - My App"</span>
})

RouteManager.registerRoute(<span class="code-string">"userDetail"</span>, <span class="code-keyword">require</span>(<span class="code-string">"pages.user_detail"</span>), {
    path = <span class="code-string">"/users/:userId"</span>,
    title = <span class="code-string">"User Details - My App"</span>
})

RouteManager.registerRoute(<span class="code-string">"settings"</span>, <span class="code-keyword">require</span>(<span class="code-string">"pages.settings"</span>), {
    path = <span class="code-string">"/settings/:tab?"</span>,
    title = <span class="code-string">"Settings - My App"</span>
})

<span class="code-comment">-- Register modals</span>
ModalManager.registerModalType(<span class="code-string">"confirm"</span>, <span class="code-keyword">require</span>(<span class="code-string">"components.modals.confirm"</span>))
ModalManager.registerModalType(<span class="code-string">"userForm"</span>, <span class="code-keyword">require</span>(<span class="code-string">"components.modals.user_form"</span>))
ModalManager.registerModalType(<span class="code-string">"deleteConfirm"</span>, <span class="code-keyword">require</span>(<span class="code-string">"components.modals.delete_confirm"</span>))

<span class="code-comment">-- Application component</span>
<span class="code-keyword">local</span> Application = FunctionalComponent:extends()
Application:setReactiveView()

<span class="code-keyword">function</span> Application:renderLayout(state, props, children, H)
    <span class="code-keyword">return</span> H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"app"</span> }, {
