        <!-- Route Manager Section -->
        <section id="route-manager" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Route Manager</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Route Registration & Configuration</h3>
                <p class="text-light-text-secondary mb-6">
                    The Route Manager handles all navigation and routing logic, supporting static routes, dynamic parameters, 
                    query strings, and animated transitions between views.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">registerRoute(name, component, options)</h4>
                    <p class="text-light-text-secondary mb-3">Register a route with the routing system.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>name</td>
                                <td>string</td>
                                <td>Unique identifier for the route</td>
                            </tr>
                            <tr>
                                <td>component</td>
                                <td>FunctionalComponent</td>
                                <td>The component to render for this route</td>
                            </tr>
                            <tr>
                                <td>options</td>
                                <td>table</td>
                                <td>Configuration options for the route</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <div class="mt-3">
                        <p><strong>Options Properties:</strong></p>
                        <ul class="list-disc pl-5 mt-2 text-light-text-secondary">
                            <li><code>path</code> (string): URL path pattern</li>
                            <li><code>title</code> (string): Page title for browser</li>
                            <li><code>defaultRoute</code> (boolean): Set as default route</li>
                        </ul>
                    </div>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Route Registration Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Static route</span>
RouteManager.registerRoute(<span class="code-string">"home"</span>, HomeComponent, {
    path = <span class="code-string">"/"</span>,
    defaultRoute = true
})

<span class="code-comment">-- Dynamic route with parameters</span>
RouteManager.registerRoute(<span class="code-string">"userProfile"</span>, UserProfileComponent, {
    path = <span class="code-string">"/user/:userId"</span>,
    title = <span class="code-string">"User Profile"</span>
})

<span class="code-comment">-- Route with optional parameters</span>
RouteManager.registerRoute(<span class="code-string">"products"</span>, ProductsComponent, {
    path = <span class="code-string">"/products/:category?/:id?"</span>,
    title = <span class="code-string">"Products"</span>
})

<span class="code-comment">-- Wildcard route</span>
RouteManager.registerRoute(<span class="code-string">"catchAll"</span>, NotFoundComponent, {
    path = <span class="code-string">"/*"</span>
})</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">navigateTo(ws_id, args)</h4>
                    <p class="text-light-text-secondary mb-3">Navigate to a specific route with parameters and configuration.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>ws_id</td>
                                <td>string</td>
                                <td>WebSocket connection ID</td>
                            </tr>
                            <tr>
                                <td>args</td>
                                <td>table</td>
                                <td>Navigation arguments</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <div class="mt-3">
                        <p><strong>Args Properties:</strong></p>
                        <ul class="list-disc pl-5 mt-2 text-light-text-secondary">
                            <li><code>routeName</code> (string): Name of the route to navigate to</li>
                            <li><code>params</code> (table): Route parameters and query parameters</li>
                            <li><code>config</code> (table): Navigation configuration (animation, etc.)</li>
                        </ul>
                    </div>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Navigation Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Simple navigation</span>
RouteManager.methods.navigateTo(self, ws_id, {
    routeName = <span class="code-string">"home"</span>
})

<span class="code-comment">-- Navigation with route parameters</span>
RouteManager.methods.navigateTo(self, ws_id, {
    routeName = <span class="code-string">"userProfile"</span>,
    params = {
        userId = <span class="code-string">"12345"</span>,
        section = <span class="code-string">"settings"</span>
    }
})

<span class="code-comment">-- Navigation with query parameters</span>
RouteManager.methods.navigateTo(self, ws_id, {
    routeName = <span class="code-string">"products"</span>,
    params = {
        category = <span class="code-string">"electronics"</span>,
        sort = <span class="code-string">"price"</span>,
        page = <span class="code-string">"2"</span>
    }
})

<span class="code-comment">-- Navigation with custom configuration</span>
RouteManager.methods.navigateTo(self, ws_id, {
    routeName = <span class="code-string">"about"</span>,
    config = {
        animation = <span class="code-string">"slide"</span>,
        animationDuration = 500,
        preserveState = true
    }
})</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Accessing Route Parameters in Components</h4>
                    <p class="text-light-text-secondary mb-3">
                        Route parameters and query parameters are automatically passed to component props.
                    </p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Accessing Route Data</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- In your component's render function</span>
<span class="code-keyword">function</span> UserProfile:renderLayout(state, props, children, H)
    <span class="code-comment">-- Access route parameters</span>
    <span class="code-keyword">local</span> userId = props.routeParams.userId
    <span class="code-keyword">local</span> section = props.queryParams.section
    
    <span class="code-comment">-- Access route configuration</span>
    <span class="code-keyword">local</span> routeConfig = props.routeConfig
    
    <span class="code-comment">-- Access route ID</span>
    <span class="code-keyword">local</span> routeId = props.routeId
    
    <span class="code-keyword">return</span> H.e(<span class="code-string">"div"</span>, { 
        id = props.routeId,
        class = <span class="code-string">"user-profile"</span> 
    }, {
        H.e(<span class="code-string">"h1"</span>, {}, <span class="code-string">"User Profile: "</span> .. userId),
        H.e(<span class="code-string">"p"</span>, {}, <span class="code-string">"Current section: "</span> .. (section <span class="code-keyword">or</span> <span class="code-string">"overview"</span>))
    })
<span class="code-keyword">end</span></code></pre>
                </div>
            </div>
            
