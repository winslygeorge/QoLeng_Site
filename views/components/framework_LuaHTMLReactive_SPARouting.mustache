UsersPage.methods.showAddUserModal = <span class="code-keyword">function</span>(self, ws_id, args)
    ModalManager.methods.showModal(self, ws_id, {
        modalType = <span class="code-string">"userForm"</span>,
        modalId = <span class="code-string">"add_user_modal"</span>,
        props = {
            title = <span class="code-string">"Add New User"</span>,
            mode = <span class="code-string">"create"</span>,
            onSave = <span class="code-keyword">function</span>(userData)
                <span class="code-comment">-- Save user logic</span>
                <span class="code-keyword">local</span> ops = HTML.client.batch(
                    HTML.client.callModuleFn(<span class="code-string">"window"</span>, <span class="code-string">"alert"</span>, {<span class="code-string">"User created successfully!"</span>}),
                    HTML.patch(<span class="code-string">"modalManager"</span>, <span class="code-keyword">nil</span>, <span class="code-string">"hideModal"</span>, { modalId = <span class="code-string">"add_user_modal"</span> })
                )
                self:sendHTMLClientOperations(ws_id, ops)
            <span class="code-keyword">end</span>
        },
        config = {
            animation = <span class="code-string">"slideUp"</span>,
            draggable = true,
            backdropClose = true
        }
    })
<span class="code-keyword">end</span>

UsersPage.methods.showDeleteConfirm = <span class="code-keyword">function</span>(self, ws_id, args)
    <span class="code-keyword">local</span> userId = args.userId
    ModalManager.methods.showModal(self, ws_id, {
        modalType = <span class="code-string">"deleteConfirm"</span>,
        modalId = <span class="code-string">"delete_confirm_"</span> .. userId,
        props = {
            title = <span class="code-string">"Confirm Delete"</span>,
            message = <span class="code-string">"Are you sure you want to delete this user?"</span>,
            onConfirm = <span class="code-keyword">function</span>()
                <span class="code-comment">-- Delete user logic</span>
                <span class="code-keyword">local</span> ops = HTML.client.batch(
                    HTML.client.callModuleFn(<span class="code-string">"window"</span>, <span class="code-string">"alert"</span>, {<span class="code-string">"User deleted!"</span>}),
                    HTML.patch(<span class="code-string">"modalManager"</span>, <span class="code-keyword">nil</span>, <span class="code-string">"hideModal"</span>, { modalId = <span class="code-string">"delete_confirm_"</span> .. userId })
                )
                self:sendHTMLClientOperations(ws_id, ops)
            <span class="code-keyword">end</span>,
            onCancel = <span class="code-keyword">function</span>()
                ModalManager.methods.hideModal(self, ws_id, { modalId = <span class="code-string">"delete_confirm_"</span> .. userId })
            <span class="code-keyword">end</span>
        }
    })
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> UsersPage:renderLayout(state, props, children, H)
    <span class="code-keyword">local</span> users = state.users <span class="code-keyword">or</span> {}
    
    <span class="code-keyword">return</span> H.e(<span class="code-string">"div"</span>, { id = props.routeId, class = <span class="code-string">"users-page"</span> }, {
