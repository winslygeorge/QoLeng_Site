            <!-- REST API Example -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">REST API Server</h3>
                <p class="text-light-text-secondary mb-4">
                    A complete REST API example with CRUD operations, middleware, and error handling.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">REST API Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-keyword">local</span> DawnServer = <span class="code-keyword">require</span>(<span class="code-string">"dawn_server"</span>)
<span class="code-keyword">local</span> json = <span class="code-keyword">require</span>(<span class="code-string">"dkjson"</span>)

<span class="code-comment">-- In-memory "database"</span>
<span class="code-keyword">local</span> users = {
    { id = 1, name = <span class="code-string">"John Doe"</span>, email = <span class="code-string">"john@example.com"</span> },
    { id = 2, name = <span class="code-string">"Jane Smith"</span>, email = <span class="code-string">"jane@example.com"</span> }
}

<span class="code-comment">-- Create server</span>
<span class="code-keyword">local</span> server = DawnServer:<span class="code-type">new</span>({
    port = 3000,
    level = <span class="code-keyword">require</span>(<span class="code-string">"utils.logger"</span>).LogLevel.INFO
})

<span class="code-comment">-- JSON middleware</span>
server:<span class="code-type">use</span>(<span class="code-keyword">function</span>(req, res, next)
    res.json = <span class="code-keyword">function</span>(data, status)
        status = status <span class="code-keyword">or</span> 200
        res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
           :<span class="code-type">writeStatus</span>(status)
           :<span class="code-type">send</span>(json.encode(data))
    <span class="code-keyword">end</span>
    next()
<span class="code-keyword">end</span>)

<span class="code-comment">-- API routes</span>
server:<span class="code-type">get</span>(<span class="code-string">"/api/users"</span>, <span class="code-keyword">function</span>(req, res)
    res:<span class="code-type">json</span>(users)
<span class="code-keyword">end</span>)

server:<span class="code-type">get</span>(<span class="code-string">"/api/users/:id"</span>, <span class="code-keyword">function</span>(req, res)
    <span class="code-keyword">local</span> userId = tonumber(req.params.id)
    <span class="code-keyword">local</span> user = <span class="code-keyword">nil</span>
    
    <span class="code-keyword">for</span> _, u <span class="code-keyword">in</span> ipairs(users) <span class="code-keyword">do</span>
        <span class="code-keyword">if</span> u.id == userId <span class="code-keyword">then</span>
            user = u
            <span class="code-keyword">break</span>
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">if</span> user <span class="code-keyword">then</span>
        res:<span class="code-type">json</span>(user)
    <span class="code-keyword">else</span>
        res:<span class="code-type">json</span>({ error = <span class="code-string">"User not found"</span> }, 404)
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)

server:<span class="code-type">post</span>(<span class="code-string">"/api/users"</span>, <span class="code-keyword">function</span>(req, res, body)
    <span class="code-keyword">if</span> <span class="code-keyword">not</span> body <span class="code-keyword">or</span> <span class="code-keyword">not</span> body.name <span class="code-keyword">or</span> <span class="code-keyword">not</span> body.email <span class="code-keyword">then</span>
        <span class="code-keyword">return</span> res:<span class="code-type">json</span>({ error = <span class="code-string">"Name and email are required"</span> }, 400)
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">local</span> newUser = {
        id = #users + 1,
        name = body.name,
        email = body.email
    }
    
    table.insert(users, newUser)
    res:<span class="code-type">json</span>(newUser, 201)
<span class="code-keyword">end</span>)

<span class="code-comment">-- Error handler</span>
server:<span class="code-type">on_error</span>(<span class="code-string">"route"</span>, <span class="code-keyword">function</span>(req, res, err)
    server.logger:<span class="code-type">log</span>(Logger.LogLevel.ERROR, <span class="code-string">"Route error: "</span> .. tostring(err))
    res:<span class="code-type">json</span>({ error = <span class="code-string">"Internal server error"</span> }, 500)
<span class="code-keyword">end</span>)

<span class="code-comment">-- Start server</span>
server:<span class="code-type">start</span>()</code></pre>
