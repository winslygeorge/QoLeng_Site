            <!-- Reactive Components -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Reactive Components</h3>
                <p class="text-light-text-secondary mb-4">
                    Dawn Server includes support for reactive components that can update state and broadcast changes to connected clients.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Reactive Component Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Define a reactive component</span>
<span class="code-keyword">local</span> CounterComponent = {
    state = { count = 0 },
    
    setState = <span class="code-keyword">function</span>(self, newState)
        self.state = newState
        <span class="code-comment">-- Return patches for WebSocket clients</span>
        <span class="code-keyword">return</span> { { op = <span class="code-string">"replace"</span>, path = <span class="code-string">"/count"</span>, value = newState.count } }
    <span class="code-keyword">end</span>,
    
    patch = <span class="code-keyword">function</span>(self, ws, patchData)
        <span class="code-comment">-- Handle WebSocket patch operations</span>
        <span class="code-keyword">if</span> patchData.type == <span class="code-string">"increment"</span> <span class="code-keyword">then</span>
            self:<span class="code-type">setState</span>({ count = self.state.count + 1 })
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>,
    
    renderAppPage = <span class="code-keyword">function</span>(self)
        <span class="code-comment">-- Render full HTML with current state</span>
        <span class="code-keyword">return</span> string.format(<span class="code-string">'&lt;div&gt;Count: %d&lt;/div&gt;'</span>, self.state.count)
    <span class="code-keyword">end</span>
}

<span class="code-comment">-- Register the component</span>
server:<span class="code-type">register_reactive_component</span>(CounterComponent, <span class="code-string">"counter"</span>)

<span class="code-comment">-- Route to serve the reactive component</span>
server:<span class="code-type">get</span>(<span class="code-string">"/counter"</span>, <span class="code-keyword">function</span>(req, res)
    <span class="code-keyword">local</span> counter = server:<span class="code-type">get_component</span>(<span class="code-string">"counter"</span>)
    <span class="code-keyword">if</span> counter <span class="code-keyword">then</span>
        res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"text/html"</span>)
           :<span class="code-type">send</span>(counter:<span class="code-type">renderAppPage</span>())
    <span class="code-keyword">else</span>
        res:<span class="code-type">writeStatus</span>(500):<span class="code-type">send</span>(<span class="code-string">"Component not found"</span>)
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)</code></pre>
