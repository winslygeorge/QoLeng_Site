            <!-- Real-time Chat Example -->
            <div class="bg-white rounded-xl shadow-md p-6 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Real-time Chat Application</h3>
                <p class="text-light-text-secondary mb-4">
                    A WebSocket-based real-time chat application with multiple rooms and user management.
                </p>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Chat Application Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-keyword">local</span> DawnServer = <span class="code-keyword">require</span>(<span class="code-string">"dawn_server"</span>)
<span class="code-keyword">local</span> json = <span class="code-keyword">require</span>(<span class="code-string">"dkjson"</span>)

<span class="code-keyword">local</span> server = DawnServer:<span class="code-type">new</span>({ port = 3000 })

<span class="code-comment">-- Chat rooms storage</span>
<span class="code-keyword">local</span> chatRooms = {}

<span class="code-comment">-- WebSocket chat handler</span>
server:<span class="code-type">ws</span>(<span class="code-string">"/chat/:room"</span>, <span class="code-keyword">function</span>(ws, event, message, code, reason)
    <span class="code-keyword">local</span> room = ws.room
    <span class="code-keyword">local</span> userId = ws.userId
    
    <span class="code-keyword">if</span> event == <span class="code-string">"open"</span> <span class="code-keyword">then</span>
        <span class="code-comment">-- Initialize room if needed</span>
        <span class="code-keyword">if</span> <span class="code-keyword">not</span> chatRooms[room] <span class="code-keyword">then</span>
            chatRooms[room] = { users = {}, messages = {} }
        <span class="code-keyword">end</span>
        
        <span class="code-comment">-- Add user to room</span>
        ws.userId = tostring(math.random(1000, 9999))
        ws.room = room
        chatRooms[room].users[ws.userId] = ws
        
        <span class="code-comment">-- Notify room about new user</span>
        <span class="code-keyword">local</span> joinMsg = {
            type = <span class="code-string">"user_joined"</span>,
            userId = ws.userId,
            room = room,
            timestamp = os.time()
        }
        
        server.dawn_sockets_handler:broadcast_to_room(room, json.encode(joinMsg))
        
    <span class="code-keyword">elseif</span> event == <span class="code-string">"message"</span> <span class="code-keyword">then</span>
        <span class="code-comment">-- Handle chat message</span>
        <span class="code-keyword">local</span> msgData = json.decode(message)
        
        <span class="code-keyword">if</span> msgData.type == <span class="code-string">"chat_message"</span> <span class="code-keyword">then</span>
            <span class="code-keyword">local</span> chatMsg = {
                type = <span class="code-string">"chat_message"</span>,
                userId = ws.userId,
                room = room,
                message = msgData.message,
                timestamp = os.time()
            }
            
            <span class="code-comment">-- Store message</span>
            table.insert(chatRooms[room].messages, chatMsg)
            
            <span class="code-comment">-- Broadcast to room</span>
            server.dawn_sockets_handler:broadcast_to_room(room, json.encode(chatMsg))
        <span class="code-keyword">end</span>
        
    <span class="code-keyword">elseif</span> event == <span class="code-string">"close"</span> <span class="code-keyword">then</span>
        <span class="code-comment">-- Remove user from room</span>
        <span class="code-keyword">if</span> chatRooms[room] <span class="code-keyword">and</span> chatRooms[room].users[ws.userId] <span class="code-keyword">then</span>
            chatRooms[room].users[ws.userId] = <span class="code-keyword">nil</span>
            
            <span class="code-comment">-- Notify room about user leaving</span>
            <span class="code-keyword">local</span> leaveMsg = {
                type = <span class="code-string">"user_left"</span>,
                userId = ws.userId,
                room = room,
                timestamp = os.time()
            }
            
            server.dawn_sockets_handler:broadcast_to_room(room, json.encode(leaveMsg))
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)

<span class="code-comment">-- HTTP route to get room messages</span>
server:<span class="code-type">get</span>(<span class="code-string">"/api/rooms/:room/messages"</span>, <span class="code-keyword">function</span>(req, res)
    <span class="code-keyword">local</span> room = req.params.room
    <span class="code-keyword">if</span> chatRooms[room] <span class="code-keyword">then</span>
        res:<span class="code-type">writeHeader</span>(<span class="code-string">"Content-Type"</span>, <span class="code-string">"application/json"</span>)
           :<span class="code-type">send</span>(json.encode(chatRooms[room].messages))
    <span class="code-keyword">else</span>
        res:<span class="code-type">writeStatus</span>(404):<span class="code-type">send</span>(<span class="code-string">"Room not found"</span>)
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)

server:<span class="code-type">start</span>()</code></pre>
