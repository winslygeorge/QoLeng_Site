 <!-- Constructor -->
<div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
  <h3 class="text-2xl font-bold mb-4 text-laser-blue">DawnServer:new(config)</h3>
  <p class="text-light-text-secondary mb-4">
    Creates a new Dawn server instance with the provided configuration table.  
    All parameters are passed through <code>server_config</code>, which controls logging, ports, static directories, token handling, multipart uploads, and more.
  </p>

  <h4 class="text-lg font-bold mb-3 text-neural-charcoal">Parameters</h4>
  <div class="bg-gray-50 p-4 rounded-lg mb-4">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-light-border">
          <th class="text-left py-2 font-bold">Parameter</th>
          <th class="text-left py-2 font-bold">Type</th>
          <th class="text-left py-2 font-bold">Description</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">config</td>
          <td class="py-2">table</td>
          <td class="py-2">Main configuration object for the server (see options below)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h4 class="text-lg font-bold mb-3 text-neural-charcoal">Configuration Options</h4>
  <div class="bg-gray-50 p-4 rounded-lg overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-light-border">
          <th class="text-left py-2 font-bold">Option</th>
          <th class="text-left py-2 font-bold">Type</th>
          <th class="text-left py-2 font-bold">Default</th>
          <th class="text-left py-2 font-bold">Mandatory</th>
          <th class="text-left py-2 font-bold">Description</th>
        </tr>
      </thead>
      <tbody>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">port</td>
          <td class="py-2">number</td>
          <td class="py-2">8080</td>
          <td class="py-2 text-green-700 font-semibold">Yes</td>
          <td class="py-2">Port for the HTTP server to listen on. Can be overridden via <code>env.PORT</code>.</td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">level</td>
          <td class="py-2">LogLevel</td>
          <td class="py-2">WARN</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Sets logging verbosity based on environment or defaults. Supports <code>DEBUG</code>, <code>INFO</code>, <code>WARN</code>, <code>ERROR</code>.</td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">logger</td>
          <td class="py-2">Logger</td>
          <td class="py-2">nil</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Custom logger instance. If nil, defaults to internal logging.</td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">static_configs</td>
          <td class="py-2">table[]</td>
          <td class="py-2">[{"/static", "./public"}]</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">List of static file directories. Each entry includes:
            <ul class="list-disc ml-6">
              <li><code>route_prefix</code> (string): URL prefix (e.g. <code>/static</code>)</li>
              <li><code>directory_path</code> (string): Path to serve files from (e.g. <code>./public</code>)</li>
            </ul>
          </td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">dev_watcher_config</td>
          <td class="py-2">table</td>
          <td class="py-2">{interval=1.0, debounce_ms=1000, retry_ms=2000}</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">File watcher for live development reloads.
            <ul class="list-disc ml-6">
              <li><code>interval</code>: Scan interval (seconds)</li>
              <li><code>debounce_ms</code>: Restart cooldown period (ms)</li>
              <li><code>retry_ms</code>: Delay before retrying failed reloads (ms)</li>
              <li><code>watch_dirs</code>: Table of directories to monitor (<code>components</code>, <code>views</code>, <code>static</code>)</li>
            </ul>
          </td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">multipart_parser_options</td>
          <td class="py-2">table</td>
          <td class="py-2">see details</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Options for handling multipart/form-data uploads:
            <ul class="list-disc ml-6">
              <li><code>debug</code>: Enable debug logging</li>
              <li><code>max_memory_size</code>: Max memory allowed per part (default 512 KB)</li>
              <li><code>decode_base64</code>: Auto-decode base64 parts</li>
              <li><code>decode_gzip</code>: Auto-decompress gzip content</li>
              <li><code>stream_to_disk</code>: Stream uploads directly to disk</li>
              <li><code>auto_save_dir</code>: Directory for saved uploads</li>
              <li><code>on_start_part</code> / <code>on_end_part</code>: Callback hooks</li>
              <li><code>progress_callback</code>: Called with uploaded byte count</li>
              <li><code>nested</code>: Parse nested form fields like <code>user[name]</code></li>
            </ul>
          </td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">token_store</td>
          <td class="py-2">table</td>
          <td class="py-2">{store=require('dawn').token_store, cleanup_interval=3600}</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Configuration for managing token persistence and cleanup frequency.</td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">heartbeat_config</td>
          <td class="py-2">table</td>
          <td class="py-2">{interval=1000, timeout=1000}</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Defines heartbeat timing for server health checks or WebSocket connections.</td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">reactive_render_engine</td>
          <td class="py-2">boolean</td>
          <td class="py-2">true</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Enable reactive DOM-based rendering engine for dynamic page updates.</td>
        </tr>

        <tr class="border-b border-light-border">
          <td class="py-2 font-mono">state_management_options</td>
          <td class="py-2">table</td>
          <td class="py-2">{session_timeout=3600, cleanup_interval=600}</td>
          <td class="py-2 text-green-700 font-semibold">Optional</td>
          <td class="py-2">Configures server-side state and session management.
            <ul class="list-disc ml-6">
              <li><code>handlers</code>: Module for WebSocket or session handlers</li>
              <li><code>session_timeout</code>: Expiry time (in seconds) for inactive sessions</li>
              <li><code>cleanup_interval</code>: Periodic cleanup frequency</li>
              <li><code>state.state_management</code>: Reference to core state manager module</li>
              <li><code>env.REDIS_CONFIG</code>: Optional Redis config for distributed session persistence</li>
            </ul>
          </td>
        </tr>

      </tbody>
    </table>
  </div>
</div>

            
            <!-- Routing Methods -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Routing Methods</h3>
                <p class="text-light-text-secondary mb-4">
                    Dawn Server supports all standard HTTP methods and WebSocket routes.
                </p>
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <h4 class="text-lg font-bold mb-3 text-neural-charcoal">HTTP Methods</h4>
                        <ul class="space-y-2">
                            <li class="flex items-start">
                                <code class="bg-gray-100 px-2 py-1 rounded text-sm mr-2">get</code>
