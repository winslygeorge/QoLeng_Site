                    <p style="color: var(--doc-text-secondary);">Advanced file uploads with preview and streaming</p>
                </div>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Quick Start Example</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Import HTML module</span>
<span class="keyword">local</span> HTML = <span class="keyword">require</span> <span class="string">"LuaHTMLReactive"</span>

<span class="comment">-- Create a complete UI with custom widgets</span>
<span class="keyword">local</span> appUI = HTML.Card({ class = <span class="string">"max-w-4xl mx-auto"</span> }, {
    HTML.e(<span class="string">"h1"</span>, { class = <span class="string">"text-2xl font-bold mb-6"</span> }, <span class="string">"User Dashboard"</span>),
    
    HTML.Grid(<span class="number">2</span>, <span class="string">"1rem"</span>, {
        HTML.Card({}, {
            HTML.e(<span class="string">"h2"</span>, { class = <span class="string">"text-lg font-semibold mb-4"</span> }, <span class="string">"User Profile"</span>),
            HTML.Form({}, {
                HTML.FormField(<span class="string">"Name"</span>, HTML.TextField(<span class="string">"name"</span>, <span class="string">"John Doe"</span>)),
                HTML.FormField(<span class="string">"Email"</span>, HTML.TextField(<span class="string">"email"</span>, <span class="string">"john@example.com"</span>)),
                HTML.PrimaryButton(<span class="string">"Save Profile"</span>, { type = <span class="string">"submit"</span> })
            })
        }),
        
        HTML.Card({}, {
            HTML.e(<span class="string">"h2"</span>, { class = <span class="string">"text-lg font-semibold mb-4"</span> }, <span class="string">"Actions"</span>),
            HTML.Column({}, {
                HTML.PrimaryButton(<span class="string">"New Project"</span>),
                HTML.SecondaryButton(<span class="string">"View Reports"</span>),
                HTML.DangerButton(<span class="string">"Delete Account"</span>)
            })
        })
    })
})

<span class="keyword">return</span> appUI</code></pre>
            </div>
        </div>
    </section>

    <!-- Layout Widgets Section -->
