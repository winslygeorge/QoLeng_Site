                        <i class="fas fa-edit"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">Form Widgets</h3>
                    <p style="color: var(--doc-text-secondary);">Input fields, buttons, selects, and form controls</p>
                </div>
                
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--query-purple), var(--warning-amber));">
                        <i class="fas fa-cube"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">UI Components</h3>
