                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Single operation</span>
<span class="code-keyword">local</span> singleOp = HTML.client.setText(<span class="code-string">"#message"</span>, <span class="code-string">"Hello World"</span>)

<span class="code-comment">-- Batch multiple operations</span>
<span class="code-keyword">local</span> batchOps = HTML.client.batch(
    HTML.client.addClass(<span class="code-string">"#element"</span>, <span class="code-string">"active"</span>),
    HTML.client.show(<span class="code-string">"#content"</span>),
    HTML.client.fetch(<span class="code-string">"/api/data"</span>)
)

<span class="code-comment">-- Use in event handlers</span>
<span class="code-keyword">local</span> button = HTML.e(<span class="code-string">"button"</span>, {
    onclick = HTML.on(<span class="code-string">"click"</span>, batchOps)
}, <span class="code-string">"Click Me"</span>)

<span class="code-comment">-- Chain operations with conditionals</span>
<span class="code-keyword">local</span> conditionalOps = HTML.client.if_(
    HTML.client.getValue(<span class="code-string">"#input"</span>),
    HTML.client.batch(
        HTML.client.setText(<span class="code-string">"#status"</span>, <span class="code-string">"Valid"</span>),
        HTML.client.addClass(<span class="code-string">"#status"</span>, <span class="code-string">"success"</span>)
    ),
    HTML.client.batch(
        HTML.client.setText(<span class="code-string">"#status"</span>, <span class="code-string">"Invalid"</span>),
        HTML.client.addClass(<span class="code-string">"#status"</span>, <span class="code-string">"error"</span>)
    )
)</code></pre>
