                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">&lt;!-- Game Interface --&gt;</span>
&lt;div id=<span class="code-string">"game-container"</span>&gt;
    &lt;div id=<span class="code-string">"players-list"</span>&gt;&lt;/div&gt;
    &lt;div id=<span class="code-string">"game-board"</span>&gt;&lt;/div&gt;
    &lt;div id=<span class="code-string">"game-chat"</span>&gt;&lt;/div&gt;
    &lt;input type=<span class="code-string">"text"</span> id=<span class="code-string">"game-chat-input"</span> placeholder=<span class="code-string">"Game chat..."</span>&gt;
&lt;/div&gt;

&lt;script&gt;
    const userId = Math.random().toString(36).substring(2, 10);
    const gameId = "chess_match_001";
    const ws = new WebSocket("ws://localhost:3003/ws");

    const gameState = {
        players: [],
        board: [],
        currentTurn: null
    };

    ws.onopen = () => {
        console.log("Connected to game server");
        
        <span class="code-comment">// Join the game room</span>
        ws.send(JSON.stringify({
            topic: `game:${gameId}`,
            event: "join",
            payload: {
                player_name: `Player_${userId}`,
                team: Math.random() > 0.5 ? "white" : "black"
            }
        }));
    };

    ws.onmessage = (event) => {
        const data = JSON.parse(event.data);
        
        switch(data.event) {
            case "player_joined":
                addPlayer(data.payload);
                break;
            case "player_left":
                removePlayer(data.payload.player_id);
                break;
            case "player_action":
                handleGameAction(data.payload);
                break;
            case "game_state":
                updateGameState(data.payload);
                break;
            case "game_chat":
                addChatMessage(data.payload);
                break;
        }
    };

    function addPlayer(player) {
        gameState.players.push(player);
        updatePlayersList();
    }

    function removePlayer(playerId) {
        gameState.players = gameState.players.filter(p => p.player_id !== playerId);
        updatePlayersList();
    }

    function handleGameAction(action) {
        console.log("Game action:", action);
        <span class="code-comment">// Update game UI based on action</span>
        updateGameBoard(action);
    }

    function sendGameAction(action, data) {
        ws.send(JSON.stringify({
            topic: `game:${gameId}`,
            event: "player_action",
            payload: {
                action: action,
                data: data
            }
        }));
    }

    function sendChatMessage() {
        const message = document.getElementById("game-chat-input").value;
        if (!message) return;

        ws.send(JSON.stringify({
            topic: `game:${gameId}`,
            event: "chat",
            payload: {
                message: message
            }
        }));

        document.getElementById("game-chat-input").value = "";
    }

    <span class="code-comment">// Example game actions</span>
    function movePiece(from, to) {
        sendGameAction("move_piece", { from, to });
    }

    function attackPiece(attacker, target) {
        sendGameAction("attack_piece", { attacker, target });
    }

    <span class="code-comment">// UI update functions</span>
    function updatePlayersList() {
        const list = document.getElementById("players-list");
        list.innerHTML = gameState.players.map(player =&gt; 
            `&lt;div&gt;${player.player_name} (${player.team})&lt;/div&gt;`
        ).join("");
    }

    function addChatMessage(message) {
        const chat = document.getElementById("game-chat");
        chat.innerHTML += `&lt;div&gt;&lt;strong&gt;${message.player_id}:&lt;/strong&gt; ${message.message}&lt;/div&gt;`;
    }
&lt;/script&gt;</code></pre>
