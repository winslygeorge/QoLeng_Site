                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>id</td>
                                <td>mixed</td>
                                <td>Primary key value</td>
                            </tr>
                            <tr>
                                <td>opts</td>
                                <td>table</td>
                                <td>Optional: {include_relations = true}</td>
                            </tr>
                            <tr>
                                <td>callback</td>
                                <td>function</td>
                                <td>Optional callback for async mode</td>
                            </tr>
                        </tbody>
