                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Find by primary key</span>
<span class="code-keyword">local</span> user, err = User:<span class="code-type">find</span>(1)
<span class="code-keyword">if</span> user <span class="code-keyword">then</span>
    print(<span class="code-string">"Found user: "</span> .. user.username)
<span class="code-keyword">end</span>

<span class="code-comment">-- Find with relations (eager loading)</span>
