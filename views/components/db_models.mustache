                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">save(callback)</h4>
                    <p class="text-light-text-secondary mb-3">Saves the current model instance (inserts new or updates existing).</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>callback</td>
                                <td>function</td>
                                <td>Optional callback for async mode</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> boolean success, error message</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Save Examples</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Create new instance and save</span>
<span class="code-keyword">local</span> user = User:<span class="code-type">new</span>({
    username = <span class="code-string">"bob_smith"</span>,
    email = <span class="code-string">"bob@example.com"</span>
})

<span class="code-keyword">local</span> success, err = user:<span class="code-type">save</span>()
<span class="code-keyword">if</span> success <span class="code-keyword">then</span>
