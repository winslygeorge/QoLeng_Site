                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Define related models</span>
<span class="code-keyword">local</span> Post = Model:<span class="code-type">extend</span>(<span class="code-string">"posts"</span>, {
    id = <span class="code-string">"integer"</span>,
