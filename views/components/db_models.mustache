                                <td><code>"integer"</code></td>
                                <td>Whole numbers</td>
                                <td><code>age = "integer"</code></td>
                            </tr>
                            <tr>
                                <td><code>"string"</code></td>
                                <td>Short text/VARCHAR</td>
                                <td><code>username = "string"</code></td>
                            </tr>
                            <tr>
                                <td><code>"timestamp"</code></td>
                                <td>Date and time</td>
                                <td><code>created_at = "timestamp"</code></td>
                            </tr>
                            <tr>
                                <td><code>"boolean"</code></td>
                                <td>True/false (stored as 1/0)</td>
                                <td><code>is_active = "boolean"</code></td>
                            </tr>
                            <tr>
                                <td><code>"float"</code></td>
                                <td>Floating point numbers</td>
                                <td><code>salary = "float"</code></td>
                            </tr>
                            <tr>
                                <td><code>"text"</code></td>
                                <td>Long text content</td>
                                <td><code>bio = "text"</code></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
