}, {
    _primary_key = <span class="code-string">"id"</span>,
    _relations = {
        author = {
            model = <span class="code-string">"User"</span>,
            foreign_key = <span class="code-string">"author_id"</span>,
            local_key = <span class="code-string">"id"</span>,
            join_type = <span class="code-string">"LEFT"</span>
        }
    },
    _model_classes = {User = User}
})

<span class="code-comment">-- Update User model with posts relation</span>
User._relations.posts = {
    model = <span class="code-string">"Post"</span>,
    foreign_key = <span class="code-string">"author_id"</span>,
    local_key = <span class="code-string">"id"</span>,
    join_type = <span class="code-string">"LEFT"</span>
}
User._model_classes.Post = Post

<span class="code-comment">-- Eager loading with relations</span>
<span class="code-keyword">local</span> user, err = User:<span class="code-type">find</span>(1, {include_relations = true})
<span class="code-keyword">if</span> user <span class="code-keyword">then</span>
