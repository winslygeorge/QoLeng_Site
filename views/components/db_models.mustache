    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>

<span class="code-comment">-- Get posts with author eager loaded</span>
<span class="code-keyword">local</span> posts, err = Post:<span class="code-type">all</span>({include_relations = true})
<span class="code-keyword">for</span> i, post <span class="code-keyword">in</span> ipairs(posts) <span class="code-keyword">do</span>
    print(<span class="code-string">"Post: "</span> .. post.title .. <span class="code-string">" by "</span> .. post.author.username)
<span class="code-keyword">end</span></code></pre>
