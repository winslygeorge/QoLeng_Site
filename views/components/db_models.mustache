                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Basic create operation</span>
<span class="code-keyword">local</span> user, err = User:<span class="code-type">create</span>({
    username = <span class="code-string">"john_doe"</span>,
    email = <span class="code-string">"john@example.com"</span>,
    first_name = <span class="code-string">"John"</span>,
    last_name = <span class="code-string">"Doe"</span>,
    age = 30
})

<span class="code-keyword">if</span> err <span class="code-keyword">then</span>
    print(<span class="code-string">"Error creating user: "</span> .. err)
<span class="code-keyword">else</span>
    print(<span class="code-string">"User created with ID: "</span> .. user.id)
<span class="code-keyword">end</span>

<span class="code-comment">-- Async create operation</span>
User:<span class="code-type">create</span>({
    username = <span class="code-string">"jane_doe"</span>,
    email = <span class="code-string">"jane@example.com"</span>
}, <span class="code-keyword">function</span>(user, err)
