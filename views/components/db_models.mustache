        <!-- Model Creation Section -->
        <section id="model-creation" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Model Creation & Configuration</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Model.extend() Method</h3>
                <p class="text-light-text-secondary mb-6">
                    The primary method for creating new model classes. Defines the database table schema and model configuration.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Model:extend(table_name, fields, options)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a new model class with the specified table schema and configuration.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>table_name</td>
                                <td>string</td>
                                <td>The name of the database table</td>
                            </tr>
                            <tr>
                                <td>fields</td>
                                <td>table</td>
                                <td>Field definitions as key-value pairs: {field_name = "type"}</td>
                            </tr>
                            <tr>
                                <td>options</td>
                                <td>table</td>
                                <td>Optional configuration for the model</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> New model class</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Complete Model Definition</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-keyword">local</span> User = Model:<span class="code-type">extend</span>(<span class="code-string">"users"</span>, {
    <span class="code-comment">-- Field definitions (string types only)</span>
    id = <span class="code-string">"integer"</span>,
    username = <span class="code-string">"string"</span>,
    email = <span class="code-string">"string"</span>,
    password_hash = <span class="code-string">"string"</span>,
    first_name = <span class="code-string">"string"</span>,
    last_name = <span class="code-string">"string"</span>,
    age = <span class="code-string">"integer"</span>,
    salary = <span class="code-string">"float"</span>,
    is_active = <span class="code-string">"boolean"</span>,
    bio = <span class="code-string">"text"</span>,
    created_at = <span class="code-string">"timestamp"</span>,
    updated_at = <span class="code-string">"timestamp"</span>,
    deleted_at = <span class="code-string">"timestamp"</span>
}, {
    <span class="code-comment">-- Model options</span>
    _primary_key = <span class="code-string">"id"</span>,
    _connection_mode = <span class="code-string">"sync"</span>, <span class="code-comment">-- or "async"</span>
    _timestamps = true,
    
    <span class="code-comment">-- Unique constraints</span>
    _unique_keys = {
        {<span class="code-string">"email"</span>},
        {<span class="code-string">"username"</span>},
        {<span class="code-string">"first_name"</span>, <span class="code-string">"last_name"</span>}
    },
    
    <span class="code-comment">-- Index definitions</span>
    _indexes = {
        <span class="code-string">"email"</span>,
        {<span class="code-string">"last_name"</span>, <span class="code-string">"first_name"</span>},
        {columns = <span class="code-string">"email"</span>, unique = true}
    },
    
    <span class="code-comment">-- Foreign key relationships</span>
    _foreign_keys = {
        {
            columns = <span class="code-string">"created_by"</span>,
            references = <span class="code-string">"users(id)"</span>,
            on_delete = <span class="code-string">"SET NULL"</span>
        }
    },
    
    <span class="code-comment">-- ORM relations for eager loading</span>
    _relations = {
        posts = {
            model = <span class="code-string">"Post"</span>,
            foreign_key = <span class="code-string">"author_id"</span>,
            local_key = <span class="code-string">"id"</span>,
            join_type = <span class="code-string">"LEFT"</span>
        }
    },
    
    <span class="code-comment">-- Filter presets for reusable queries</span>
    _filter_presets = {
        active = <span class="code-keyword">function</span>(qb)
            <span class="code-keyword">return</span> qb:<span class="code-type">where</span>(<span class="code-string">"is_active"</span>, <span class="code-string">"="</span>, true)
        <span class="code-keyword">end</span>,
        recent = <span class="code-keyword">function</span>(qb)
            <span class="code-keyword">return</span> qb:<span class="code-type">where</span>(<span class="code-string">"created_at"</span>, <span class="code-string">">"</span>, os.date(<span class="code-string">"!%Y-%m-%d"</span>, os.time() - 7*24*60*60))
        <span class="code-keyword">end</span>
    },
    
    <span class="code-comment">-- Required for relation loading</span>
    _model_classes = {Post = Post}
})</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">Supported Field Types</h4>
                    <p class="text-light-text-secondary mb-3">The ORM supports these basic field types:</p>
                    
                    <table class="param-table">
                        <thead>
