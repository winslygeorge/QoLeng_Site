                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Get all users</span>
<span class="code-keyword">local</span> users, err = User:<span class="code-type">all</span>()
<span class="code-keyword">for</span> i, user <span class="code-keyword">in</span> ipairs(users) <span class="code-keyword">do</span>
    print(<span class="code-string">"User: "</span> .. user.username)
<span class="code-keyword">end</span>

<span class="code-comment">-- Get all with relations</span>
<span class="code-keyword">local</span> users, err = User:<span class="code-type">all</span>({include_relations = true})

<span class="code-comment">-- Where conditions</span>
<span class="code-keyword">local</span> active_users, err = User:<span class="code-type">where</span>({is_active = true})
<span class="code-keyword">local</span> admins, err = User:<span class="code-type">where</span>({role = <span class="code-string">"admin"</span>, status = <span class="code-string">"active"</span>})

<span class="code-comment">-- Advanced where conditions</span>
<span class="code-keyword">local</span> users, err = User:<span class="code-type">find_where</span>({
