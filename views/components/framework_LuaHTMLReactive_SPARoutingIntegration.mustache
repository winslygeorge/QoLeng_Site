MainAppPage.methods.navigateTo = <span class="code-keyword">function</span>(self, ws_id, args)
    <span class="code-keyword">local</span> routeManager = self:getChildComponent(<span class="code-string">"routeManager"</span>)
    <span class="code-keyword">if</span> routeManager <span class="code-keyword">then</span>
        routeManager.methods.navigateTo(routeManager, ws_id, args)
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>

MainAppPage.methods.showModal = <span class="code-keyword">function</span>(self, ws_id, args)
    self:callChildMethod(<span class="code-string">"modalManager"</span>, <span class="code-string">"showModal"</span>, ws_id, args)
<span class="code-keyword">end</span>

MainAppPage.methods.hideModal = <span class="code-keyword">function</span>(self, ws_id, args)
    self:callChildMethod(<span class="code-string">"modalManager"</span>, <span class="code-string">"hideModal"</span>, ws_id, args)
<span class="code-keyword">end</span></code></pre>
