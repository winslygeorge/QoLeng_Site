        <span class="code-keyword">end</span>

        <span class="code-keyword">return</span> <span class="code-keyword">function</span>(state, props, children, H, client_state)
            <span class="code-keyword">return</span> MainAppPage:renderLayout(state, props, children, H)
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>

<span class="code-comment">-- ===== CLIENT READY HANDLER =====</span>
MainAppPage:onClientReady(<span class="code-keyword">function</span> (self, parent_ws_id, parent_client_toke)
    <span class="code-keyword">local</span> clientState = self:getRedisClientState(parent_client_toke, <span class="code-string">"modalManager"</span>)
