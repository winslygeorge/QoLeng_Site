<span class="code-keyword">end</span>)

<span class="code-comment">-- ===== FINAL APPLICATION RENDER =====</span>
<span class="code-keyword">function</span> MainAppPage:render_layout()
    <span class="code-comment">-- Set component key for identification</span>
