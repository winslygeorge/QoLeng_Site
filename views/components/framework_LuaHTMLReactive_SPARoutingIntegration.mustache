    <span class="keyword">local</span> modalManager = <span class="keyword">require</span>(<span class="string">"system.ModalManager"</span>)
    self:addChildComponent(<span class="string">'modalManager'</span>, modalManager)
    modalManager:load()
    
    <span class="keyword">return</span> self:renderAppPage({
        title = <span class="string">"Qoleng - Build Bold"</span>,
        body_attrs = { class = <span class="string">"antialiased bg-[#FFFFFF]"</span> }
    })
<span class="keyword">end</span>

<span class="keyword">return</span> MainAppPage</code></pre>
