                        </p>
                        <div class="bg-gray-800 text-gray-200 rounded-lg p-4 code-block">
                            <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Home.lua - Example page component</span>
<span class="code-keyword">local</span> FunctionalComponent = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.FuncComponent"</span>)
<span class="code-keyword">local</span> HTML = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.LuaHTMLReactive"</span>)

<span class="code-keyword">local</span> HomePage = FunctionalComponent:extends()
HomePage:setReactiveView()

<span class="code-keyword">function</span> HomePage:renderLayout(state, props, children, H)
    <span class="code-keyword">local</span> routeId = props.routeId <span class="code-comment">-- Provided by RouteManager</span>
    <span class="code-keyword">local</span> queryParams = props.queryParams <span class="code-comment">-- URL query parameters</span>
    <span class="code-keyword">local</span> routeParams = props.routeParams <span class="code-comment">-- Route path parameters</span>
    
    <span class="code-keyword">return</span> HTML.e(<span class="code-string">"div"</span>, { 
        id = routeId, 
        class = <span class="code-string">"home-page bg-white p-6"</span> 
    }, {
        HTML.e(<span class="code-string">"h1"</span>, { class = <span class="code-string">"text-3xl font-bold"</span> }, <span class="code-string">"Welcome Home"</span>),
        
        <span class="code-comment">-- Navigation example</span>
        HTML.e(<span class="code-string">"button"</span>, 
            HTML.merge({ class = <span class="code-string">"btn btn-primary"</span> }, 
                HTML.onClick(
                    HTML.patch(<span class="code-string">"routeManager"</span>, <span class="code-keyword">nil</span>, <span class="code-string">"navigateTo"</span>, {
                        routeName = <span class="code-string">"about"</span>,
                        params = { source = <span class="code-string">"home_page"</span> }
                    })
                )
            ), 
            <span class="code-string">"Go to About"</span>
        ),
        
        <span class="code-comment">-- Modal example</span>
        HTML.e(<span class="code-string">"button"</span>, 
            HTML.merge({ class = <span class="code-string">"btn btn-secondary"</span> }, 
                HTML.onClick(
                    HTML.patch(<span class="code-string">"modalManager"</span>, <span class="code-keyword">nil</span>, <span class="code-string">"showModal"</span>, {
                        modalType = <span class="code-string">"promptModal"</span>,
                        modalId = <span class="code-string">"welcome_modal"</span>,
                        props = {
                            title = <span class="code-string">"Welcome!"</span>,
                            message = <span class="code-string">"This is a modal from the home page."</span>
                        }
                    })
                )
            ), 
            <span class="code-string">"Show Welcome Modal"</span>
        )
    })
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> HomePage</code></pre>
