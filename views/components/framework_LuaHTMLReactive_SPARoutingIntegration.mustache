<span class="code-keyword">local</span> RouteManager = <span class="code-keyword">require</span>(<span class="code-string">"system.RouteManager"</span>)
<span class="code-keyword">local</span> HomePage = <span class="code-keyword">require</span>(<span class="code-string">"lib.components.home"</span>)
<span class="code-keyword">local</span> AboutPage = <span class="code-keyword">require</span>(<span class="code-string">"lib.components.about"</span>)

<span class="code-comment">-- Register routes</span>
RouteManager.registerRoute(<span class="code-string">"home"</span>, HomePage, {
    path = <span class="code-string">"/"</span>,
    defaultRoute = true
})

RouteManager.registerRoute(<span class="code-string">"about"</span>, AboutPage, {
    path = <span class="code-string">"/about"</span>
})

<span class="code-comment">-- Add as child component</span>
self:addChildComponent(<span class="code-string">"routeManager"</span>, RouteManager)
RouteManager:load()</code></pre>
                        </div>
