<span class="keyword">local</span> HomePage = <span class="keyword">require</span>(<span class="string">"lib.components.home"</span>)

<span class="keyword">local</span> MainAppPage = FunctionalComponent:extends()
MainAppPage:setReactiveView()

RouteManager.registerRoute(<span class="string">"home"</span>, HomePage, {
