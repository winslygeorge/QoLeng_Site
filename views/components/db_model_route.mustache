                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Create ModelRoute directly (usually done by DawnModelRoute)</span>
<span class="code-keyword">local</span> ModelRoute = <span class="code-keyword">require</span>(<span class="code-string">"orm.model_route"</span>)
<span class="code-keyword">local</span> User = <span class="code-keyword">require</span>(<span class="code-string">"models.user"</span>)

<span class="code-comment">-- Create ModelRoute instance</span>
