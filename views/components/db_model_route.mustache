                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Load required modules</span>
<span class="code-keyword">local</span> DawnModelRoute = <span class="code-keyword">require</span>(<span class="code-string">"path.to.dawn_model_route"</span>)
<span class="code-keyword">local</span> User = <span class="code-keyword">require</span>(<span class="code-string">"models.user"</span>) <span class="code-comment">-- Your ORM model</span>
<span class="code-keyword">local</span> DawnServer = <span class="code-keyword">require</span>(<span class="code-string">"dawn"</span>) <span class="code-comment">-- Dawn server instance</span>

<span class="code-comment">-- Create model route</span>
<span class="code-keyword">local</span> user_route = DawnModelRoute:<span class="code-type">new</span>(<span class="code-string">"users"</span>, User, DawnServer)

<span class="code-comment">-- Initialize routes</span>
user_route:<span class="code-type">initialize</span>()

<span class="code-comment">-- Now you have automatic REST API endpoints:</span>
<span class="code-comment">-- GET /api/users</span>
<span class="code-comment">-- GET /api/users/:id</span>
<span class="code-comment">-- POST /api/users</span>
<span class="code-comment">-- PUT /api/users/:id</span>
<span class="code-comment">-- DELETE /api/users/:id</span></code></pre>
