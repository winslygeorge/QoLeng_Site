                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- app.lua - Main application file</span>

<span class="code-comment">-- Load required modules</span>
<span class="code-keyword">local</span> DawnServer = <span class="code-keyword">require</span>(<span class="code-string">"dawn"</span>)
<span class="code-keyword">local</span> DawnModelRoute = <span class="code-keyword">require</span>(<span class="code-string">"path.to.dawn_model_route"</span>)

<span class="code-comment">-- Load your ORM models</span>
<span class="code-keyword">local</span> User = <span class="code-keyword">require</span>(<span class="code-string">"models.user"</span>)
<span class="code-keyword">local</span> Product = <span class="code-keyword">require</span>(<span class="code-string">"models.product"</span>)
<span class="code-keyword">local</span> Order = <span class="code-keyword">require</span>(<span class="code-string">"models.order"</span>)

<span class="code-comment">-- Create DawnServer instance</span>
<span class="code-keyword">local</span> server = DawnServer:<span class="code-type">new</span>({
    port = 8080,
    host = <span class="code-string">"0.0.0.0"</span>
})

<span class="code-comment">-- Create model routes</span>
<span class="code-keyword">local</span> user_route = DawnModelRoute:<span class="code-type">new</span>(<span class="code-string">"users"</span>, User, server)
<span class="code-keyword">local</span> product_route = DawnModelRoute:<span class="code-type">new</span>(<span class="code-string">"products"</span>, Product, server)
<span class="code-keyword">local</span> order_route = DawnModelRoute:<span class="code-type">new</span>(<span class="code-string">"orders"</span>, Order, server)

<span class="code-comment">-- Initialize all routes</span>
user_route:<span class="code-type">initialize</span>()
product_route:<span class="code-type">initialize</span>()
order_route:<span class="code-type">initialize</span>()

<span class="code-comment">-- Add custom routes if needed</span>
server:<span class="code-type">get</span>(<span class="code-string">"/"</span>, <span class="code-keyword">function</span>(req, res)
    res:<span class="code-type">send</span>(<span class="code-string">"Welcome to the API!"</span>)
<span class="code-keyword">end</span>)

<span class="code-comment">-- Start the server</span>
server:<span class="code-type">start</span>()

<span class="code-comment">-- Now you have automatic REST APIs for:</span>
<span class="code-comment">-- Users:    /api/users</span>
<span class="code-comment">-- Products: /api/products</span>
<span class="code-comment">-- Orders:   /api/orders</span>

<span class="code-comment">-- Example API usage:</span>
<span class="code-comment">-- GET    /api/users           - Get all users</span>
<span class="code-comment">-- GET    /api/users/123       - Get user with ID 123</span>
<span class="code-comment">-- POST   /api/users           - Create new user</span>
