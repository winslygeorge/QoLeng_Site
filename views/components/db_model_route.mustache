        <!-- DawnModelRoute Section -->
        <section id="dawn-model-route" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">DawnModelRoute</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Route Registration & Management</h3>
                <p class="text-light-text-secondary mb-6">
                    DawnModelRoute acts as a wrapper that automatically registers RESTful routes for ORM models
                    with the DawnServer, providing a clean API scoped under <code>/api/{model_name}</code>.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">new(model_name, Model, server)</h4>
                    <p class="text-light-text-secondary mb-3">Creates a new DawnModelRoute instance for automatic route generation.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>model_name</td>
                                <td>string</td>
                                <td>The name of the model (e.g., "User", "Product") used in route paths</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>Model</td>
                                <td>table</td>
                                <td>The ORM model class (e.g., User, Product) to which the route is associated</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>server</td>
                                <td>table</td>
                                <td>The server instance (DawnServer) to which the route is associated</td>
                                <td>Yes</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> table - A new DawnModelRoute instance</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">DawnModelRoute Creation Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Create routes for User model</span>
<span class="code-keyword">local</span> DawnModelRoute = <span class="code-keyword">require</span>(<span class="code-string">"path.to.dawn_model_route"</span>)
<span class="code-keyword">local</span> User = <span class="code-keyword">require</span>(<span class="code-string">"models.user"</span>)
<span class="code-keyword">local</span> DawnServer = <span class="code-keyword">require</span>(<span class="code-string">"dawn"</span>)

<span class="code-comment">-- Create the route instance</span>
<span class="code-keyword">local</span> user_route = DawnModelRoute:<span class="code-type">new</span>(<span class="code-string">"users"</span>, User, DawnServer)

<span class="code-comment">-- Initialize routes (registers them with the server)</span>
user_route:<span class="code-type">initialize</span>()

<span class="code-comment">-- Now the following routes are available:</span>
<span class="code-comment">-- GET    /api/users</span>
<span class="code-comment">-- GET    /api/users/:id</span>
<span class="code-comment">-- POST   /api/users</span>
<span class="code-comment">-- PUT    /api/users/:id</span>
<span class="code-comment">-- DELETE /api/users/:id</span></code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">initialize()</h4>
                    <p class="text-light-text-secondary mb-3">
                        Initializes and registers all CRUD API routes for the model with the server.
                        This method creates routes scoped under <code>/api/{model_name}</code>.
                    </p>
                    
                    <p class="mt-3"><strong>Returns:</strong> None</p>
                    <p class="mt-2"><strong>Side Effects:</strong> Registers routes with the DawnServer instance</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Generated Routes</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- After calling initialize(), these routes are registered:</span>

<span class="code-comment">-- GET /api/{model_name}</span>
<span class="code-comment">-- Retrieves all records with optional filtering and pagination</span>
<span class="code-comment">-- Example: GET /api/users?page=1&limit=10&name=John</span>

<span class="code-comment">-- GET /api/{model_name}/:id</span>
<span class="code-comment">-- Retrieves a single record by ID</span>
<span class="code-comment">-- Example: GET /api/users/123</span>

<span class="code-comment">-- POST /api/{model_name}</span>
<span class="code-comment">-- Creates a new record</span>
<span class="code-comment">-- Example: POST /api/users with JSON body</span>

<span class="code-comment">-- PUT /api/{model_name}/:id</span>
<span class="code-comment">-- Updates an existing record by ID</span>
<span class="code-comment">-- Example: PUT /api/users/123 with JSON body</span>

<span class="code-comment">-- DELETE /api/{model_name}/:id</span>
<span class="code-comment">-- Deletes a record by ID</span>
<span class="code-comment">-- Example: DELETE /api/users/123</span></code></pre>
                </div>
            </div>
        </section>

