                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Set user status to online</span>
redis_backend:<span class="code-type">set_user_status</span>(<span class="code-string">"user123"</span>, <span class="code-string">"online"</span>)

<span class="code-comment">-- Set user status to offline</span>
redis_backend:<span class="code-type">set_user_status</span>(<span class="code-string">"user456"</span>, <span class="code-string">"offline"</span>)

<span class="code-comment">-- Get user status</span>
<span class="code-keyword">local</span> status = redis_backend:<span class="code-type">get_user_status</span>(<span class="code-string">"user123"</span>)
print(<span class="code-string">"User status: "</span> .. status) <span class="code-comment">-- Output: "online"</span></code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">set_presence(topic, ws_id, user_id, meta)</h4>
                    <p class="text-light-text-secondary mb-3">Set presence information for a user in a specific topic/room.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>topic</td>
                                <td>string</td>
                                <td>The topic/room where presence is being set</td>
                            </tr>
                            <tr>
                                <td>ws_id</td>
                                <td>string</td>
                                <td>The websocket connection ID</td>
                            </tr>
                            <tr>
                                <td>user_id</td>
                                <td>string</td>
                                <td>The ID of the user (optional if using ws_id only)</td>
                            </tr>
                            <tr>
                                <td>meta</td>
                                <td>table</td>
                                <td>Additional metadata about the presence</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> None</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Presence Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Set presence for a user in a room</span>
<span class="code-keyword">local</span> presence_meta = {
    joined_at = os.time(),
    display_name = <span class="code-string">"John Doe"</span>,
    avatar_url = <span class="code-string">"https://example.com/avatar.jpg"</span>
}

redis_backend:<span class="code-type">set_presence</span>(<span class="code-string">"room_123"</span>, <span class="code-string">"ws_connection_456"</span>, <span class="code-string">"user123"</span>, presence_meta)

<span class="code-comment">-- Get all presence in a room</span>
<span class="code-keyword">local</span> all_presence = redis_backend:<span class="code-type">get_all_presence</span>(<span class="code-string">"room_123"</span>)
<span class="code-keyword">for</span> user_id, meta <span class="code-keyword">in</span> <span class="code-keyword">pairs</span>(all_presence) <span class="code-keyword">do</span>
    print(<span class="code-string">"User "</span> .. user_id .. <span class="code-string">" is present with meta: "</span> .. json.encode(meta))
<span class="code-keyword">end</span></code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">diff_presence(topic, old_state, new_state)</h4>
                    <p class="text-light-text-secondary mb-3">Calculate the difference between two presence states to detect joins and leaves.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>topic</td>
                                <td>string</td>
                                <td>The topic/room being analyzed</td>
                            </tr>
                            <tr>
                                <td>old_state</td>
                                <td>table</td>
                                <td>The previous presence state</td>
                            </tr>
                            <tr>
                                <td>new_state</td>
                                <td>table</td>
                                <td>The current presence state</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> Table with 'joins' and 'leaves' arrays containing user IDs</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Presence Diff Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Calculate presence changes</span>
<span class="code-keyword">local</span> old_presence = {
    user123 = { display_name = <span class="code-string">"John"</span> },
    user456 = { display_name = <span class="code-string">"Jane"</span> }
}

<span class="code-keyword">local</span> new_presence = {
    user123 = { display_name = <span class="code-string">"John"</span> },
    user789 = { display_name = <span class="code-string">"Bob"</span> }
}

<span class="code-keyword">local</span> changes = redis_backend:<span class="code-type">diff_presence</span>(<span class="code-string">"room_123"</span>, old_presence, new_presence)

print(<span class="code-string">"Users who joined: "</span> .. json.encode(changes.joins)) <span class="code-comment">-- ["user789"]</span>
print(<span class="code-string">"Users who left: "</span> .. json.encode(changes.leaves)) <span class="code-comment">-- ["user456"]</span></code></pre>
                </div>
