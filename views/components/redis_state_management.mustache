        <!-- Pub/Sub Section -->
        <section id="pubsub" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Pub/Sub Messaging</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Publish/Subscribe Pattern</h3>
                <p class="text-light-text-secondary mb-6">
                    Redis Pub/Sub allows real-time messaging between different parts of your application. 
                    Publishers send messages to channels, and subscribers receive those messages.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">subscribe(topic, callback)</h4>
                    <p class="text-light-text-secondary mb-3">Subscribe to a topic to receive messages published to that channel.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>topic</td>
                                <td>string</td>
                                <td>The channel/topic to subscribe to</td>
                            </tr>
                            <tr>
                                <td>callback</td>
                                <td>function</td>
                                <td>Function called when a message is received: function(received_topic, message_data)</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> None (blocking function)</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Subscribe Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Subscribe to a topic</span>
redis_backend:<span class="code-type">subscribe</span>(<span class="code-string">"user_updates"</span>, <span class="code-keyword">function</span>(topic, message)
    print(<span class="code-string">"Received message on topic: "</span> .. topic)
    print(<span class="code-string">"Message data: "</span> .. json.encode(message))
    
    <span class="code-comment">-- Handle the message based on its content</span>
    <span class="code-keyword">if</span> message.type == <span class="code-string">"user_joined"</span> <span class="code-keyword">then</span>
        print(<span class="code-string">"User joined: "</span> .. message.user_id)
    <span class="code-keyword">end</span>
<span class="code-keyword">end</span>)</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">publish(topic, message)</h4>
                    <p class="text-light-text-secondary mb-3">Publish a message to a specific topic/channel.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>topic</td>
                                <td>string</td>
                                <td>The channel/topic to publish to</td>
                            </tr>
                            <tr>
                                <td>message</td>
                                <td>table</td>
                                <td>The message data to publish (will be JSON encoded)</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> Number of clients that received the message</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Publish Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Publish a message to a topic</span>
<span class="code-keyword">local</span> message = {
    type = <span class="code-string">"user_joined"</span>,
    user_id = <span class="code-string">"user123"</span>,
    timestamp = os.time()
}

<span class="code-keyword">local</span> recipients = redis_backend:<span class="code-type">publish</span>(<span class="code-string">"user_updates"</span>, message)
print(<span class="code-string">"Message sent to "</span> .. recipients .. <span class="code-string">" subscribers"</span>)</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">unsubscribe(topic)</h4>
                    <p class="text-light-text-secondary mb-3">Unsubscribe from a topic to stop receiving messages.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>topic</td>
                                <td>string</td>
                                <td>The channel/topic to unsubscribe from</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> Redis reply indicating success</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Unsubscribe Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Unsubscribe from a topic</span>
redis_backend:<span class="code-type">unsubscribe</span>(<span class="code-string">"user_updates"</span>)
print(<span class="code-string">"Unsubscribed from user_updates topic"</span>)</code></pre>
                </div>
            </div>
