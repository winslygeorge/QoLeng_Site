                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Todo App using LuaReactive</span>
<span class="code-keyword">local</span> FunctionalComponent = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.FuncComponent"</span>)
<span class="code-keyword">local</span> HTML = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.LuaHTMLReactive"</span>)

<span class="code-keyword">local</span> TodoApp = FunctionalComponent:<span class="code-type">extends</span>()
TodoApp:<span class="code-type">setReactiveView</span>()

<span class="code-comment">-- Component methods for interactivity</span>
TodoApp.methods.addTodo = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
    <span class="code-keyword">local</span> newTodo = {
        id = <span class="code-keyword">tostring</span>(os.time()),
        text = args.text,
        completed = false
    }
    
    <span class="code-keyword">local</span> currentTodos = <span class="code-keyword">self</span>.state.todos <span class="code-keyword">or</span> {}
    table.insert(currentTodos, newTodo)
    
    <span class="code-keyword">self</span>:<span class="code-type">setState</span>({ todos = currentTodos })
<span class="code-keyword">end</span>

TodoApp.methods.toggleTodo = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
    <span class="code-keyword">local</span> todos = <span class="code-keyword">self</span>.state.todos <span class="code-keyword">or</span> {}
    <span class="code-keyword">for</span> i, todo <span class="code-keyword">in</span> <span class="code-keyword">ipairs</span>(todos) <span class="code-keyword">do</span>
        <span class="code-keyword">if</span> todo.id == args.id <span class="code-keyword">then</span>
            todo.completed = <span class="code-keyword">not</span> todo.completed
            <span class="code-keyword">break</span>
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>
    
    <span class="code-keyword">self</span>:<span class="code-type">setState</span>({ todos = todos })
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> TodoApp:<span class="code-type">renderLayout</span>(state, props, children, H)
    <span class="code-keyword">local</span> todos = state.todos <span class="code-keyword">or</span> {}
    
    <span class="code-keyword">return</span> H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"max-w-md mx-auto mt-8 p-6 bg-white rounded-lg shadow-lg"</span> }, {
        H.e(<span class="code-string">"h1"</span>, { class = <span class="code-string">"text-2xl font-bold mb-4"</span> }, <span class="code-string">"Todo App"</span>),
        
        <span class="code-comment">-- Add todo form</span>
        H.e(<span class="code-string">"form"</span>, {
            onSubmit = H.onSubmit(HTML.patch(<span class="code-keyword">self</span>.component_key, <span class="code-keyword">nil</span>, <span class="code-string">"addTodo"</span>, {}))
        }, {
            H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"flex gap-2 mb-4"</span> }, {
                H.e(<span class="code-string">"input"</span>, {
                    type = <span class="code-string">"text"</span>,
                    name = <span class="code-string">"text"</span>,
                    placeholder = <span class="code-string">"Add a new todo..."</span>,
                    class = <span class="code-string">"flex-1 p-2 border rounded"</span>,
                    required = true
                }),
                H.e(<span class="code-string">"button"</span>, {
                    type = <span class="code-string">"submit"</span>,
                    class = <span class="code-string">"bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600"</span>
                }, <span class="code-string">"Add"</span>)
            })
        }),
        
        <span class="code-comment">-- Todo list</span>
        H.e(<span class="code-string">"ul"</span>, { class = <span class="code-string">"space-y-2"</span> }, 
            #todos > 0 <span class="code-keyword">and</span> H.map(todos, <span class="code-keyword">function</span>(todo)
                <span class="code-keyword">return</span> H.e(<span class="code-string">"li"</span>, { 
                    class = <span class="code-string">"flex items-center gap-2 p-2 border rounded"</span> 
                }, {
                    H.e(<span class="code-string">"input"</span>, {
                        type = <span class="code-string">"checkbox"</span>,
                        checked = todo.completed,
                        onChange = H.onChange(HTML.patch(<span class="code-keyword">self</span>.component_key, <span class="code-keyword">nil</span>, <span class="code-string">"toggleTodo"</span>, { id = todo.id }))
                    }),
                    H.e(<span class="code-string">"span"</span>, { 
                        class = todo.completed <span class="code-keyword">and</span> <span class="code-string">"line-through text-gray-500"</span> <span class="code-keyword">or</span> <span class="code-string">""</span>
                    }, todo.text)
                })
            <span class="code-keyword">end</span>) <span class="code-keyword">or</span> {
                H.e(<span class="code-string">"li"</span>, { class = <span class="code-string">"text-gray-500 text-center py-4"</span> }, <span class="code-string">"No todos yet. Add one above!"</span>)
            }
        )
    })
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> TodoApp:<span class="code-type">startInit</span>()
    <span class="code-keyword">self</span>:<span class="code-type">init</span>(<span class="code-keyword">function</span>(server, children, props, style, H)
        <span class="code-keyword">return</span> <span class="code-keyword">function</span>(state, props, children, H)
            <span class="code-keyword">return</span> <span class="code-keyword">self</span>:<span class="code-type">renderLayout</span>(state, props, children, H)
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> TodoApp</code></pre>
