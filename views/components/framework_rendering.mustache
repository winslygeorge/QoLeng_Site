                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Parent component adding a child</span>
<span class="code-keyword">self</span>:<span class="code-type">addChildComponent</span>(<span class="code-string">"userPanel"</span>, userPanelComponent)

<span class="code-comment">-- Child component accessing parent state</span>
<span class="code-keyword">local</span> parentState = <span class="code-keyword">self</span>:<span class="code-type">getParentState</span>()

<span class="code-comment">-- Parent calling child method</span>
<span class="code-keyword">self</span>:<span class="code-type">callChildMethod</span>(<span class="code-string">"userPanel"</span>, <span class="code-string">"refreshData"</span>, ws_id, { force = true })

