        <!-- FuncComponent Features Section -->
        <section id="funccomponent" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-build-green flex items-center justify-center text-white font-bold mr-4">3</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">FuncComponent Features & API</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Core Component System</h3>
                <p class="text-light-text-secondary mb-6">
                    FuncComponent provides the foundation for both rendering approaches with a rich set of features
                    for state management, lifecycle handling, and component composition.
                </p>
                
                <div class="grid md:grid-cols-2 gap-6 mb-8">
                    <div class="feature-card bg-blue-50 p-6 rounded-lg border border-blue-100">
                        <h4 class="text-lg font-bold mb-3 text-laser-blue">Component Creation</h4>
                        <ul class="text-sm text-light-text-secondary">
                            <li class="mb-2"><span class="method-badge badge-both">extends()</span> Create a new component</li>
                            <li class="mb-2"><span class="method-badge badge-both">setServer(server)</span> Attach server instance</li>
                            <li class="mb-2"><span class="method-badge badge-both">setComponentKey(key)</span> Set unique identifier</li>
                            <li class="mb-2"><span class="method-badge badge-both">enableHotReload(server)</span> Enable development hot reload</li>
                        </ul>
                    </div>
                    
                    <div class="feature-card bg-green-50 p-6 rounded-lg border border-green-100">
                        <h4 class="text-lg font-bold mb-3 text-build-green">State Management</h4>
                        <ul class="text-sm text-light-text-secondary">
                            <li class="mb-2"><span class="method-badge badge-both">setState(newState)</span> Update component state</li>
                            <li class="mb-2"><span class="method-badge badge-both">getClientState(ws_id)</span> Get client-specific state</li>
                            <li class="mb-2"><span class="method-badge badge-both">setClientState(ws_id, newState)</span> Update client state</li>
                            <li class="mb-2"><span class="method-badge badge-both">pruneClientStates()</span> Clean up old client states</li>
                        </ul>
                    </div>
                    
                    <div class="feature-card bg-purple-50 p-6 rounded-lg border border-purple-100">
                        <h4 class="text-lg font-bold mb-3 text-query-purple">Component Composition</h4>
                        <ul class="text-sm text-light-text-secondary">
                            <li class="mb-2"><span class="method-badge badge-both">addChildComponent(key, component)</span> Add child component</li>
                            <li class="mb-2"><span class="method-badge badge-both">getChildComponent(key)</span> Get child by key</li>
                            <li class="mb-2"><span class="method-badge badge-both">registerChildMethods()</span> Expose child methods</li>
                            <li class="mb-2"><span class="method-badge badge-both">callChildMethod()</span> Invoke child method</li>
