                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Dashboard using Lustache templates</span>
<span class="code-keyword">local</span> FuncComponent = <span class="code-keyword">require</span>(<span class="code-string">'layout.renderer.FuncComponent'</span>)
<span class="code-keyword">local</span> Header = <span class="code-keyword">require</span>(<span class="code-string">'components.header'</span>)
<span class="code-keyword">local</span> Sidebar = <span class="code-keyword">require</span>(<span class="code-string">'components.sidebar'</span>)
<span class="code-keyword">local</span> StatsPanel = <span class="code-keyword">require</span>(<span class="code-string">'components.stats'</span>)

<span class="code-keyword">local</span> Dashboard = FuncComponent:<span class="code-type">extends</span>()

<span class="code-keyword">function</span> Dashboard:<span class="code-type">new</span>(config)
    <span class="code-keyword">local</span> instance = {
        config = config <span class="code-keyword">or</span> {}
    }
    <span class="code-keyword">return</span> <span class="code-keyword">self</span>.parent.<span class="code-type">new</span>(<span class="code-keyword">self</span>, instance)
<span class="code-keyword">end</span>

Dashboard:<span class="code-type">setView</span>(<span class="code-string">'layouts/dashboard'</span>)

<span class="code-keyword">function</span> Dashboard:<span class="code-type">initComponent</span>()
    <span class="code-keyword">self</span>:<span class="code-type">init</span>(<span class="code-keyword">function</span>(children, props, style)
        <span class="code-comment">-- Set dashboard data</span>
        props.dashboard = {
            title = <span class="code-keyword">self</span>.config.title <span class="code-keyword">or</span> <span class="code-string">"Dashboard"</span>,
            user = { name = <span class="code-string">"John Doe"</span>, role = <span class="code-string">"Admin"</span> },
            stats = {
                { label = <span class="code-string">"Users"</span>, value = 1243, change = +12 },
                { label = <span class="code-string">"Revenue"</span>, value = <span class="code-string">"$42.5K"</span>, change = +8 },
                { label = <span class="code-string">"Orders"</span>, value = 567, change = -3 }
            }
        }
        
        <span class="code-comment">-- Compose dashboard with components</span>
        children.header = Header:<span class="code-type">new</span>({ user = props.dashboard.user }):<span class="code-type">build</span>()
        children.sidebar = Sidebar:<span class="code-type">new</span>():<span class="code-type">build</span>()
        children.stats = StatsPanel:<span class="code-type">new</span>({ stats = props.dashboard.stats }):<span class="code-type">build</span>()
    <span class="code-keyword">end</span>)
    
    <span class="code-keyword">return</span> <span class="code-keyword">self</span>
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> Dashboard:<span class="code-type">render</span>()
    <span class="code-keyword">self</span>:<span class="code-type">initComponent</span>()
    <span class="code-keyword">return</span> <span class="code-keyword">self</span>:<span class="code-type">build</span>()
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> Dashboard</code></pre>
