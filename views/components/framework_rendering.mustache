        <!-- Lustache Section -->
        <section id="lustache" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-laser-blue flex items-center justify-center text-white font-bold mr-4">1</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">Lustache Template Rendering</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Template-Based Component System</h3>
                <p class="text-light-text-secondary mb-6">
                    Lustache provides a Mustache-compatible template engine for server-side rendering. 
                    Components use a layout-based approach where you define a main template and compose it with child components.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">setView(viewName)</h4>
                    <p class="text-light-text-secondary mb-3">Set the Mustache template to use for rendering this component.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>viewName</td>
                                <td>string</td>
                                <td>The name of the template file (without extension) located in ./views/</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> Self for method chaining</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Basic Lustache Component</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- MainComponent.lua</span>
<span class="code-keyword">local</span> FuncComponent = <span class="code-keyword">require</span>(<span class="code-string">'layout.renderer.FuncComponent'</span>)
<span class="code-keyword">local</span> navComponent = <span class="code-keyword">require</span>(<span class="code-string">'lib.components.navpage'</span>)
<span class="code-keyword">local</span> footer = <span class="code-keyword">require</span>(<span class="code-string">'lib.components.footerpage'</span>)
<span class="code-keyword">local</span> header = <span class="code-keyword">require</span>(<span class="code-string">'lib.components.headerpage'</span>)

<span class="code-keyword">local</span> MainComponent = FuncComponent:<span class="code-type">extends</span>()

<span class="code-comment">-- Set the main layout template</span>
MainComponent:<span class="code-type">setView</span>(<span class="code-string">'layouts/default'</span>)

<span class="code-keyword">function</span> MainComponent:<span class="code-type">startInit</span>()
    <span class="code-comment">-- Initialize the component with data and children</span>
    <span class="code-keyword">self</span>:<span class="code-type">init</span>(<span class="code-keyword">function</span> (children, props, style)
        <span class="code-comment">-- Set template data</span>
        props.layout_data = {
            title = <span class="code-string">"Home - Dawnserver"</span>,
            head_extra = <span class="code-string">'&lt;meta name="keywords" content="luajit, webserver, uwebsockets">'</span>,
            current_year = os.date(<span class="code-string">"%Y"</span>)
        }
        
        <span class="code-comment">-- Add child components to the layout</span>
        children.header = header:<span class="code-type">build</span>()
        children.nav = navComponent:<span class="code-type">build</span>()
        children.body = children.body <span class="code-keyword">or</span> <span class="code-string">""</span>
        <span class="code-comment">-- children.footer = footer:build()</span>
    <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> MainComponent:<span class="code-type">render_layout</span>()
    <span class="code-keyword">self</span>:<span class="code-type">startInit</span>()
    <span class="code-keyword">local</span> output = <span class="code-keyword">self</span>:<span class="code-type">build</span>()
    <span class="code-keyword">return</span> output
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> MainComponent</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">init(callback)</h4>
                    <p class="text-light-text-secondary mb-3">Initialize the component with data, children, and styling.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>callback</td>
                                <td>function</td>
                                <td>Function that receives (children, props, style, htmlBuilder, clientState) parameters</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <p class="mt-3"><strong>Returns:</strong> Self for method chaining</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Layout Template Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">&lt;!-- views/layouts/default.mustache --&gt;</span>
&lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
    &lt;title&gt;{{layout_data.title}}&lt;/title&gt;
    {{{layout_data.head_extra}}}
&lt;/head&gt;
&lt;body&gt;
    &lt;div id="app"&gt;
        {{{header}}}
        {{{nav}}}
        &lt;main&gt;
            {{{body}}}
        &lt;/main&gt;
        &lt;footer&gt;
            &lt;p&gt;© {{layout_data.current_year}} Dawn Framework&lt;/p&gt;
        &lt;/footer&gt;
    &lt;/div&gt;
&lt;/body&gt;
&lt;/html&gt;</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">build()</h4>
                    <p class="text-light-text-secondary mb-3">Render the component and its children into HTML.</p>
                    
                    <p class="mt-3"><strong>Returns:</strong> Rendered HTML string</p>
                </div>
            </div>
        </section>

        <!-- LuaReactive Section -->
        <section id="luareactive" class="mb-16 animate-fadeIn">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-query-purple flex items-center justify-center text-white font-bold mr-4">2</div>
                <h2 class="text-3xl font-bold text-neural-charcoal">LuaReactive Component System</h2>
            </div>
            
            <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-light-border">
                <h3 class="text-2xl font-bold mb-4 text-laser-blue">Reactive Virtual DOM Components</h3>
                <p class="text-light-text-secondary mb-6">
                    LuaReactive provides a reactive component system with virtual DOM diffing for highly interactive user interfaces.
                    Components can maintain state, respond to user interactions, and update efficiently.
                </p>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">setReactiveView()</h4>
                    <p class="text-light-text-secondary mb-3">Configure the component to use LuaReactive rendering.</p>
                    
                    <p class="mt-3"><strong>Returns:</strong> Self for method chaining</p>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block mb-6">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Basic LuaReactive Component</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- HomePage.lua</span>
<span class="code-keyword">local</span> FunctionalComponent = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.FuncComponent"</span>)
<span class="code-keyword">local</span> HTML = <span class="code-keyword">require</span>(<span class="code-string">"layout.renderer.LuaHTMLReactive"</span>)

<span class="code-keyword">local</span> HomePage = FunctionalComponent:<span class="code-type">extends</span>()
<span class="code-comment">-- Enable reactive rendering</span>
HomePage:<span class="code-type">setReactiveView</span>()

<span class="code-comment">-- Define component methods for interactivity</span>
HomePage.methods.sayHello = <span class="code-keyword">function</span>(<span class="code-keyword">self</span>, ws_id, args)
    <span class="code-keyword">local</span> ops = HTML.client.callModuleFn(<span class="code-string">"window"</span>, <span class="code-string">"alert"</span>, {<span class="code-string">"Hello, World!"</span>})
    <span class="code-keyword">self</span>:<span class="code-type">sendHTMLClientOperations</span>(ws_id, ops)
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> HomePage:<span class="code-type">renderLayout</span>(state, props, children, H)
    <span class="code-comment">-- Return virtual DOM using HTML builder functions</span>
    <span class="code-keyword">return</span> 
    H.e(<span class="code-string">"div"</span>, { id=props.routeId, class = <span class="code-string">"bg-[#FBFBFF] text-[#1A1A2E] font-sans"</span> }, {
        <span class="code-comment">-- Header section</span>
        H.e(<span class="code-string">"header"</span>, { class = <span class="code-string">"fixed top-0 left-0 right-0 z-50 py-6 bg-white/80 backdrop-blur-sm"</span> }, {
            H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"container mx-auto px-4"</span> }, {
                H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"flex justify-between items-center"</span> }, {
                    H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"flex items-center gap-3"</span> }, {
                        H.e(<span class="code-string">"div"</span>, { class = <span class="code-string">"w-10 h-10 bg-gradient-to-br from-[#0066FF] to-[#8A2BE2] rounded-lg flex items-center justify-center text-white font-bold"</span> }, <span class="code-string">"Q"</span>),
                        H.e(<span class="code-string">"span"</span>, { class = <span class="code-string">"text-2xl font-bold text-[#1A1A2E]"</span> }, <span class="code-string">"QoLeng"</span>)
                    })
                })
            })
        })
    })
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> HomePage:<span class="code-type">startInit</span>()
    <span class="code-keyword">self</span>:<span class="code-type">init</span>(<span class="code-keyword">function</span>(server, children, props, style, H)
        <span class="code-keyword">return</span> <span class="code-keyword">function</span>(state, props, children, H)
            <span class="code-keyword">return</span> <span class="code-keyword">self</span>:<span class="code-type">renderLayout</span>(state, props, children, H)
        <span class="code-keyword">end</span>
    <span class="code-keyword">end</span>)
<span class="code-keyword">end</span>

<span class="code-keyword">function</span> HomePage:<span class="code-type">load</span>()
    <span class="code-keyword">self</span>:<span class="code-type">startInit</span>()
<span class="code-keyword">end</span>

<span class="code-keyword">return</span> HomePage</code></pre>
                </div>
                
                <div class="function-signature">
                    <h4 class="font-bold text-lg mb-2">HTML Builder Functions</h4>
                    <p class="text-light-text-secondary mb-3">LuaReactive provides functions to create virtual DOM elements.</p>
                    
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Function</th>
                                <th>Parameters</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>H.e(tag, props, children)</td>
                                <td>tag (string), props (table), children (array)</td>
                                <td>Create a virtual DOM element</td>
                            </tr>
                            <tr>
                                <td>H.merge(...)</td>
                                <td>Multiple props tables</td>
                                <td>Merge multiple props objects</td>
                            </tr>
                            <tr>
                                <td>H.onClick(patch)</td>
                                <td>patch (table)</td>
                                <td>Create click handler that triggers a patch</td>
                            </tr>
                            <tr>
                                <td>HTML.patch(component, ws_id, method, args)</td>
                                <td>component (string), ws_id (string/nil), method (string), args (table)</td>
                                <td>Create a patch operation to call component methods</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <div class="bg-gray-800 text-gray-200 rounded-lg p-6 code-block">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-bold">Interactive Button Example</h4>
                        <button class="bg-laser-blue text-white px-3 py-1 rounded text-sm hover:bg-blue-700 transition-colors copy-btn">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Creating an interactive button with LuaReactive</span>
H.e(<span class="code-string">"button"</span>,
    H.merge(
        { class = <span class="code-string">"bg-[#0066FF] text-white px-8 py-4 rounded-lg font-semibold text-lg"</span> },
        H.onClick(
            HTML.patch(<span class="code-string">"modalManager"</span>, <span class="code-keyword">nil</span>, <span class="code-string">"showModal"</span>, {
                modalType = <span class="code-string">"promptModal"</span>,
                modalId = <span class="code-string">"getStartedModal"</span>,
                props = {
                    title = <span class="code-string">"Get Started with QoLeng"</span>,
                    message = <span class="code-string">"Welcome to QoLeng! Let's get started."</span>,
                    modalId = <span class="code-string">"getStartedModal"</span>
                }
            })
        )
    ),
    {
        H.e(<span class="code-string">"i"</span>, { class = <span class="code-string">"fas fa-bolt"</span> }),
        <span class="code-string">"Get Started →"</span>
    }
)</code></pre>
