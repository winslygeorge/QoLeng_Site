                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Server state (shared across all clients)</span>
<span class="code-keyword">self</span>:<span class="code-type">setState</span>({
    userCount = 42,
    serverTime = os.time()
})

<span class="code-comment">-- Client state (specific to each websocket connection)</span>
<span class="code-keyword">self</span>:<span class="code-type">setClientState</span>(ws_id, {
    theme = <span class="code-string">"dark"</span>,
    preferences = {
        notifications = true,
        language = <span class="code-string">"en"</span>
    }
})

<span class="code-comment">-- Access client state in render method</span>
<span class="code-keyword">local</span> clientState = <span class="code-keyword">self</span>:<span class="code-type">getClientState</span>(ws_id)
<span class="code-keyword">local</span> theme = clientState.theme <span class="code-keyword">or</span> <span class="code-string">"light"</span></code></pre>
