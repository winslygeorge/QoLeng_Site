            <div class="grid md:grid-cols-2 gap-6 mb-8">
                <div>
                    <h4 class="text-lg font-bold mb-3" style="color: var(--doc-text);">Synchronous Operations</h4>
                    <ul class="space-y-2" style="color: var(--doc-text-secondary);">
                        <li><code class="px-2 py-1 rounded text-sm" style="background: var(--doc-method-bg);">read_file</code> - Read file content</li>
                        <li><code class="px-2 py-1 rounded text-sm" style="background: var(--doc-method-bg);">write_file</code> - Write content to file</li>
