    <!-- File Operations Section -->
    <section id="file-ops" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">3</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">File Operations</h2>
