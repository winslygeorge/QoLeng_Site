                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- setInterval: Periodic task every 6 seconds</span>
<span class="keyword">local</span> timer = server:<span class="function">setInterval</span>(<span class="keyword">function</span>()
    print(<span class="string">"Periodic task executed at:"</span>, os.date(<span class="string">"%H:%M:%S"</span>))
<span class="keyword">end</span>, <span class="number">6000</span>)

<span class="comment">-- setTimeout: One-time task after 30 seconds</span>
server:<span class="function">setTimeout</span>(<span class="keyword">function</span>()
    print(<span class="string">"Timeout executed after 30 seconds"</span>)
    server:<span class="function">clearTimer</span>(timer)
<span class="keyword">end</span>, <span class="number">30000</span>)</code></pre>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Practical Timer Use Cases</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Health check monitoring (every 30 seconds)</span>
<span class="keyword">local</span> healthTimer = server:<span class="function">setInterval</span>(<span class="keyword">function</span>()
    <span class="comment">-- Check external service health</span>
    server:<span class="function">http_get</span>(<span class="string">"https://api.example.com/health"</span>, <span class="keyword">function</span>(res)
        <span class="keyword">if</span> res.status ~= <span class="number">200</span> <span class="keyword">then</span>
            print(<span class="string">"External service unhealthy!"</span>)
        <span class="keyword">end</span>
    <span class="keyword">end</span>)
<span class="keyword">end</span>, <span class="number">30000</span>)

<span class="comment">-- Cache warming (every 10 minutes)</span>
server:<span class="function">setInterval</span>(<span class="keyword">function</span>()
    warmCache(<span class="string">"popular_products"</span>)
    warmCache(<span class="string">"user_sessions"</span>)
<span class="keyword">end</span>, <span class="number">600000</span>)</code></pre>
            </div>
        </div>
    </section>

    <!-- HTTP Client Section -->
    <section id="http-client" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">2</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">HTTP Client</h2>
        </div>
        
        <div class="rounded-xl p-6 mb-8 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <h3 class="text-2xl font-bold mb-4" style="color: var(--laser-blue);">HTTP Request Methods</h3>
            
            <div class="grid md:grid-cols-2 gap-6 mb-8">
                <div>
                    <h4 class="text-lg font-bold mb-3" style="color: var(--doc-text);">Convenience Methods</h4>
                    <div class="space-y-2">
                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_get</code><span style="color: var(--doc-text-secondary);">Make GET requests</span></div>
                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_post</code><span style="color: var(--doc-text-secondary);">Make POST requests</span></div>
                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_put</code><span style="color: var(--doc-text-secondary);">Make PUT requests</span></div>
                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_patch</code><span style="color: var(--doc-text-secondary);">Make PATCH requests</span></div>
                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_delete</code><span style="color: var(--doc-text-secondary);">Make DELETE requests</span></div>
                    </div>
                </div>
                
                <div>
                    <h4 class="text-lg font-bold mb-3" style="color: var(--doc-text);">Advanced Methods</h4>
                    <div class="space-y-2">
