                </div>
                
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--build-green), var(--query-purple));">
                        <i class="fas fa-globe"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">HTTP Client</h3>
                    <p style="color: var(--doc-text-secondary);">Make external HTTP requests with full method support</p>
                </div>
                
                <div class="feature-card">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white mb-4" style="background: linear-gradient(135deg, var(--query-purple), var(--warning-amber));">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: var(--doc-text);">File Operations</h3>
                    <p style="color: var(--doc-text-secondary);">Sync/async file operations with streaming support</p>
                </div>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - Quick Feature Overview</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Timer example</span>
<span class="keyword">local</span> timer = server:<span class="function">setInterval</span>(<span class="keyword">function</span>()
    print(<span class="string">"Running every 5 seconds"</span>)
<span class="keyword">end</span>, <span class="number">5000</span>)

<span class="comment">-- HTTP request example</span>
server:<span class="function">http_get</span>(<span class="string">"https://api.example.com/data"</span>, <span class="keyword">function</span>(res)
    print(<span class="string">"Response:"</span>, res.body)
<span class="keyword">end</span>)

<span class="comment">-- File operation example</span>
<span class="keyword">local</span> content, err = server:<span class="function">read_file</span>(<span class="string">"config.json"</span>)
<span class="keyword">if</span> <span class="keyword">not</span> err <span class="keyword">then</span>
    print(<span class="string">"File content:"</span>, content)
<span class="keyword">end</span></code></pre>
            </div>
        </div>
    </section>

    <!-- Timer Management Section -->
    <section id="timers" class="mb-16 animate-fadeIn">
        <div class="flex items-center mb-6">
            <div class="section-number">1</div>
            <h2 class="text-3xl font-bold" style="color: var(--doc-text);">Timer Management</h2>
        </div>
        
        <div class="rounded-xl p-6 mb-8 border" style="background: var(--doc-card-bg); border-color: var(--doc-border);">
            <h3 class="text-2xl font-bold mb-4" style="color: var(--laser-blue);">Timer Functions Overview</h3>
            
            <div class="grid md:grid-cols-3 gap-4 mb-8">
                <div class="p-4 rounded-lg border" style="background: var(--doc-badge-blue); border-color: var(--doc-border);">
                    <span class="method-badge badge-blue">setInterval</span>
                    <p class="text-sm mt-2" style="color: var(--doc-text-secondary);">Execute a function repeatedly at specified intervals</p>
                </div>
                <div class="p-4 rounded-lg border" style="background: var(--doc-badge-green); border-color: var(--doc-border);">
                    <span class="method-badge badge-green">setTimeout</span>
                    <p class="text-sm mt-2" style="color: var(--doc-text-secondary);">Execute a function once after a delay</p>
                </div>
                <div class="p-4 rounded-lg border" style="background: var(--doc-badge-purple); border-color: var(--doc-border);">
                    <span class="method-badge badge-purple">clearTimer</span>
                    <p class="text-sm mt-2" style="color: var(--doc-text-secondary);">Cancel a scheduled timer</p>
