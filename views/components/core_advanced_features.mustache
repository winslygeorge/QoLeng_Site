                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_options</code><span style="color: var(--doc-text-secondary);">Make OPTIONS requests</span></div>
                        <div class="flex items-start"><code class="px-2 py-1 rounded text-sm mr-2" style="background: var(--doc-method-bg);">http_request</code><span style="color: var(--doc-text-secondary);">Generic request with custom method</span></div>
                    </div>
                </div>
            </div>
            
            <div class="code-block">
                <div class="code-header">
                    <span class="code-language"><i class="fab fa-lua"></i> Lua - GET Request Example</span>
                    <button class="copy-btn" onclick="copyCode(this)"><i class="fas fa-copy"></i> Copy</button>
                </div>
                <pre><code><span class="comment">-- Simple GET request</span>
server:<span class="function">http_get</span>(<span class="string">"https://randomuser.me/api/"</span>, <span class="keyword">function</span>(res)
    <span class="keyword">if</span> res.error <span class="keyword">then</span>
        print(<span class="string">"GET failed:"</span>, res.error)
        <span class="keyword">return</span>
    <span class="keyword">end</span>
    
    print(<span class="string">"Status:"</span>, res.status)
    print(<span class="string">"Body:"</span>, res.body)
<span class="keyword">end</span>)

<span class="comment">-- GET with custom headers</span>
server:<span class="function">http_get</span>(<span class="string">"https://api.example.com/profile"</span>, <span class="keyword">function</span>(res)
    print(<span class="string">"Status:"</span>, res.status)
<span class="keyword">end</span>, {
    [<span class="string">"Authorization"</span>] = <span class="string">"Bearer 12345"</span>,
    [<span class="string">"X-Client"</span>] = <span class="string">"DawnServer"</span>
})</code></pre>
