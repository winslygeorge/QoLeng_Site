                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="code-comment">-- Create a periodic task that runs every 6 seconds</span>
<span class="code-keyword">local</span> timer = server:<span class="code-type">setInterval</span>(<span class="code-keyword">function</span>()
    <span class="code-comment">-- Place your periodic task code here</span>
    print(<span class="code-string">"Periodic task executed at:"</span>, os.date(<span class="code-string">"%H:%M:%S"</span>))
<span class="code-keyword">end</span>, 6000)  <span class="code-comment">-- 6000 milliseconds = 6 seconds</span>

print(<span class="code-string">"Starting timer with ID:"</span>, timer)

<span class="code-comment">-- The timer ID can be used to stop the interval later</span>
<span class="code-comment">-- server:clearTimer(timer)</span></code></pre>
                </div>
                
                <h4 class="text-xl font-bold mb-4 text-query-purple">setTimeout - Delayed Execution</h4>
